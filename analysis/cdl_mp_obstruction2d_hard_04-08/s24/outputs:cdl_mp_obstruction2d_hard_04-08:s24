                              NUM_OBSTRUCTIONS, NAV_CLEAR_Y)
    grasp_y = max(NAV_CLEAR_Y, obj_cy)  # can't go below min safe y

    candidates = [
        (obj_cx - GRASP_REACH, grasp_y, 0.0),      # approach from left
        (obj_cx + GRASP_REACH, grasp_y, np.pi),     # approach from right
    ]

    # Build obstacle rects (all except skip_idx)
    rects = []
    for i in range(NUM_OBSTRUCTIONS):
