 blocking.add(j)\n\n        blocker_candidates = []\n        for j in blocking:\n            if obstruction_on_surface(obs, j):\n                continue   # already in surface_candidates\n            ob_j = get_obstruction(obs, j)\n            pick_y_j = pickup_robot_y(ob_j[\"top\"])\n            pick_x_j = safe_pick_x(obs, j, ob_j, pick_y_j)\n            if self._pick_x_is_valid(obs, j, ob_j, pick_x_j, pick_y_j):\n                blocker_candidates.append((j, ob_j, pick_x_j, pick_y_j))\n\n        if blocker_candidates:\n            j, ob_j, pick_x_j, pick_y_j = max(blocker_candidates, key=lambda t: t[1][\"top\"])\n            self._pick_x = pick_x_j\n            self._pick_y = pick_y_j\n            self._dep_x  = choose_deposit_x(obs, j, ob_j, block, pick_x=self._pick_x)\n            self._dep_y  = self._pick_y\n            self._phase  = _P_RAISE\n            return\n\n        # Priority 3: fallback — tallest on-surface obstruction\n        i, ob = max(surface_candidates, key=lambda t: t[1][\"top\"])\n        pick_y = pickup_robot_y(ob[\"top\"])\n        self._pick_y = pick_y\n        self._pick_x = safe_pick_x(obs, i, ob, pick_y)\n        self._dep_x  = choose_deposit_x(obs, i, ob, block, pick_x=self._pick_x)\n        self._dep_y  = self._pick_y\n        self._phase  = _P_RAISE","originalFile":"\"\"\"Behavior classes for Obstruction2D-o4-v0.\"\"\"\nimport numpy as np\nfrom behavior import Behavior\nfrom obs_helpers import (\n    get_robot, get_surface, get_block, get_obstruction,\n    any_obstruction_on_surface, obstruction_on_surface, is_block_on_surface,\n    NUM_OBS, intervals_overlap_strict,\n)\nfrom act_helpers import (\n    make_action, move_1d, correct_theta,\n    ARM_MIN, ARM_TOL, XY_TOL, THETA_TOL,\n    TARGET_THETA, DX_MAX, DY_MAX, DARM_MAX,\n    CARRY_HEIGHT, PICKUP_OFFSET,\n    pickup_robot_y, choose_deposit_x, safe_pick_x,\n    _circle_rect_dist,\n)\n\n# ── FSM phase labels ──────────────────────────────────────────────────────────\n_P_PLAN       = \"PLAN\"\n_P_RAISE      = \"RAISE\"       # lift to CARRY_HEIGHT before lateral movement\n_P_APPROACH_X = \"APPROACH_X\"\n_P_APPROACH_Y = \"APPROACH_Y\"\n_P_CORRECT_TH = \"CORRECT_THETA\"\n_P_VACUUM_ON  = \"VACUUM_ON\"\n_P_LIFT       = \"LIFT\"\n_P_CARRY_X    = \"CARRY_X\"\n_P_LOWER      = \"LOWER\"      # only for target-block placement\n_P_VACUUM_OFF = \"VACUUM_OFF\"\n_P_DONE       = \"DONE\"\n\n\nclass _PickPlaceFSM:\n    \"\"\"\n    Generic pick-and-place FSM (mixin).\n\n    Subclasses set:\n      self._pick_x  : target robot x for pickup\n      self._pick_y  : target robot y for pickup  (obj_top + ARM_MIN + PICKUP_OFFSET)\n      self._dep_x   : target robot x for deposit\n      self._dep_y   : target robot y for deposit (CARRY_HEIGHT for obstructions;\n                       pick_y for block-on-surface)\n    then call self._phase = _P_APPROACH_X to start.\n    \"\"\"\n\n    def _fsm_reset_state(self):\n        self._phase  = _P_DONE\n        self._pick_x = None\n        self._pick_y = None\n        self._dep_x  = None\n        self._dep_y  = CARRY_HEIGHT\n\n    def _fsm_done(self):\n        return self._phase == _P_DONE\n\n    def _fsm_step(self, obs):\n        r = get_robot(obs)\n\n        # ── RAISE: lift to CARRY_HEIGHT before any lateral movement ──────────\n        if self._phase == _P_RAISE:\n            dy   = move_1d(r[\"y\"], CARRY_HEIGHT, DY_MAX)\n            darm = move_1d(r[\"arm_joint\"], ARM_MIN, DARM_MAX)\n            dth  = correct_theta(r[\"theta\"])\n            if abs(r[\"y\"] - CARRY_HEIGHT) < XY_TOL and r[\"arm_joint\"] <= ARM_MIN + ARM_TOL:\n                self._phase = _P_APPROACH_X\n            return make_action(dy=dy, darm=darm, dtheta=dth, vac=0.0)\n\n        # ── APPROACH_X: move x to pick_x, arm retracted ───────────────────────\n        if self._phase == _P_APPROACH_X:\n            dx   = move_1d(r[\"x\"], self._pick_x, DX_MAX)\n            darm = move_1d(r[\"arm_joint\"], ARM_MIN, DARM_MAX)\n            dth  = correct_theta(r[\"theta\"])\n            if abs(r[\"x\"] - self._pick_x) < XY_TOL and r[\"arm_joint\"] <= ARM_MIN + ARM_TOL:\n                self._phase = _P_APPROACH_Y\n            return make_action(dx=dx, darm=darm, dtheta=dth, vac=0.0)\n\n        # ── APPROACH_Y: lower to pickup height ────────────────────────────────\n        if self._phase == _P_APPROACH_Y:\n            dy  = move_1d(r[\"y\"], self._pick_y, DY_MAX)\n            dth = correct_theta(r[\"theta\"])\n            if abs(r[\"y\"] - self._pick_y) < XY_TOL:\n                self._phase = _P_CORRECT_TH\n            return make_action(dy=dy, dtheta=dth, vac=0.0)\n\n        # ── CORRECT_THETA: ensure arm points straight down ────────────────────\n        if self._phase == _P_CORRECT_TH:\n            dth = correct_theta(r[\"theta\"])\n            if abs(r[\"theta\"] - TARGET_THETA) < THETA_TOL:\n                self._phase = _P_VACUUM_ON\n            return make_action(dtheta=dth, vac=0.0)\n\n        # ── VACUUM_ON: activate vacuum (object suctioned on next step) ────────\n        if self._phase == _P_VACUUM_ON:\n            self._phase = _P_LIFT\n            return make_action(vac=1.0)\n\n        # ── LIFT: raise robot to CARRY_HEIGHT ─────────────────────────────────\n        if self._phase == _P_LIFT:\n            dy  = move_1d(r[\"y\"], CARRY_HEIGHT, DY_MAX)\n            dth = correct_theta(r[\"theta\"])\n            if abs(r[\"y\"] - CARRY_HEIGHT) < XY_TOL:\n                self._phase = _P_CARRY_X\n            return make_action(dy=dy, dtheta=dth, vac=1.0)\n\n        # ── CARRY_X: move to deposit x ────────────────────────────────────────\n        if self._phase == _P_CARRY_X:\n            dx  = move_1d(r[\"x\"], self._dep_x, DX_MAX)\n            dth = correct_theta(r[\"theta\"])\n            if abs(r[\"x\"] - self._dep_x) < XY_TOL:\n                self._phase = _P_LOWER\n            return make_action(dx=dx, dtheta=dth, vac=1.0)\n\n        # ── LOWER: descend to deposit height ──────────────────────────────────\n        if self._phase == _P_LOWER:\n            dy  = move_1d(r[\"y\"], self._dep_y, DY_MAX)\n            dth = correct_theta(r[\"theta\"])\n            if abs(r[\"y\"] - self._dep_y) < XY_TOL:\n                self._phase = _P_VACUUM_OFF\n            return make_action(dy=dy, dtheta=dth, vac=1.0)\n\n        # ── VACUUM_OFF: release object ────────────────────────────────────────\n        if self._phase == _P_VACUUM_OFF:\n            self._phase = _P_DONE\n            return make_action(vac=0.0)\n\n        return make_action()   # DONE\n\n\n# ══════════════════════════════════════════════════════════════════════════════\nclass ClearObstructionsBehavior(_PickPlaceFSM, Behavior):\n    \"\"\"\n    Iterates over all obstructions that overlap the target surface,\n    picks each one up, lifts it, and drops it at a clear deposit location\n    (at CARRY_HEIGHT = no-gravity \"mid-air\" deposit).\n    Terminates when no obstruction overlaps the surface.\n    \"\"\"\n\n    def reset(self, obs):\n        self._fsm_reset_state()\n        self._start_plan(obs)\n\n    def initializable(self, obs):\n        return True\n\n    def terminated(self, obs):\n        return self._fsm_done() and not any_obstruction_on_surface(obs)\n\n    def step(self, obs):\n        if self.terminated(obs):\n            return make_action()\n\n        if self._fsm_done():\n            self._start_plan(obs)\n\n        if self._fsm_done():\n            return make_action()\n\n        return self._fsm_step(obs)\n\n    def _start_plan(self, obs):\n        # Collect all obstructions on the surface; pick tallest first to avoid\n        # robot-base collisions when approaching shorter obstructions nearby.\n        candidates = [\n            (i, get_obstruction(obs, i))\n            for i in range(NUM_OBS)\n            if obstruction_on_surface(obs, i)\n        ]\n        if not candidates:\n            self._phase = _P_DONE\n            return\n        i, ob = max(candidates, key=lambda t: t[1][\"top\"])\n        block = get_block(obs)\n        pick_y = pickup_robot_y(ob[\"top\"])\n        self._pick_y = pick_y\n        self._pick_x = safe_pick_x(obs, i, ob, pick_y)\n        self._dep_x  = choose_deposit_x(obs, i, ob, block, pick_x=self._pick_x)\n        self._dep_y  = self._pick_y      # release at table level\n        self._phase  = _P_RAISE\n\n\n# ══════════════════════════════════════════════════════════════════════════════\nclass PickAndPlaceBehavior(_PickPlaceFSM, Behavior):\n    \"\"\"\n    Picks up the target block and places it on the target surface.\n    Precondition: no obstructions on target surface.\n    \"\"\"\n\n    def reset(self, obs):\n        self._fsm_reset_state()\n        self._setup(obs)\n\n    def _setup(self, obs):\n        b = get_block(obs)\n        s = get_surface(obs)\n        self._pick_x   = b[\"cx\"]\n        self._pick_y   = pickup_robot_y(b[\"top\"])\n        self._dep_x    = s[\"cx\"]\n        # Deposit at same robot_y as pickup → block lands at same y (≈ table level)\n        self._dep_y    = pickup_robot_y(b[\"top\"])\n        self._phase    = _P_RAISE\n\n    def initializable(self, obs):\n        return not any_obstruction_on_surface(obs)\n\n    def terminated(self, obs):\n        return is_block_on_surface(obs)\n\n    def step(self, obs):\n        if self.terminated(obs):\n            return make_action()\n\n        if self._fsm_done():\n            # Retry: re-read block position (it may have drifted)\n            self._fsm_reset_state()\n            self._setup(obs)\n\n        return self._fsm_step(obs)\n","structuredPatch":[{"oldStart":156,"oldLines":24,"newStart":156,"newLines":95,"lines":[" ","         return self._fsm_step(obs)"," ","+    def _pick_x_is_valid(self, obs, i, ob, pick_x, pick_y):","+        \"\"\"Return True if robot at (pick_x, pick_y) is collision-free w.r.t. all other obs.\"\"\"","+        for j in range(NUM_OBS):","+            if j == i:","+                continue","+            ob_j = get_obstruction(obs, j)