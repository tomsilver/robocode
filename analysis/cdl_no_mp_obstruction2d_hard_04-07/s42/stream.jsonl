posit_x(obs, i, ob[\"w\"], block[\"cx\"])\n        self._dep_y  = self._pick_y      # release at table level\n        self._phase  = _P_RAISE\n\n\n# ══════════════════════════════════════════════════════════════════════════════\nclass PickAndPlaceBehavior(_PickPlaceFSM, Behavior):\n    \"\"\"\n    Picks up the target block and places it on the target surface.\n    Precondition: no obstructions on target surface.\n    \"\"\"\n\n    def reset(self, obs):\n        self._fsm_reset_state()\n        self._setup(obs)\n\n    def _setup(self, obs):\n        b = get_block(obs)\n        s = get_surface(obs)\n        self._pick_x   = b[\"cx\"]\n        self._pick_y   = pickup_robot_y(b[\"top\"])\n        self._dep_x    = s[\"cx\"]\n        # Deposit at same robot_y as pickup → block lands at same y (≈ table level)\n        self._dep_y    = pickup_robot_y(b[\"top\"])\n        self._phase    = _P_RAISE\n\n    def initializable(self, obs):\n        return not any_obstruction_on_surface(obs)\n\n    def terminated(self, obs):\n        return is_block_on_surface(obs)\n\n    def step(self, obs):\n        if self.terminated(obs):\n            return make_action()\n\n        if self._fsm_done():\n            # Retry: re-read block position (it may have drifted)\n            self._fsm_reset_state()\n            self._setup(obs)\n\n        return self._fsm_step(obs)\n","structuredPatch":[{"oldStart":168,"oldLines":9,"newStart":168,"newLines":10,"lines":["             return","         i, ob = max(candidates, key=lambda t: t[1][\"top\"])","         block = get_block(obs)","-        self._pick_x = ob[\"cx\"]","-        self._pick_y = pickup_robot_y(ob[\"top\"])","-        self._dep_x  = choose_deposit_x(obs, i, ob[\"w\"], block[\"cx\"])","+        pick_y = pickup_robot_y(ob[\"top\"])","+        self._pick_y = pick_y","+        self._pick_x = safe_pick_x(obs, i, ob, pick_y)","+        self._dep_x  = choose_deposit_x(obs, i, ob, block)","         self._dep_y  = self._pick_y      # release at 