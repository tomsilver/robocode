═════════════════════════════════════════\nclass ClearObstructionsBehavior(_PickPlaceFSM, Behavior):\n    \"\"\"\n    Iterates over all obstructions that overlap the target surface,\n    picks each one up, and deposits it at a clear location.\n    Terminates when no obstruction overlaps the surface.\n    \"\"\"\n\n    def reset(self, obs):\n        self._fsm_reset()\n        self._obs_idx = 0          # which obstruction we're working on\n        self._dep_counter = 0      # deposit counter for varied x positions\n        self._start_plan(obs)\n\n    def initializable(self, obs):\n        return True   # can always start from scratch\n\n    def terminated(self, obs):\n        return not any_obstruction_on_surface(obs)\n\n    def step(self, obs):\n        if self.terminated(obs):\n            return make_action()\n\n        # If current sub-task is done, plan next\n        if self._fsm_done():\n            self._fsm_reset()\n            self._start_plan(obs)\n\n        if self._fsm_done():\n            # Nothing left to do\n            return make_action()\n\n        return self._fsm_step(obs)\n\n    def _start_plan(self, obs):\n        \"\"\"Find next obstruction on surface and set up pick/place targets.\"\"\"\n        for i in range(NUM_OBS):\n            if obstruction_on_surface(obs, i):\n                ob = get_obstruction(obs, i)\n                obj_y = ob[\"y\"]\n                self._pick_x  = ob[\"x\"]\n                self._pick_y  = pickup_robot_y(obj_y)\n                self._dep_x   = deposit_x_for_obstruction(self._dep_counter)\n                self._dep_counter += 1\n                self._phase   = _P_APPROACH_X\n                return\n        # No obstruction on surface → stay DONE\n        self._phase = _P_DONE\n\n\n# ══════════════════════════════════════════════════════════════════════════════\nclass PickAndPlaceBehavior(_PickPlaceFSM, Behavior):\n    \"\"\"\n    Picks up the target block and places it at the center of the target surface.\n    Precondition: no obstructions on target surface.\n    \"\"\"\n\n    def reset(self, obs):\n        self._fsm_reset()\n        self._setup(obs)\n\n    def _setup(self, obs):\n        b = get_block(obs)\n        s = get_surface(obs)\n        self._pick_x = b[\"x\"]\n        self._pick_y = pickup_robot_y(b[\"y\"])\n        self._dep_x  = s[\"x\"]   # place at surface center\n        self._phase  = _P_APPROACH_X\n\n    def initializable(self, obs):\n        return not any_obstruction_on_surface(obs)\n\n    def terminated(self, obs):\n        return is_block_on_surface(obs)\n\n    def step(self, obs):\n        if self.terminated(obs):\n            return make_action()\n\n        # Replan if FSM is done but block isn't on surface yet (e.g. misaligned)\n        if self._fsm_done():\n            self._fsm_reset()\n            # Update pick target in case block moved\n            self._setup(obs)\n\n        return self._fsm_step(obs)\n","structuredPatch":[],"originalFile":null}}
