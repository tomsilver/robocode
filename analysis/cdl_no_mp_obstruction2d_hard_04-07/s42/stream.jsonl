X,     DX_MAX),\n81\t        clamp(dy,     -DY_MAX,     DY_MAX),\n82\t        clamp(dtheta, -DTHETA_MAX, DTHETA_MAX),\n83\t        clamp(darm,   -DARM_MAX,   DARM_MAX),\n84\t        clamp(vac,    0.0,         1.0),\n85\t    ], dtype=np.float32)\n86\t\n87\t\n88\tdef pickup_robot_y(obj_top):\n89\t    \"\"\"Target robot_y to hover just above obj_top with arm retracted at ARM_MIN.\n90\t    Window: (obj_top + 0.105, obj_top + 0.110) — use midpoint.\n91\t    \"\"\"\n92\t    return obj_top + PICKUP_OFFSET   # = obj_top + 0.108\n93\t\n94\t\n95\tdef choose_deposit_x(obs, carried_idx, carried_w, block_cx):\n96\t    \"\"\"\n97\t    Scan x positions and return the first one where the carried object\n98\t    (width=carried_w) won't x-overlap any other obstruction, the surface,\n99\t    or the robot's approach zone for the target block.\n100\t    Clearance = max(carried_w/2, ARM_MIN) + a small margin.\n101\t    \"\"\"\n102\t    from obs_helpers import get_surface, get_obstruction, NUM_OBS, intervals_overlap_strict\n103\t    s = get_surface(obs)\n104\t    half = max(carried_w / 2, ARM_MIN) + 0.01  # generous clearance\n105\t\n106\t    x = DEPOSIT_X_SCAN_START\n107\t    while x <= DEPOSIT_X_SCAN_END + 1e-9:\n108\t        lo, hi = x - half, x + half\n109\t        # Avoid target surface\n110\t        if intervals_overlap_strict(lo, hi, s[\"x\"], s[\"x\"] + s[\"w\"]):\n111\t            x += DEPOSIT_X_SCAN_STEP; continue\n112\t        # Avoid block approach zone: the deposited object's x-extent must not\n113\t        # overlap the robot-base zone when robot is at block_cx.\n114\t        dep_lo_obj = x - carried_w / 2\n115\t        dep_hi_obj = x + carried_w / 2\n116\t        if intervals_overlap_strict(dep_lo_obj, dep_hi_obj, block_cx - ARM_MIN, block_cx + ARM_MIN):\n117\t            x += DEPOSIT_X_SCAN_STEP; continue\n118\t        # Avoid all obstructions except the one being carried\n119\t        blocked = False\n120\t        for j in range(NUM_OBS):\n121\t            if j == carried