   # ── POST_RETRACT: retract arm ─────────────────────────────────────────","-        if phase == _P_POST_RET:","-            darm = move_1d(r[\"arm_joint\"], ARM_MIN, DARM_MAX)","-            if r[\"arm_joint\"] <= ARM_MIN + ARM_TOL:","-                self._phase = _P_DONE","-            return make_action(darm=darm, vac=0.0)","+        return make_action()   # DONE"," ","-        # ── DONE ──────────────────────────────────────────────────────────────","-        return make_action()"," ","-    @staticmethod","-    def _correct_theta(current_theta):","-        return angle_diff(TARGET_THETA, current_theta)","-","-"," # ══════════════════════════════════════════════════════════════════════════════"," class ClearObstructionsBehavior(_PickPlaceFSM, Behavior):","     \"\"\"","     Iterates over all obstructions that overlap the target surface,","-    picks each one up, and deposits it at a clear location.","+    picks each one up, lifts it, and drops it at a clear deposit location","+    (at CARRY_HEIGHT = no-gravity \"mid-air\" deposit).","     Terminates when no obstruction overlaps the surface.","     \"\"\""," ","     def reset(self, obs):","-        self._fsm_reset()","-        self._obs_idx = 0          # which obstruction we're working on","-        self._dep_counter = 0      # deposit counter for varied x positions","+        self._fsm_reset_state()","+        self._dep_counter = 0","         self._start_plan(obs)"," ","     def initializable(self, obs):","-        return True   # can always start from scratch","+        return True"," ","     def terminated(self, obs):","         return not any_obstruction_on_surface(obs)"]},{"oldStart":159,"oldLines":51,"newStart":138,"newLines":48,"lines":["         if self.terminated(obs):","             return make_action()"," ","-        # If current sub-task is done, plan next","         if self._fsm_done():","-            self._fsm_reset()","             self._start_plan(obs)"," ","         if self._fsm_done():","-            # Nothing left to do","             return make_action()"," ","         return self._fsm_step(obs)"," ","     def _start_plan(self, obs):","-        \"\"\"Find next obstruction on surface and set up pick/place targets.\"\"\"","         for i in range(NUM_OBS):","             if obstruction_on_surface(obs, i):","                 ob = get_obstruction(obs, i)","-                obj_y = ob[\"y\"]","-                self._pick_x  = ob[\"x\"]","-                self._pick_y  = pickup_robot_y(obj_y)","-                self._dep_x   = deposit_x_for_obstruction(self._dep_counter)","+                self._pick_x = ob[\"cx\"]","+                self._pick_y = pickup_robot_y(ob[\"top\"])","+                self._dep_x  = deposit_x_for_index(self._dep_counter)","+                self._dep_y  = CARRY_HEIGHT      # release in mid-air (no gravity)","                 self._dep_counter += 1","-                self._phase   = _P_APPROACH_X","+                self._phase = _P_APPROACH_X","                 return","-        # No obstruction on surface → stay DONE","         self._phase = _P_DONE"," "," "," # ══════════════════════════════════════════════════════════════════════════════"," class PickAndPlaceBehavior(_PickPlaceFSM, Behavior):","     \"\"\"","-    Picks up the target block and places it at the center of the target surface.","+    Picks up the target block and places it on the target surface.","     Precondition: no obstructions on target surface.","     \"\"\""," ","     def reset(self, obs):","-        self._fsm_reset()","+        self._fsm_reset_state()","         self._setup(obs)"," ","     def _setup(self, obs):","         b = get_block(obs)","         s = get_surface(obs)","-        self._pick_x = b[\"x\"]","-        self._pick_y = pickup_robot_y(b[\"y\"])","-        self._dep_x  = s[\"x\"]   # place at surface center","-        self._phase  = _P_APPROACH_X","+        self._pick_x   = b[\"cx\"]","+        self._pick_y   = pickup_robot_y(b[\"top\"])","+        self._dep_x    = s[\"cx\"]","+        # Deposit at same robot_y as pickup → block lands at same y (≈ table level)","+        self._dep_y    = pickup_robot_y(b[\"top\"])","+        self._phase    = _P_APPROACH_X"," ","     def initializable(self, obs):","         return not any_obstruction_on_surface(obs)"]},{"oldStart":215,"oldLines":10,"newStart":191,"newLines":9,"lines":["         if self.terminated(obs):","             return make_action()"," ","-        # Replan if FSM is done but block isn't on surface yet (e.g. misaligned)","         if self._fsm_done():","-            self._fsm_reset()","-            # Update pick target in case block moved","+            # Retry: re-read block position (it may have drifted)","+            self._fsm_reset_state()","             self._setup(obs)"," ","         return self._fsm_step(obs)"]}],"originalFile":"\"\"\"Behavior classes for Obstruction2D-o4-v0.\"\"\"\nimport numpy as np\nfrom behavior import Behavior\nfrom obs_helpers import (\n    get_robot, get_surface, get_block, get_obstruction,\n    any_obstruction_on_surface, obstruction_on_surface, is_block_on_surface,\n    NUM_OBS, suction_y,\n)\nfrom act_helpers import (\n    make_action, move_1d, angle_diff,\n    ARM_MIN, ARM_MAX, ARM_TOL, XY_TOL, THETA_TOL,\n    TARGET_THETA, DX_MAX, DY_MAX, DARM_MAX,\n    pickup_robot_y, deposit_x_for_obstruction,\n)\n\n# ── Internal FSM phase constants ──────────────────────────────────────────────\n_P_PLAN       = \"PLAN\"\n_P_APPROACH_X = \"APPROACH_X\"\n_P_APPROACH_Y = \"APPROACH_Y\"\n_P_THETA      = \"THETA\"\n_P_EXTEND     = \"EXTEND\"\n_P_VACUUM_ON  = \"VACUUM_ON\"\n_P_RETRACT    = \"RETRACT\"\n_P_CARRY_X    = \"CARRY_X\"\n_P_LOWER      = \"LOWER\"\n_P_VACUUM_OFF = \"VACUUM_OFF\"\n_P_POST_RET   = \"POST_RETRACT\"\n_P_DONE       = \"DONE\"\n\n# ── Grip width threshold for vacuum ──────────────────────────────────────────\nGRIP_W = 0.01\nSUCTION_EXTRA = GRIP_W + GRIP_W / 2   # 0.015\n\n\nclass _PickPlaceFSM:\n    \"\"\"\n    Shared FSM mixin: pick an object at (pick_x, pick_y) and place at (dep_x, pick_y).\n    Subclasses call _fsm_step(obs) which returns an action or None when done.\n    Call _fsm_reset() to initialise, set self._pick_x, self._pick_y, self._dep_x before stepping.\n    \"\"\"\n\n    def _fsm_reset(self):\n        self._phase    = _P_PLAN\n        self._pick_x   = None\n        self._pick_y   = None   # robot y for pickup\n        self._dep_x    = None\n        self._vac_hold = False\n\n    def _fsm_done(self):\n        return self._phase == _P_DONE\n\n    def _fsm_step(self, obs):\n        \"\"\"Execute one FSM step; return action (np.array) or None if done.\"\"\"\n        r = get_robot(obs)\n        phase = self._phase\n\n        # ── APPROACH_X: move to pick_x at current y (retract arm first) ──────\n        if phase == _P_APPROACH_X:\n            dx = move_1d(r[\"x\"], self._pick_x, DX_MAX)\n            darm = move_1d(r[\"arm_joint\"], ARM_MIN, DARM_MAX)\n            dth  = self._correct_theta(r[\"theta\"])\n            at_x = abs(r[\"x\"] - self._pick_x) < XY_TOL\n            arm_ok = r[\"arm_joint\"] <= ARM_MIN + ARM_TOL\n            if at_x and arm_ok:\n                self._phase = _P_APPROACH_Y\n            return make_action(dx=dx, darm=darm, dtheta=dth, vac=0.0)\n\n        # ── APPROACH_Y: move to robot_y = pick_y ─────────────────────────────\n        if phase == _P_APPROACH_Y:\n            dy  = move_1d(r[\"y\"], self._pick_y, DY_MAX)\n            dth = self._correct_theta(r[\"theta\"])\n            if abs(r[\"y\"] - self._pick_y) < XY_TOL:\n                self._phase = _P_THETA\n            return make_action(dy=dy, dtheta=dth, vac=0.0)\n\n        # ── THETA: correct arm angle ──────────────────────────────────────────\n        if phase == _P_THETA:\n            dth = self._correct_theta(r[\"theta\"])\n            if abs(angle_diff(r[\"theta\"], TARGET_THETA)) < THETA_TOL:\n                self._phase = _P_EXTEND\n            return make_action(dtheta=dth, vac=0.0)\n\n        # ── EXTEND: extend arm to ARM_MAX ─────────────────────────────────────\n        if phase == _P_EXTEND:\n            darm = move_1d(r[\"arm_joint\"], ARM_MAX, DARM_MAX)\n            dth  = self._correct_theta(r[\"theta\"])\n            if r[\"arm_joint\"] >= ARM_MAX - ARM_TOL:\n                self._phase = _P_VACUUM_ON\n            return make_action(darm=darm, dtheta=dth, vac=0.0)\n\n        # ── VACUUM_ON: turn on vacuum ─────────────────────────────────────────\n        if phase == _P_VACUUM_ON:\n            self._phase = _P_RETRACT\n            return make_action(vac=1.0)\n\n        # ── RETRACT: pull arm back (object lifts with it) ─────────────────────\n        if phase == _P_RETRACT:\n            darm = move_1d(r[\"arm_joint\"], ARM_MIN, DARM_MAX)\n            if r[\"arm_joint\"] <= ARM_MIN + ARM_TOL:\n                self._phase = _P_CARRY_X\n            return make_action(darm=darm, vac=1.0)\n\n        # ── CARRY_X: move to deposit x ────────────────────────────────────────\n        if phase == _P_CARRY_X:\n            dx = move_1d(r[\"x\"], self._dep_x, DX_MAX)\n            dth = self._correct_theta(r[\"theta\"])\n            if abs(r[\"x\"] - self._dep_x) < XY_TOL:\n                self._phase = _P_LOWER\n            return make_action(dx=dx, dtheta=dth, vac=1.0)\n\n        # ── LOWER: extend arm at deposit (object descends) ────────────────────\n        if phase == _P_LOWER:\n            darm = move_1d(r[\"arm_joint\"], ARM_MAX, DARM_MAX)\n            if r[\"arm_joint\"] >= ARM_MAX - ARM_TOL:\n                self._phase = _P_VACUUM_OFF\n            return make_action(darm=darm, vac=1.0)\n\n        # ── VACUUM_OFF: release object ────────────────────────────────────────\n        if phase == _P_VACUUM_OFF:\n            self._phase = _P_POST_RET\n            return make_action(vac=0.0)\n\n        # ── POST_RETRACT: retract arm ─────────────────────────────────────────\n        if phase == _P_POST_RET:\n            darm = move_1d(r[\"arm_joint\"], ARM_MIN, DARM_MAX)\n            if r[\"arm_joint\"] <= ARM_MIN + ARM_TOL:\n                self._phase = _P_DONE\n            return make_action(darm=darm, vac=0.0)\n\n        # ── DONE ──────────────────────────────────────────────────────────────\n        return make_action()\n\n    @staticmethod\n    def _correct_theta(current_theta):\n        return angle_diff(TARGET_THETA, current_theta)\n\n\n# ══════════════════════════════════════════════════════════════════════════════\nclass ClearObstructionsBehavior(_PickPlaceFSM, Behavior):\n    \"\"\"\n    Iterates over all obstructions that overlap the target surface,\n    picks each one up, and deposits it at a clear location.\n    Terminates when no obstruction overlaps the surface.\n    \"\"\"\n\n    def reset(self, obs):\n        self._fsm_reset()\n        self._obs_idx = 0          # which obstruction we're working on\n        self._dep_counter = 0      # deposit counter for varied x positions\n        self._start_plan(obs)\n\n    def initializable(self, obs):\n        return True   # can always start from scratch\n\n    def terminated(self, obs):\n        return not any_obstruction_on_surface(obs)\n\n    def step(self, obs):\n        if self.terminated(obs):\n            return make_action()\n\n        # If current sub-task is done, plan next\n        if self._fsm_done():\n            self._fsm_reset()\n            self._start_plan(obs)\n\n        if self._fsm_done():\n            # Nothing left to do\n            return make_action()\n\n        return self._fsm_step(obs)\n\n    def _start_plan(self, obs):\n        \"\"\"Find next obstruction on surface and set up pick/place targets.\"\"\"\n        for i in range(NUM_OBS):\n            if obstruction_on_surface(obs, i):\n                ob = get_obstruction(obs, i)\n                obj_y = ob[\"y\"]\n                self._pick_x  = ob[\"x\"]\n                self._pick_y  = pickup_robot_y(obj_y)\n                self._dep_x   = deposit_x_for_obstruction(self._dep_counter)\n                self._dep_counter += 1\n                self._phase   = _P_APPROACH_X\n                return\n        # No obstruction on surface → stay DONE\n        self._phase = _P_DONE\n\n\n# ══════════════════════════════════════════════════════════════════════════════\nclass PickAndPlaceBehavior(_PickPlaceFSM, Behavior):\n    \"\"\"\n    Picks up the target block and places it at the center of the target surface.\n    Precondition: no obstructions on target surface.\n    \"\"\"\n\n    def reset(self, obs):\n        self._fsm_reset()\n        self._setup(obs)\n\n    def _setup(self, obs):\n        b = get_block(obs)\n        s = get_surface(obs)\n        self._pick_x = b[\"x\"]\n        self._pick_y = pickup_robot_y(b[\"y\"])\n        self._dep_x  = s[\"x\"]   # place at surface center\n        self._phase  = _P_APPROACH_X\n\n    def initializable(self, obs):\n        return not any_obstruction_on_surface(obs)\n\n    def terminated(self, obs):\n        return is_block_on_surface(obs)\n\n    def step(self, obs):\n        if self.terminated(obs):\n            return make_action()\n\n        # Replan if FSM is done but block isn't on surface yet (e.g. misaligned)\n        if self._fsm_done():\n            self._fsm_reset()\n            # Update pick target in case block moved\n            self._setup(obs)\n\n        return self._fsm_step(obs)\n"}}
