  = eff_cx + carried_w / 2\n        lo, hi  = x - half, x + half   # robot-base clearance zone\n\n        # 1. Avoid target surface (using effective object position)\n        if intervals_overlap_strict(eff_lo, eff_hi, s[\"x\"], s[\"x\"] + s[\"w\"]):\n            x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 2. Avoid block approach zone (effective carried obj must not block robot at block_cx)\n        if intervals_overlap_strict(eff_lo, eff_hi,\n                                    block_cx - ARM_MIN, block_cx + ARM_MIN):\n            x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 3. Avoid robot base at (x, dep_y) colliding with block during LOWER\n        if dep_y < block_top + ARM_MIN:      # y-ranges could overlap\n            if intervals_overlap_strict(x - ARM_MIN, x + ARM_MIN, block_lo, block_hi):\n                x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 4. Avoid all obstructions except the one being carried:\n        #    (a) robot base circle at (x, dep_y) must not collide with obstruction\n        #    (b) effective deposited object x-range must not overlap obstruction\n        blocked = False\n        for j in range(NUM_OBS):\n            if j == carried_idx:\n                continue\n            ob_j = get_obstruction(obs, j)\n            ob_lo_j = ob_j[\"x\"]; ob_hi_j = ob_j[\"x\"] + ob_j[\"w\"]\n            # (a) robot base collision at deposit point\n            d = _circle_rect_dist(x, dep_y, ob_j[\"x\"], ob_j[\"y\"],\n                                  ob_j[\"w\"], ob_j[\"top\"] - ob_j[\"y\"])\n            if d < ARM_MIN + 0.005:\n                blocked = True; break\n            # (b) deposited object x-range overlap with obstruction\n            if intervals_overlap_strict(eff_lo, eff_hi, ob_lo_j, ob_hi_j):\n                blocked = True; break\n        if blocked:\n            x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 5. Effective deposited object must not block future approach to\n        #    remaining surface obstructions (robot base circle at their pick pos).\n        for k in range(NUM_OBS):\n            if k == carried_idx:\n                continue\n            ob_k = get_obstruction(obs, k)\n            # Only care about surface obstructions (need to approach them later)\n            if not intervals_overlap_strict(ob_k[\"x\"], ob_k[\"x\"] + ob_k[\"w\"],\n                                            s[\"x\"], s[\"x\"] + s[\"w\"]):\n                continue\n            pick_y_k = pickup_robot_y(ob_k[\"top\"])\n            pick_x_k = ob_k[\"cx\"]  # conservative: use center as approach x\n            # Check distance from robot-at-pick to effective deposited object\n            d = _circle_rect_dist(pick_x_k, pick_y_k,\n                                  eff_lo, carried_ob[\"y\"],\n                                  carried_w, carried_ob[\"top\"] - carried_ob[\"y\"])\n            if d < ARM_MIN + 0.005:\n                blocked = True; break\n        if not blocked:\n            return x\n        x += DEPOSIT_X_SCAN_STEP\n    return DEPOSIT_X_SCAN_START  # fallback","newString":"def choose_deposit_x(obs, carried_idx, carried_ob, block_ob, pick_x=None):\n    \"\"\"\n    Scan x positions and return the FARTHEST valid one from the target surface center,\n    clear of all obstructions, the surface, block approach zone, and future PLACE operation.\n\n    pick_x: the robot x used during pickup.  When pick_x != carried_ob[\"cx\"],\n            the object is gripped off-center, so after deposit at robot_x=dep_x\n            the object's effective center = dep_x + (carried_ob[\"cx\"] - pick_x).\n    \"\"\"\n    from obs_helpers import get_surface, get_obstruction, NUM_OBS, intervals_overlap_strict\n    s = get_surface(obs)\n    s_cx = s[\"x\"] + s[\"w\"] / 2\n    carried_w   = carried_ob[\"w\"]\n    carried_top = carried_ob[\"top\"]\n    dep_y       = pickup_robot_y(carried_top)\n\n    # x-offset between object center and robot x during grip\n    cx_offset = carried_ob[\"cx\"] - (pick_x if pick_x is not None else carried_ob[\"cx\"])\n\n    block_lo    = block_ob[\"x\"]\n    block_hi    = block_ob[\"x\"] + block_ob[\"w\"]\n    block_top   = block_ob[\"top\"]\n    block_cx    = block_ob[\"cx\"]\n    pick_y_blk  = pickup_robot_y(block_top)\n\n    half = max(carried_w / 2, ARM_MIN) + 0.01  # robot-base clearance zone\n\n    best_x = None\n    best_dist = -1.0\n\n    x = DEPOSIT_X_SCAN_START\n    while x <= DEPOSIT_X_SCAN_END + 1e-9:\n        # Effective object center and x-range after deposit at robot_x=x\n        eff_cx  = x + cx_offset\n        eff_lo  = eff_cx - carried_w / 2\n        eff_hi  = eff_cx + carried_w / 2\n\n        # 1. Avoid target surface (using effective object position)\n        if intervals_overlap_strict(eff_lo, eff_hi, s[\"x\"], s[\"x\"] + s[\"w\"]):\n            x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 2. Avoid block approach zone (effective carried obj must not block robot at block_cx)\n        if intervals_overlap_strict(eff_lo, eff_hi,\n                                    block_cx - ARM_MIN, block_cx + ARM_MIN):\n            x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 3. Avoid robot base at (x, dep_y) colliding with block during LOWER\n        if dep_y < block_top + ARM_MIN:      # y-ranges could overlap\n            if intervals_overlap_strict(x - ARM_MIN, x + ARM_MIN, block_lo, block_hi):\n                x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 4. Avoid all obstructions except the one being carried:\n        #    (a) robot base circle at (x, dep_y) must not collide with obstruction\n        #    (b) effective deposited object x-range must not overlap obstruction\n        blocked = False\n        for j in range(NUM_OBS):\n            if j == carried_idx:\n                continue\n            ob_j = get_obstruction(obs, j)\n            ob_lo_j = ob_j[\"x\"]; ob_hi_j = ob_j[\"x\"] + ob_j[\"w\"]\n            # (a) robot base collision at deposit point\n            d = _circle_rect_dist(x, dep_y, ob_j[\"x\"], ob_j[\"y\"],\n                                  ob_j[\"w\"], ob_j[\"top\"] - ob_j[\"y\"])\n            if d < ARM_MIN + 0.005:\n                blocked = True; break\n            # (b) deposited object x-range overlap with obstruction\n            if intervals_overlap_strict(eff_lo, eff_hi, ob_lo_j, ob_hi_j):\n                blocked = True; break\n        if blocked:\n            x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 5. Effective deposited object must not block future approach to\n        #    remaining surface obstructions (robot base circle at their pick pos).\n        for k in range(NUM_OBS):\n            if k == carried_idx:\n                continue\n            ob_k = get_obstruction(obs, k)\n            # Only care about surface obstructions (need to approach them later)\n            if not intervals_overlap_strict(ob_k[\"x\"], ob_k[\"x\"] + ob_k[\"w\"],\n                                            s[\"x\"], s[\"x\"] + s[\"w\"]):\n                continue\n            pick_y_k = pickup_robot_y(ob_k[\"top\"])\n            pick_x_k = ob_k[\"cx\"]  # conservative: use center as approach x\n            # Check distance from robot-at-pick to effective deposited object\n            d = _circle_rect_dist(pick_x_k, pick_y_k,\n                                  eff_lo, carried_ob[\"y\"],\n                                  carried_w, carried_ob[\"top\"] - carried_ob[\"y\"])\n            if d < ARM_MIN + 0.005:\n                blocked = True; break\n        if blocked:\n            x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 6. Deposited object must not block PLACE operation:\n        #    robot at (block_cx, pick_y_blk) or (s_cx, pick_y_blk) must be clear.\n        for ref_x in [block_cx, s_cx]:\n            d = _circle_rect_dist(ref_x, pick_y_blk,\n                                  eff_lo, carried_ob[\"y\"],\n                                  carried_w, carried_ob[\"top\"] - carried_ob[\"y\"])\n            if d < ARM_MIN + 0.005:\n                blocked = True; break\n        if blocked:\n            x += DEPOSIT_X_SCAN_STEP; continue\n\n        # Valid position — prefer farthest from surface center\n        dist = abs(x - s_cx)\n        if dist > best_dist:\n            best_dist = dist\n            best_x = x\n        x += DEPOSIT_X_SCAN_STEP\n\n    return best_x if best_x is not None else DEPOSIT_X_SCAN_START","originalFile":"\"\"\"All action generation helpers for Obstruction2D-o4-v0.\"\"\"\nimport numpy as np\n\n# ── Action space limits ───────────────────────────────────────────────────────\nDX_MAX     = 0.050\nDY_MAX     = 0.050\nDTHETA_MAX = 0.196   # ~π/16\nDARM_MAX   = 0.100\n\n# ── Arm constants ─────────────────────────────────────────────────────────────\nARM_MIN    = 0.10    # = base_radius (minimum arm extension)\nARM_MAX    = 0.20    # maximum arm extension\n\n# ── Gripper geometry (theta = -pi/2, arm pointing DOWN) ───────────────────────\nGRIP_H          = 0.07    # perpendicular extent\nGRIP_W          = 0.01    # along-arm extent\nGRIP_HALF_H     = GRIP_H / 2         # 0.035 — horizontal reach\nGRIP_HALF_W     = GRIP_W / 2         # 0.005 — vertical half-thickness\n\n# ── Suction zone geometry ─────────────────────────────────────────────────────\nSUCTION_REACH   = GRIP_W + GRIP_W / 2      # 0.015 below arm_joint\nSUCTION_Y_TOP   = GRIP_W                   # 0.010 below arm_joint\nSUCTION_Y_BOT   = GRIP_W + GRIP_W          # 0.020 below arm_joint\n\n# ── Pickup geometry ───────────────────────────────────────────────────────────\nPICKUP_OFFSET   = 0.108   # above obj_top; window is (0.105, 0.110)\n\n# ── Carry / deposit heights ───────────────────────────────────────────────────\nCARRY_HEIGHT    = 0.700\n\n# ── Deposit x scan range ─────────────────────────────────────────────────────\nDEPOSIT_X_SCAN_START = 0.15\nDEPOSIT_X_SCAN_END   = 1.55\nDEPOSIT_X_SCAN_STEP  = 0.05\n\n# ── Pick-x scan step ─────────────────────────────────────────────────────────\nPICK_X_SCAN_STEP = 0.005\n\n# ── Target theta ─────────────────────────────────────────────────────────────\nTARGET_THETA = -np.pi / 2\n\n# ── Tolerances ────────────────────────────────────────────────────────────────\nXY_TOL    = 0.004\nARM_TOL   = 0.005\nTHETA_TOL = 0.02\n\n# ── Helpers ───────────────────────────────────────────────────────────────────\n\ndef clamp(v, lo, hi):\n    return max(lo, min(hi, v))\n\n\ndef move_1d(current, target, max_step):\n    delta = target - current\n    return clamp(delta, -max_step, max_step)\n\n\ndef angle_diff(a, b):\n    d = a - b\n    while d >  np.pi: d -= 2 * np.pi\n    while d < -np.pi: d += 2 * np.pi\n    return d\n\n\ndef make_action(dx=0.0, dy=0.0, dtheta=0.0, darm=0.0, vac=0.0):\n    return np.array([\n        clamp(dx,     -DX_MAX,     DX_MAX),\n        clamp(dy,     -DY_MAX,     DY_MAX),\n        clamp(dtheta, -DTHETA_MAX, DTHETA_MAX),\n        clamp(darm,   -DARM_MAX,   DARM_MAX),\n        clamp(vac,    0.0,         1.0),\n    ], dtype=np.float32)\n\n\ndef pickup_robot_y(obj_top):\n    return obj_top + PICKUP_OFFSET\n\n\ndef _circle_rect_dist(cx, cy, rx, ry, rw, rh):\n    \"\"\"Min distance from circle center (cx,cy) to rectangle [rx,rx+rw]×[ry,ry+rh].\"\"\"\n    px = np.clip(cx, rx, rx + rw)\n    py = np.clip(cy, ry, ry + rh)\n    return np.sqrt((cx - px)**2 + (cy - py)**2)\n\n\ndef safe_pick_x(obs, ob_idx, ob, pick_y):\n    \"\"\"\n    Find a robot x within ob's x-range (accounting for suction half-width)\n    where the robot base circle at (x, pick_y) doesn't collide with any\n    other obstruction.  Scans left-to-right; falls back to ob[\"cx\"].\n    \"\"\"\n    from obs_helpers import get_obstruction, NUM_OBS\n    margin = ARM_MIN + 0.005   # safety margin\n    half_h = GRIP_HALF_H       # 0.035 — suction must be inside object\n\n    lo = ob[\"x\"] + half_h\n    hi = ob[\"x\"] + ob[\"w\"] - half_h\n    if lo > hi:\n        lo = hi = ob[\"cx\"]\n\n    for x in np.arange(lo, hi + 1e-9, PICK_X_SCAN_STEP):\n        ok = True\n        for j in range(NUM_OBS):\n            if j == ob_idx:\n                continue\n            ob_j = get_obstruction(obs, j)\n            # Robot base circle must not collide\n            d = _circle_rect_dist(x, pick_y,\n                                  ob_j[\"x\"], ob_j[\"y\"], ob_j[\"w\"],\n                                  ob_j[\"top\"] - ob_j[\"y\"])\n            if d < margin:\n                ok = False\n                break\n            # Gripper horizontal extent must not overlap adjacent object (accidental lift)\n            from obs_helpers import intervals_overlap_strict as _iov\n            if _iov(x - GRIP_HALF_H, x + GRIP_HALF_H,\n                    ob_j[\"x\"], ob_j[\"x\"] + ob_j[\"w\"]):\n                ok = False\n                break\n        if ok:\n            return x\n    return ob[\"cx\"]   # fallback\n\n\ndef choose_deposit_x(obs, carried_idx, carried_ob, block_ob, pick_x=None):\n    \"\"\"\n    Scan x positions and return the first one clear of:\n      1. Target surface  (checked using effective object x-range after deposit)\n      2. All other obstructions (checked using effective object x-range)\n      3. Carried object overlapping robot-at-block approach zone\n      4. Robot base at (dep_x, dep_y) colliding with block during LOWER\n\n    pick_x: the robot x used during pickup.  When pick_x != carried_ob[\"cx\"],\n            the object is gripped off-center, so after deposit at robot_x=dep_x\n            the object's effective center = dep_x + (carried_ob[\"cx\"] - pick_x).\n    \"\"\"\n    from obs_helpers import get_surface, get_obstruction, NUM_OBS, intervals_overlap_strict\n    s = get_surface(obs)\n    carried_w   = carried_ob[\"w\"]\n    carried_top = carried_ob[\"top\"]\n    dep_y       = pickup_robot_y(carried_top)\n\n    # x-offset between object center and robot x during grip\n    cx_offset = carried_ob[\"cx\"] - (pick_x if pick_x is not None else carried_ob[\"cx\"])\n\n    block_lo  = block_ob[\"x\"]\n    block_hi  = block_ob[\"x\"] + block_ob[\"w\"]\n    block_top = block_ob[\"top\"]\n    block_cx  = block_ob[\"cx\"]\n\n    half = max(carried_w / 2, ARM_MIN) + 0.01  # robot-base clearance zone\n\n    x = DEPOSIT_X_SCAN_START\n    while x <= DEPOSIT_X_SCAN_END + 1e-9:\n        # Effective object center and x-range after deposit at robot_x=x\n        eff_cx  = x + cx_offset\n        eff_lo  = eff_cx - carried_w / 2\n        eff_hi  = eff_cx + carried_w / 2\n        lo, hi  = x - half, x + half   # robot-base clearance zone\n\n        # 1. Avoid target surface (using effective object position)\n        if intervals_overlap_strict(eff_lo, eff_hi, s[\"x\"], s[\"x\"] + s[\"w\"]):\n            x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 2. Avoid block approach zone (effective carried obj must not block robot at block_cx)\n        if intervals_overlap_strict(eff_lo, eff_hi,\n                                    block_cx - ARM_MIN, block_cx + ARM_MIN):\n            x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 3. Avoid robot base at (x, dep_y) colliding with block during LOWER\n        if dep_y < block_top + ARM_MIN:      # y-ranges could overlap\n            if intervals_overlap_strict(x - ARM_MIN, x + ARM_MIN, block_lo, block_hi):\n                x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 4. Avoid all obstructions except the one being carried:\n        #    (a) robot base circle at (x, dep_y) must not collide with obstruction\n        #    (b) effective deposited object x-range must not overlap obstruction\n        blocked = False\n        for j in range(NUM_OBS):\n            if j == carried_idx:\n                continue\n            ob_j = get_obstruction(obs, j)\n            ob_lo_j = ob_j[\"x\"]; ob_hi_j = ob_j[\"x\"] + ob_j[\"w\"]\n            # (a) robot base collision at deposit point\n            d = _circle_rect_dist(x, dep_y, ob_j[\"x\"], ob_j[\"y\"],\n                                  ob_j[\"w\"], ob_j[\"top\"] - ob_j[\"y\"])\n            if d < ARM_MIN + 0.005:\n                blocked = True; break\n            # (b) deposited object x-range overlap with obstruction\n            if intervals_overlap_strict(eff_lo, eff_hi, ob_lo_j, ob_hi_j):\n                blocked = True; break\n        if blocked:\n            x += DEPOSIT_X_SCAN_STEP; continue\n\n        # 5. Effective deposited object must not block future approach to\n        #    remaining surface obstructions (robot base circle at their pick pos).\n        for k in range(NUM_OBS):\n            if k == carried_idx:\n                continue\n            ob_k = get_obstruction(obs, k)\n            # Only care about surface obstructions (need to approach them later)\n            if not intervals_overlap_strict(ob_k[\"x\"], ob_k[\"x\"] + ob_k[\"w\"],\n                                            s[\"x\"], s[\"x\"] + s[\"w\"]):\n                continue\n            pick_y_k = pickup_robot_y(ob_k[\"top\"])\n            pick_x_k = ob_k[\"cx\"]  # conservative: use center as approach x\n            # Check distance from robot-at-pick to effective deposited object\n            d = _circle_rect_dist(pick_x_k, pick_y_k,\n                                  eff_lo, carried_ob[\"y\"],\n                                  carried_w, carried_ob[\"top\"] - carried_ob[\"y\"])\n            if d < ARM_MIN + 0.005:\n                blocked = True; break\n        if not blocked:\n            return x\n        x += DEPOSIT_X_SCAN_STEP\n    return DEPOSIT_X_SCAN_START  # fallback\n\n\ndef correct_theta(current_theta):\n    return angle_diff(TARGET_THETA, current_theta)\n","structuredPatch":[{"oldStart":124,"oldLines":11,"newStart":124,"newLines":8,"lines":[" "," def choose_deposit_x(obs, carried_idx, carried_ob, block_ob, pick_x=None):","     \"\"\"","-    Scan x positions and return the first one clear of:","-      1. Target surface  (checked using effective object x-range after deposit)","-      2. All other obstructions (checked using effective object x-range)","-      3. Carried object overlapping robot-at-block approach zone","-      4. Robot base at (dep_x, dep_y) colliding with block during LOWER","+    Scan x positions and return the FARTHEST valid one from the target surface center,","+    clear of all obstructions, the surface, block approach zone, and future PLACE operation."," ","     pick_x: the robot x used during pickup.  When pick_x != carried_ob[\"cx\"],","             the object is gripped off-center, so after deposit at robot_x=dep_x"]},{"oldStart":136,"oldLines":6,"newStart":133,"newLines":7,"lines":["     \"\"\"","     from obs_helpers import get_surface, get_obstruction, NUM_OBS, intervals_overlap_strict","     s = get_surface(obs)","+    s_cx = s[\"x\"] + s[\"w\"] / 2","     carried_w   = carried_ob[\"w\"]","     carried_top = carried_ob[\"top\"]","     dep_y       = pickup_robot_y(carried_top)"]},{"oldStart":143,"oldLines":20,"newStart":141,"newLines":23,"lines":["     # x-offset between object center and robot x during grip","     cx_offset = carried_ob[\"cx\"] - (pick_x if pick_x is not None else carried_ob[\"cx\"])"," ","-    block_lo  = block_ob[\"x\"]","-    block_hi  = block_ob[\"x\"] + block_ob[\"w\"]","-    block_top = block_ob[\"top\"]","-    block_cx  = block_ob[\"cx\"]","+    block_lo    = block_ob[\"x\"]","+    block_hi    = block_ob[\"x\"] + block_ob[\"w\"]","+    block_top   = block_ob[\"top\"]","+    block_cx    = block_ob[\"cx\"]","+    pick_y_blk  = pickup_robot_y(block_top)"," ","     half = max(carried_w / 2, ARM_MIN) + 0.01  # robot-base clearance zone"," ","+    best_x = None","+    best_dist = -1.0","+","     x = DEPOSIT_X_SCAN_START","     while x <= DEPOSIT_X_SCAN_END + 1e-9:","         # Effective object center and x-range after deposit at robot_x=x","         eff_cx  = x + cx_offset","         eff_lo  = eff_cx - carried_w / 2","         eff_hi  = eff_cx + carried_w / 2","-        lo, hi  = x - half, x + half   # robot-base clearance zone"," ","         # 1. Avoid target surface (using effective object position)","         if intervals_overlap_strict(eff_lo, eff_hi, s[\"x\"], s[\"x\"] + s[\"w\"]):"]},{"oldStart":210,"oldLines":11,"newStart":211,"newLines":29,"lines":["                                   carried_w, carried_ob[\"top\"] - carried_ob[\"y\"])","             if d < ARM_MIN + 0.005:","                 blocked = True; break","-        if not blocked:","-            return x","+        if blocked:","+            x += DEPOSIT_X_SCAN_STEP; continue","+","+        # 6. Deposited object must not block PLACE operation:","+        #    robot at (block_cx, pick_y_blk) or (s_cx, pick_y_blk) must be clear.","+        for ref_x in [block_cx, s_cx]:","+            d = _circle_rect_dist(ref_x, pick_y_blk,","+                                  eff_lo, carried_ob[\"y\"],","+                                  carried_w, carried_ob[\"top\"] - carried_ob[\"y\"])","+            if d < ARM_MIN + 0.005:","+                blocked = True; break","+        if blocked:","+            x += DEPOSIT_X_SCAN_STEP; continue","+","+        # Valid position — prefer farthest from surface center","+        dist = abs(x - s_cx)","+        if dist > best_dist:","+            best_dist = dist","+            best_x = x","         x += DEPOSIT_X_SCAN_STEP","-    return DEPOSIT_X_SCAN_START  # fallback"," ","+    return best_x if best_x is not None else DEPOSIT_X_SCAN_START"," ","+"," def correct_theta(current_theta):","     return angle_diff(TARGET_THETA, current_theta)"]}],"userModified":false,"replaceAll":false}}
