────────────────────────────────────────────\nSURF_X     = 9\nSURF_Y     = 10\nSURF_W     = 17\nSURF_H     = 18\n\n# ── Target block indices ───────────────────────────────────────────────────────\nBLOCK_X    = 19\nBLOCK_Y    = 20\nBLOCK_W    = 27\nBLOCK_H    = 28\n\n# ── Obstruction layout ────────────────────────────────────────────────────────\nOBS_BASE   = 29    # index of obstruction0's first feature\nOBS_STRIDE = 10    # features per obstruction\nNUM_OBS    = 4\n\n# Within each obstruction block (relative to OBS_BASE + i*OBS_STRIDE):\nOBS_REL_X  = 0\nOBS_REL_Y  = 1\nOBS_REL_W  = 8\nOBS_REL_H  = 9\n\n# ── Geometry constants ────────────────────────────────────────────────────────\nIS_ON_TOL      = 0.025   # tolerance used in is_on()\nGRIP_W         = 0.01    # gripper width (along arm direction)\nGRIP_H         = 0.07    # gripper height (perpendicular to arm)\nSUCTION_EXTRA  = GRIP_W + GRIP_W / 2   # = 0.015 beyond arm_joint\n\n# ── Extraction helpers ────────────────────────────────────────────────────────\n\ndef get_robot(obs):\n    \"\"\"Return dict of robot features.\"\"\"\n    return {\n        \"x\": obs[ROBOT_X],\n        \"y\": obs[ROBOT_Y],\n        \"theta\": obs[ROBOT_THETA],\n        \"base_r\": obs[ROBOT_BASE_R],\n        \"arm_joint\": obs[ROBOT_ARM_JOINT],\n        \"arm_len\": obs[ROBOT_ARM_LEN],\n        \"vacuum\": obs[ROBOT_VACUUM],\n        \"grip_h\": obs[ROBOT_GRIP_H],\n        \"grip_w\": obs[ROBOT_GRIP_W],\n    }\n\n\ndef get_surface(obs):\n    \"\"\"Return dict of target_surface features.\"\"\"\n    return {\n        \"x\": obs[SURF_X],\n        \"y\": obs[SURF_Y],\n        \"w\": obs[SURF_W],\n        \"h\": obs[SURF_H],\n    }\n\n\ndef get_block(obs):\n    \"\"\"Return dict of target_block features.\"\"\"\n    return {\n        \"x\": obs[BLOCK_X],\n        \"y\": obs[BLOCK_Y],\n        \"w\": obs[BLOCK_W],\n        \"h\": obs[BLOCK_H],\n    }\n\n\ndef get_obstruction(obs, i):\n    \"\"\"Return dict of obstruction i features (i in 0..NUM_OBS-1).\"\"\"\n    base = OBS_BASE + i * OBS_STRIDE\n    return {\n        \"x\": obs[base + OBS_REL_X],\n        \"y\": obs[base + OBS_REL_Y],\n        \"w\": obs[base + OBS_REL_W],\n        \"h\": obs[base + OBS_REL_H],\n    }\n\n\ndef suction_y(robot_y, arm_joint):\n    \"\"\"Y-coordinate of suction zone center for theta=-pi/2.\"\"\"\n    return robot_y - arm_joint - SUCTION_EXTRA\n\n\ndef intervals_overlap(c1, half1, c2, half2):\n    \"\"\"True if [c1-half1, c1+half1] overlaps [c2-half2, c2+half2].\"\"\"\n    return abs(c1 - c2) < (half1 + half2)\n\n\ndef obstruction_on_surface(obs, i):\n    \"\"\"True if obstruction i horizontally overlaps the target surface.\"\"\"\n    obs_i = get_obstruction(obs, i)\n    surf  = get_surface(obs)\n    return intervals_overlap(obs_i[\"x\"], obs_i[\"w\"] / 2,\n                             surf[\"x\"],  surf[\"w\"] / 2)\n\n\ndef any_obstruction_on_surface(obs):\n    \"\"\"True if any obstruction overlaps the target surface.\"\"\"\n    return any(obstruction_on_surface(obs, i) for i in range(NUM_OBS))\n\n\ndef is_block_on_surface(obs):\n    \"\"\"\n    Mimic is_on(): both bottom vertices of block (offset by -IS_ON_TOL in y)\n    must lie inside the surface rectangle.  Assumes theta=0 for both objects.\n    \"\"\"\n    b = get_block(obs)\n    s = get_surface(obs)\n\n    # Two bottom vertices (lowest y = b[\"y\"] - b[\"h\"]/2)\n    by_offset = b[\"y\"] - b[\"h\"] / 2 - IS_ON_TOL\n    bx_left   = b[\"x\"] - b[\"w\"] / 2\n    bx_right  = b[\"x\"] + b[\"w\"] / 2\n\n    sx_lo = s[\"x\"] - s[\"w\"] / 2\n    sx_hi = s[\"x\"] + s[\"w\"] / 2\n    sy_lo = s[\"y\"] - s[\"h\"] / 2\n    sy_hi = s[\"y\"] + s[\"h\"] / 2\n\n    def inside(px, py):\n        return sx_lo <= px <= sx_hi and sy_lo <= py <= sy_hi\n\n    return inside(bx_left, by_offset) and inside(bx_right, by_offset)\n"}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_012mXrB4wtYUzn1HcPGuvEpg","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015DKHQsXNq1CpMyUzKVDSrf","name":"Write","input":{"file_path":"act_helpers.py","content":"\"\"\"All action generation helpers for Obstruction2D-o4-v0.\"\"\"\nimport numpy as np\n\n# ── Action space limits ───────────────────────────────────────────────────────\nDX_MAX     = 0.050\nDY_MAX     = 0.050\nDTHETA_MAX = 0.196   # ~π/16\nDARM_MAX   = 0.100\n\n# ── Arm constants ─────────────────────────────────────────────────────────────\nARM_MIN    = 0.10    # = base_radius (minimum arm extension)\nARM_MAX    = 0.20    # maximum arm extension\n\n# ── Gripper geometry (theta = -pi/2, arm pointing DOWN) ───────────────────────\n# Gripper: height=0.07 perpendicular to arm (→ horizontal extent ±0.035)\n#          width=0.01  along arm direction (→ vertical extent ±0.005)\n# Gripper center:  (robot_x, robot_y - arm_joint)\n# Gripper y_min:   robot_y - arm_joint - 0.005  (gripper bottom)\n# Gripper y_max:   robot_y - arm_joint + 0.005  (gripper top)\nGRIP_H          = 0.07    # perpendicular extent\nGRIP_W          = 0.01    # along-arm extent\nGRIP_HALF_H     = GRIP_H / 2         # 0.035 — horizontal reach\nGRIP_HALF_W     = GRIP_W / 2         # 0.005 — vertical half-thickness\n\n# ── Suction zone geometry ─────────────────────────────────────────────────────\n# suction center: (robot_x, robot_y - arm_joint - GRIP_W - GRIP_W/2) = robot_y - arm_joint - 0.015\n# suction y_max:  robot_y - arm_joint - GRIP_W             = robot_y - arm_joint - 0.010\n# suction y_min:  robot_y - arm_joint - GRIP_W - GRIP_W    = robot_y - arm_joint - 0.020\nSUCTION_REACH   = GRIP_W + GRIP_W / 2      # 0.015 below arm_joint\nSUCTION_Y_TOP   = GRIP_W                   # 0.010 below arm_joint (suction top edge)\nSUCTION_Y_BOT   = GRIP_W + GRIP_W          # 0.020 below arm_joint (suction bottom edge)\n\n# ── Pickup geometry ───────────────────────────────────────────────────────────\n# No-collision condition (gripper_y_min > obj_top):\n#   robot_y > obj_top + arm_joint + GRIP_HALF_W  → robot_y > obj_top + 0.105\n# Suction reaches obj top (suction_y_max ≤ obj_top):\n#   robot_y ≤ obj_top + arm_joint + SUCTION_Y_TOP  → robot_y ≤ obj_top + 0.110\n# Safe pickup robot_y = obj_top + arm_joint + PICKUP_OFFSET (midway in window)\nPICKUP_OFFSET   = 0.108   # above obj_top; window is (0.105, 0.110)\n\n# ── Carry / deposit heights ───────────────────────────────────────────────────\nCARRY_HEIGHT    = 0.700   # safe robot_y for horizontal movement while holding\nDEPOSIT_CLEAR_Y = CARRY_HEIGHT   # obstruction deposit: release at carry height (no gravity)\n\n# ── Deposit x positions for obstructions (far from table objects) ─────────────\nDEPOSIT_X_POSITIONS = [0.15, 0.25, 1.35, 1.45]\n\n# ── Target theta ─────────────────────────────────────────────────────────────\nTARGET_THETA = -np.pi / 2\n\n# ── Tolerances ────────────────────────────────────────────────────────────────\nXY_TOL    = 0.004   # position tolerance (tighter than one DY step)\nARM_TOL   = 0.005\nTHETA_TOL = 0.02\n\n# ── Helpers ───────────────────────────────────────────────────────────────────\n\ndef clamp(v, lo, hi):\n    return max(lo, min(hi, v))\n\n\ndef move_1d(current, target, max_step):\n    \"\"\"Signed delta toward target, bounded by max_step.\"\"\"\n    delta = target - current\n    return clamp(delta, -max_step, max_step)\n\n\ndef angle_diff(a, b):\n    \"\"\"Signed (a - b) wrapped to [-pi, pi].\"\"\"\n    d = a - b\n    while d >  np.pi: d -= 2 * np.pi\n    while d < -np.pi: d += 2 * np.pi\n    return d\n\n\ndef make_action(dx=0.0, dy=0.0, dtheta=0.0, darm=0.0, vac=0.0):\n    return np.array([\n        clamp(dx,     -DX_MAX,     DX_MAX),\n        clamp(dy,     -DY_MAX,     DY_MAX),\n        clamp(dtheta, -DTHETA_MAX, DTHETA_MAX),\n        clamp(darm,   -DARM_MAX,   DARM_MAX),\n        clamp(vac,    0.0,         1.0),\n    ], dtype=np.float32)\n\n\ndef pickup_robot_y(obj_top):\n    \"\"\"Target robot_y to hover just above obj_top with arm retracted at ARM_MIN.\"\"\"\n    return obj_top + ARM_MIN + PICKUP_OFFSET\n\n\ndef deposit_x_for_index(idx):\n    return DEPOSIT_X_POSITIONS[idx % len(DEPOSIT_X_POSITIONS)]\n\n\ndef correct_theta(current_theta):\n    \"\"\"Correction dtheta toward TARGET_THETA.\"\"\"\n    return angle_diff(TARGET_THETA, current_theta)\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":24984,"cache_read_input_tokens":98041,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":24984},"output_tokens":63,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"fd37b91c-ebd5-4910-858d-9dd025b7a813","uuid":"0010cc3a-fb73-44db-8260-f181c787dba1"}
