{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01BTjUT5dMgTL71ELaxRLtWq","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WuFaKRv6aPuCVJBkN4CPA7","name":"Write","input":{"file_path":"obs_helpers.py","content":"\"\"\"All observation parsing helpers for Obstruction2D-o4-v0.\n\nIMPORTANT COORDINATE CONVENTION:\n  - Robot (x, y) = CENTER of the circular base\n  - Rectangle objects (x, y) = BOTTOM-LEFT CORNER  (confirmed by vertex inspection)\n    => center_x = obs_x + obs_w/2\n    => top_y    = obs_y + obs_h\n\"\"\"\nimport numpy as np\n\n# ── Robot indices ──────────────────────────────────────────────────────────────\nROBOT_X         = 0\nROBOT_Y         = 1\nROBOT_THETA     = 2\nROBOT_BASE_R    = 3\nROBOT_ARM_JOINT = 4\nROBOT_ARM_LEN   = 5\nROBOT_VACUUM    = 6\nROBOT_GRIP_H    = 7\nROBOT_GRIP_W    = 8\n\n# ── Target surface indices (bottom-left corner convention) ─────────────────────\nSURF_X     = 9\nSURF_Y     = 10\nSURF_W     = 17\nSURF_H     = 18\n\n# ── Target block indices (bottom-left corner convention) ───────────────────────\nBLOCK_X    = 19\nBLOCK_Y    = 20\nBLOCK_W    = 27\nBLOCK_H    = 28\n\n# ── Obstruction layout ────────────────────────────────────────────────────────\nOBS_BASE   = 29    # index of obstruction0's first feature\nOBS_STRIDE = 10    # features per obstruction\nNUM_OBS    = 4\n\n# Within each obstruction block (relative to OBS_BASE + i*OBS_STRIDE):\nOBS_REL_X  = 0\nOBS_REL_Y  = 1\nOBS_REL_W  = 8\nOBS_REL_H  = 9\n\n# ── is_on tolerance ───────────────────────────────────────────────────────────\nIS_ON_TOL  = 0.025\n\n\n# ── Extraction helpers ────────────────────────────────────────────────────────\n\ndef get_robot(obs):\n    return {\n        \"x\": obs[ROBOT_X],\n        \"y\": obs[ROBOT_Y],\n        \"theta\": obs[ROBOT_THETA],\n        \"base_r\": obs[ROBOT_BASE_R],\n        \"arm_joint\": obs[ROBOT_ARM_JOINT],\n        \"arm_len\": obs[ROBOT_ARM_LEN],\n        \"vacuum\": obs[ROBOT_VACUUM],\n        \"grip_h\": obs[ROBOT_GRIP_H],\n        \"grip_w\": obs[ROBOT_GRIP_W],\n    }\n\n\ndef get_surface(obs):\n    \"\"\"Bottom-left x,y and dimensions of target_surface.\"\"\"\n    return {\n        \"x\": obs[SURF_X],   # left edge\n        \"y\": obs[SURF_Y],   # bottom edge\n        \"w\": obs[SURF_W],\n        \"h\": obs[SURF_H],\n        \"cx\": obs[SURF_X] + obs[SURF_W] / 2,    # center x\n        \"top\": obs[SURF_Y] + obs[SURF_H],        # top edge y\n    }\n\n\ndef get_block(obs):\n    \"\"\"Bottom-left x,y and dimensions of target_block.\"\"\"\n    return {\n        \"x\": obs[BLOCK_X],   # left edge\n        \"y\": obs[BLOCK_Y],   # bottom edge\n        \"w\": obs[BLOCK_W],\n        \"h\": obs[BLOCK_H],\n        \"cx\": obs[BLOCK_X] + obs[BLOCK_W] / 2,  # center x\n        \"top\": obs[BLOCK_Y] + obs[BLOCK_H],      # top edge y\n    }\n\n\ndef get_obstruction(obs, i):\n    \"\"\"Bottom-left x,y and dimensions of obstruction i.\"\"\"\n    base = OBS_BASE + i * OBS_STRIDE\n    x, y = obs[base + OBS_REL_X], obs[base + OBS_REL_Y]\n    w, h = obs[base + OBS_REL_W], obs[base + OBS_REL_H]\n    return {\n        \"x\": x,\n        \"y\": y,\n        \"w\": w,\n        \"h\": h,\n        \"cx\": x + w / 2,   # center x\n        \"top\": y + h,       # top edge y\n    }\n\n\ndef intervals_overlap_strict(lo1, hi1, lo2, hi2):\n    \"\"\"True if open intervals (lo1, hi1) and (lo2, hi2) overlap.\"\"\"\n    return lo1 < hi2 and lo2 < hi1\n\n\ndef obstruction_on_surface(obs, i):\n    \"\"\"True if obstruction i x-range strictly overlaps the target surface x-range.\"\"\"\n    ob = get_obstruction(obs, i)\n    s  = get_surface(obs)\n    return intervals_overlap_strict(ob[\"x\"], ob[\"x\"] + ob[\"w\"],\n                                    s[\"x\"],  s[\"x\"]  + s[\"w\"])\n\n\ndef any_obstruction_on_surface(obs):\n    \"\"\"True if any obstruction overlaps the target surface in x.\"\"\"\n    return any(obstruction_on_surface(obs, i) for i in range(NUM_OBS))\n\n\ndef is_block_on_surface(obs):\n    \"\"\"\n    Mirrors is_on(): the two bottom vertices of the target_block\n    (offset down by IS_ON_TOL) must lie inside the target_surface rectangle.\n    Uses bottom-left corner convention.\n    \"\"\"\n    b = get_block(obs)\n    s = get_surface(obs)\n\n    # Bottom vertices of block: (b[\"x\"], b[\"y\"]) and (b[\"x\"]+b[\"w\"], b[\"y\"])\n    # Effective y after tol offset:\n    eff_y = b[\"y\"] - IS_ON_TOL\n\n    s_lo_x, s_hi_x = s[\"x\"], s[\"x\"] + s[\"w\"]\n    s_lo_y, s_hi_y = s[\"y\"], s[\"y\"] + s[\"h\"]\n\n    def inside(px, py):\n        return s_lo_x <= px <= s_hi_x and s_lo_y <= py <= s_hi_y\n\n    return inside(b[\"x\"], eff_y) and inside(b[\"x\"] + b[\"w\"], eff_y)\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":360,"cache_read_input_tokens":97681,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":360},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"fd37b91c-ebd5-4910-858d-9dd025b7a813","uuid":"91be9270-37f8-4edd-b52e-63b878ba0ddf"}
