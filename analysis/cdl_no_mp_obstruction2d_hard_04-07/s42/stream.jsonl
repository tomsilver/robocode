{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017vpDh53aK7n8QaBCpe85PC","type":"tool_result","content":"1\t\"\"\"Utility functions shared across different types of environments.\"\"\"\n2\t\n3\timport abc\n4\tfrom collections.abc import Callable\n5\t\n6\timport matplotlib.pyplot as plt\n7\timport numpy as np\n8\tfrom gymnasium.spaces import Box\n9\tfrom numpy.typing import NDArray\n10\tfrom prpl_utils.utils import fig2data\n11\tfrom relational_structs import (\n12\t    Object,\n13\t    ObjectCentricState,\n14\t)\n15\tfrom tomsgeoms2d.structs import Circle, Geom2D, Lobject, Rectangle, Tobject\n16\tfrom tomsgeoms2d.utils import geom2ds_intersect\n17\t\n18\tfrom kinder.envs.dynamic2d.object_types import (\n19\t    DotRobotType,\n20\t    DynRectangleType,\n21\t    KinRectangleType,\n22\t    KinRobotType,\n23\t)\n24\tfrom kinder.envs.dynamic2d.object_types import LObjectType as LObjectTypeDyn\n25\tfrom kinder.envs.dynamic2d.object_types import (\n26\t    SmallCircleType,\n27\t    SmallSquareType,\n28\t    TObjectType,\n29\t)\n30\tfrom kinder.envs.geom2d.object_types import (\n31\t    CircleType,\n32\t    CRVRobotType,\n33\t    DoubleRectType,\n34\t)\n35\tfrom kinder.envs.geom2d.object_types import LObjectType as LObjectTypeGeom\n36\tfrom kinder.envs.geom2d.object_types import (\n37\t    RectangleType,\n38\t)\n39\tfrom kinder.envs.geom2d.structs import (\n40\t    Body2D,\n41\t    MultiBody2D,\n42\t    SE2Pose,\n43\t    ZOrder,\n44\t    z_orders_may_collide,\n45\t)\n46\t\n47\tPURPLE: tuple[float, float, float] = (128 / 255, 0 / 255, 128 / 255)\n48\tBLACK: tuple[float, float, float] = (0.1, 0.1, 0.1)\n49\tBROWN: tuple[float, float, float] = (0.4, 0.2, 0.1)\n50\tORANGE: tuple[float, float, float] = (1.0, 165 / 255, 0.0)\n51\t\n52\t\n53\tclass RobotActionSpace(Box):\n54\t    \"\"\"A space for robot actions.\"\"\"\n55\t\n56\t    @abc.abstractmethod\n57\t    def create_markdown_description(self) -> str:\n58\t        \"\"\"Create a markdown description of this space.\"\"\"\n59\t\n60\t\n61\tdef get_se2_pose(state: ObjectCentricState, obj: Object) -> SE2Pose:\n62\t    \"\"\"Get the SE2Pose of an object in a given state.\"\"\"\n63\t    return SE2Pose(\n64\t        x=state.get(obj, \"x\"),\n65\t        y=state.get(obj, \"y\"),\n66\t        theta=state.get(obj, \"theta\"),\n67\t    )\n68\t\n69\t\n70\tdef get_relative_se2_transform(\n71\t    state: ObjectCentricState, obj1: Object, obj2: Object\n72\t) -> SE2Pose:\n73\t    \"\"\"Get the pose of obj2 in the frame of obj1.\"\"\"\n74\t    world_to_obj1 = get_se2_pose(state, obj1)\n75\t    world_to_obj2 = get_se2_pose(state, obj2)\n76\t    return world_to_obj1.inverse * world_to_obj2\n77\t\n78\t\n79\tdef sample_se2_pose(\n80\t    bounds: tuple[SE2Pose, SE2Pose], rng: np.random.Generator\n81\t) -> SE2Pose:\n82\t    \"\"\"Sample a SE2Pose uniformly between the bounds.\"\"\"\n83\t    lb, ub = bounds\n84\t    x = rng.uniform(lb.x, ub.x)\n85\t    y = rng.uniform(lb.y, ub.y)\n86\t    theta = rng.uniform(lb.theta, ub.theta)\n87\t    return SE2Pose(x, y, theta)\n88\t\n89\t\n90\tdef state_2d_has_collision(\n91\t    state: ObjectCentricState,\n92\t    group1: set[Object],\n93\t    group2: set[Object],\n94\t    static_object_cache: dict[Object, MultiBody2D],\n95\t    ignore_z_orders: bool = False,\n96\t) -> bool:\n97\t    \"\"\"Check for collisions between any objects in two groups.\"\"\"\n98\t    # Create multibodies once.\n99\t    obj_to_multibody = {\n100\t        o: object_to_multibody2d(o, state, static_object_cache) for o in state\n101\t    }\n102\t    # Check pairwise collisions.\n103\t    for obj1 in group1:\n104\t        for obj2 in group2:\n105\t            obj1_static = (\n106\t                state.get(obj1, \"static\")\n107\t                if \"static\" in state.type_features[obj1.type]\n108\t                else False\n109\t            )\n110\t            obj2_static = (\n111\t                state.get(obj2, \"static\")\n112\t                if \"static\" in state.type_features[obj2.type]\n113\t                else False\n114\t            )\n115\t            if obj1 == obj2 or (obj1_static and obj2_static):\n116\t                # Skip self-collision and static-static collision.\n117\t                continue\n118\t            multibody1 = obj_to_multibody[obj1]\n119\t            multibody2 = obj_to_multibody[obj2]\n120\t            for body1 in multibody1.bodies:\n121\t                for body2 in multibody2.bodies:\n122\t                    if not (\n123\t                        ignore_z_orders\n124\t                        or z_orders_may_collide(body1.z_order, body2.z_order)\n125\t                    ):\n126\t                        continue\n127\t                    if geom2ds_intersect(body1.geom, body2.geom):\n128\t                        return True\n129\t    return False\n130\t\n131\t\n132\tdef render_2dstate_on_ax(\n133\t    state: ObjectCentricState,\n134\t    ax: plt.Axes,\n135\t    static_object_body_cache: dict[Object, MultiBody2D] | None = None,\n136\t) -> None:\n137\t    \"\"\"Render a state on an existing plt.Axes.\"\"\"\n138\t    if static_object_body_cache is None:\n139\t        static_object_body_cache = {}\n140\t\n141\t    # Sort objects by ascending z order, with the robot first.\n142\t    def _render_order(obj: Object) -> int:\n143\t        if obj.is_instance(CRVRobotType) or obj.is_instance(KinRobotType):\n144\t            return -1\n145\t        return int(state.get(obj, \"z_order\"))\n146\t\n147\t    for obj in sorted(state, key=_render_order):\n148\t        body = object_to_multibody2d(obj, state, static_object_body_cache)\n149\t        body.plot(ax)\n150\t\n151\t\n152\tdef render_2dstate(\n153\t    state: ObjectCentricState,\n154\t    static_object_body_cache: dict[Object, MultiBody2D] | None = None,\n155\t    world_min_x: float = 0.0,\n156\t    world_max_x: float = 10.0,\n157\t    world_min_y: float = 0.0,\n158\t    world_max_y: float = 10.0,\n159\t    render_dpi: int = 150,\n160\t    ax_callback: Callable[[plt.Axes], None] | None = None,\n161\t) -> NDArray[np.uint8]:\n162\t    \"\"\"Render a state.\n163\t\n164\t    Useful for viz and debugging.\n165\t    \"\"\"\n166\t    if static_object_body_cache is None:\n167\t        static_object_body_cache = {}\n168\t\n169\t    figsize = (\n170\t        world_max_x - world_min_x,\n171\t        world_max_y - world_min_y,\n172\t    )\n173\t    fig, ax = plt.subplots(1, 1, figsize=figsize, dpi=render_dpi)\n174\t\n175\t    render_2dstate_on_ax(state, ax, static_object_body_cache)\n176\t\n177\t    pad_x = (world_max_x - world_min_x) / 25\n178\t    pad_y = (world_max_y - world_min_y) / 25\n179\t    ax.set_xlim(world_min_x - pad_x, world_max_x + pad_x)\n180\t    ax.set_ylim(world_min_y - pad_y, world_max_y + pad_y)\n181\t    ax.axis(\"off\")\n182\t    plt.tight_layout()\n183\t    if ax_callback is not None:\n184\t        ax_callback(ax)\n185\t    img = fig2data(fig)\n186\t    plt.close()\n187\t    return img\n188\t\n189\t\n190\t# ****** State to MultiBody2D conversion helpers ******\n191\t\n192\t\n193\tdef kin_robot_to_multibody2d(obj: Object, state: ObjectCentricState) -> MultiBody2D:\n194\t    \"\"\"Helper for object_to_multibody2d().\"\"\"\n195\t    assert obj.is_instance(KinRobotType)\n196\t    bodies: list[Body2D] = []\n197\t\n198\t    # Base.\n199\t    base_x = state.get(obj, \"x\")\n200\t    base_y = state.get(obj, \"y\")\n201\t    base_radius = state.get(obj, \"base_radius\")\n202\t    circ = Circle(\n203\t        x=base_x,\n204\t        y=base_y,\n205\t        radius=base_radius,\n206\t    )\n207\t    z_order = ZOrder.SURFACE\n208\t    rendering_kwargs = {\"facecolor\": PURPLE, \"edgecolor\": BLACK}\n209\t    base = Body2D(circ, z_order, rendering_kwargs, name=\"base\")\n210\t    bodies.append(base)\n211\t\n212\t    # Gripper Base\n213\t    theta = state.get(obj, \"theta\")\n214\t    arm_joint = state.get(obj, \"arm_joint\")\n215\t    gripper_base_cx = base_x + np.cos(theta) * arm_joint\n216\t    gripper_base_cy = base_y + np.sin(theta) * arm_joint\n217\t    gripper_base_height = state.get(obj, \"gripper_base_height\")\n218\t    gripper_base_width = state.get(obj, \"gripper_base_width\")\n219\t    rect = Rectangle.from_center(\n220\t        center_x=gripper_base_cx,\n221\t        center_y=gripper_base_cy,\n222\t        height=gripper_base_height,\n223\t        width=gripper_base_width,\n224\t        rotation_about_center=theta,\n225\t    )\n226\t    z_order = ZOrder.SURFACE\n227\t    rendering_kwargs = {\"facecolor\": PURPLE, \"edgecolor\": BLACK}\n228\t    gripper_base = Body2D(rect, z_order, rendering_kwargs, name=\"gripper_base\")\n229\t    gripper_base_pose = SE2Pose(\n230\t        x=gripper_base_cx,\n231\t        y=gripper_base_cy,\n232\t        theta=theta,\n233\t    )\n234\t    bodies.append(gripper_base)\n235\t\n236\t    # Arm\n237\t    gripper_base_arm_rel_se2 = SE2Pose(\n238\t        x=(-state.get(obj, \"arm_length\") / 2 - gripper_base_width / 2),\n239\t        y=0.0,\n240\t        theta=0.0,\n241\t    )\n242\t    arm_se2 = gripper_base_pose * gripper_base_arm_rel_se2\n243\t    rect = Rectangle.from_center(\n244\t        center_x=arm_se2.x,\n245\t        center_y=arm_se2.y,\n246\t        height=gripper_base_width,\n247\t        width=state.get(obj, \"arm_length\"),\n248\t        rotation_about_center=theta,\n249\t    )\n250\t    z_order = ZOrder.SURFACE\n251\t    rendering_kwargs = {\"facecolor\": PURPLE, \"edgecolor\": BLACK}\n252\t    arm = Body2D(rect, z_order, rendering_kwargs, name=\"arm\")\n253\t    bodies.append(arm)\n254\t\n255\t    # Fingers\n256\t    relative_dx = state.get(obj, \"finger_width\") / 2\n257\t    relative_dy_r = -state.get(obj, \"finger_gap\") / 2\n258\t    relative_dy_l = state.get(obj, \"finger_gap\") / 2\n259\t    finger_r_pose = gripper_base_pose * SE2Pose(\n260\t        x=relative_dx,\n261\t        y=relative_dy_r,\n262\t        theta=0.0,\n263\t    )\n264\t    finger_l_pose = gripper_base_pose * SE2Pose(\n265\t        x=relative_dx,\n266\t        y=relative_dy_l,\n267\t        theta=0.0,\n268\t    )\n269\t    finger_r = Rectangle.from_center(\n270\t        center_x=finger_r_pose.x,\n271\t        center_y=finger_r_pose.y,\n272\t        height=state.get(obj, \"finger_height\"),\n273\t        width=state.get(obj, \"finger_width\"),\n274\t        rotation_about_center=finger_r_pose.theta,\n275\t    )\n276\t    finger_l = Rectangle.from_center(\n277\t        center_x=finger_l_pose.x,\n278\t        center_y=finger_l_pose.y,\n279\t        height=state.get(obj, \"finger_height\"),\n280\t        width=state.get(obj, \"finger_width\"),\n281\t        rotation_about_center=finger_l_pose.theta,\n282\t    )\n283\t    z_order = ZOrder.SURFACE\n284\t    rendering_kwargs = {\"facecolor\": PURPLE, \"edgecolor\": BLACK}\n285\t    finger_l_body = Body2D(finger_r, z_order, rendering_kwargs, name=\"arm\")\n286\t    bodies.append(finger_l_body)\n287\t    finger_r_body = Body2D(finger_l, z_order, rendering_kwargs, name=\"arm\")\n288\t    bodies.append(finger_r_body)\n289\t\n290\t    multibody = MultiBody2D(obj.name, bodies)\n291\t    return multibody\n292\t\n293\t\n294\tdef crv_robot_to_multibody2d(obj: Object, state: ObjectCentricState) -> MultiBody2D:\n295\t    \"\"\"Helper for object_to_multibody2d().\"\"\"\n296\t    assert obj.is_instance(CRVRobotType)\n297\t    bodies: list[Body2D] = []\n298\t\n299\t    # Base.\n300\t    base_x = state.get(obj, \"x\")\n301\t    base_y = state.get(obj, \"y\")\n302\t    base_radius = state.get(obj, \"base_radius\")\n303\t    circ = Circle(\n304\t        x=base_x,\n305\t        y=base_y,\n306\t        radius=base_radius,\n307\t    )\n308\t    z_order = ZOrder.ALL\n309\t    rendering_kwargs = {\"facecolor\": PURPLE, \"edgecolor\": BLACK}\n310\t    base = Body2D(circ, z_order, rendering_kwargs, name=\"base\")\n311\t    bodies.append(base)\n312\t\n313\t    # Gripper.\n314\t    theta = state.get(obj, \"theta\")\n315\t    arm_joint = state.get(obj, \"arm_joint\")\n316\t    gripper_cx = base_x + np.cos(theta) * arm_joint\n317\t    gripper_cy = base_y + np.sin(theta) * arm_joint\n318\t    gripper_height = state.get(obj, \"gripper_height\")\n319\t    gripper_width = state.get(obj, \"gripper_width\")\n320\t    rect = Rectangle.from_center(\n321\t        center_x=gripper_cx,\n322\t        center_y=gripper_cy,\n323\t        height=gripper_height,\n324\t        width=gripper_width,\n325\t        rotation_about_center=theta,\n326\t    )\n327\t    z_order = ZOrder.SURFACE\n328\t    rendering_kwargs = {\"facecolor\": PURPLE, \"edgecolor\": BLACK}\n329\t    gripper = Body2D(rect, z_order, rendering_kwargs, name=\"gripper\")\n330\t    bodies.append(gripper)\n331\t\n332\t    # Arm.\n333\t    rect = Rectangle.from_center(\n334\t        center_x=(base_x + gripper_cx) / 2,\n335\t        center_y=(base_y + gripper_cy) / 2,\n336\t        height=np.sqrt((base_x - gripper_cx) ** 2 + (base_y - gripper_cy) ** 2),\n337\t        width=(0.5 * gripper_width),\n338\t        rotation_about_center=(theta + np.pi / 2),\n339\t    )\n340\t    z_order = ZOrder.SURFACE\n341\t    silver = (128 / 255, 128 / 255, 128 / 255)\n342\t    rendering_kwargs = {\"facecolor\": silver, \"edgecolor\": BLACK}\n343\t    arm = Body2D(rect, z_order, rendering_kwargs, name=\"arm\")\n344\t    bodies.append(arm)\n345\t\n346\t    # If the vacuum is on, add a suction area.\n347\t    if state.get(obj, \"vacuum\") > 0.5:\n348\t        suction_height = gripper_height\n349\t        suction_width = gripper_width\n350\t        suction_cx = base_x + np.cos(theta) * (\n351\t            arm_joint + gripper_width + suction_width / 2\n352\t        )\n353\t        suction_cy = base_y + np.sin(theta) * (\n354\t            arm_joint + gripper_width + suction_width / 2\n355\t        )\n356\t        rect = Rectangle.from_center(\n357\t            center_x=suction_cx,\n358\t            center_y=suction_cy,\n359\t            height=suction_height,\n360\t            width=suction_width,\n361\t            rotation_about_center=theta,\n362\t        )\n363\t        z_order = ZOrder.NONE  # NOTE: suction collides with nothing\n364\t        rendering_kwargs = {\"facecolor\": PURPLE}\n365\t        suction = Body2D(rect, z_order, rendering_kwargs, name=\"suction\")\n366\t        bodies.append(suction)\n367\t\n368\t    return MultiBody2D(obj.name, bodies)\n369\t\n370\t\n371\tdef geom2d_lobject_to_multibody2d(\n372\t    obj: Object, state: ObjectCentricState\n373\t) -> MultiBody2D:\n374\t    \"\"\"Helper to create a MultiBody2D for an LObjectType object.\"\"\"\n375\t    assert obj.is_instance(LObjectTypeGeom) or obj.is_instance(LObjectTypeDyn)\n376\t    # Get parameters\n377\t    x = state.get(obj, \"x\")\n378\t    y = state.get(obj, \"y\")\n379\t    theta = state.get(obj, \"theta\")\n380\t    width = state.get(obj, \"width\")\n381\t    length_side1 = state.get(obj, \"length_side1\")\n382\t    length_side2 = state.get(obj, \"length_side2\")\n383\t    color = (\n384\t        state.get(obj, \"color_r\"),\n385\t        state.get(obj, \"color_g\"),\n386\t        state.get(obj, \"color_b\"),\n387\t    )\n388\t    z_order = ZOrder(int(state.get(obj, \"z_order\")))\n389\t\n390\t    geom = Lobject(x, y, width, (length_side1, length_side2), theta)\n391\t\n392\t    rendering_kwargs = {\n393\t        \"facecolor\": color,\n394\t        \"edgecolor\": BLACK,\n395\t    }\n396\t    body = Body2D(geom, z_order, rendering_kwargs, name=\"hook\")\n397\t\n398\t    return MultiBody2D(obj.name, [body])\n399\t\n400\t\n401\tdef geom2d_double_rectangle_to_multibody2d(\n402\t    obj: Object, state: ObjectCentricState\n403\t) -> MultiBody2D:\n404\t    \"\"\"Helper to create a MultiBody2D for a DoubleRectType object.\"\"\"\n405\t    assert obj.is_instance(DoubleRectType)\n406\t    # Note: We need to assume the two rectangles are aligned now.\n407\t    # This means theta is the same, relative dy == 0, 0 <= dx < width0 - width1.\n408\t    # Such that we can create two obstacles from the base rectangle.\n409\t    bodies: list[Body