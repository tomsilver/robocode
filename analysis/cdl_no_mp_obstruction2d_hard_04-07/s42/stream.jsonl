A],\n        \"base_r\": obs[ROBOT_BASE_R],\n        \"arm_joint\": obs[ROBOT_ARM_JOINT],\n        \"arm_len\": obs[ROBOT_ARM_LEN],\n        \"vacuum\": obs[ROBOT_VACUUM],\n        \"grip_h\": obs[ROBOT_GRIP_H],\n        \"grip_w\": obs[ROBOT_GRIP_W],\n    }\n\n\ndef get_surface(obs):\n    \"\"\"Bottom-left x,y and dimensions of target_surface.\"\"\"\n    return {\n        \"x\": obs[SURF_X],   # left edge\n        \"y\": obs[SURF_Y],   # bottom edge\n        \"w\": obs[SURF_W],\n        \"h\": obs[SURF_H],\n        \"cx\": obs[SURF_X] + obs[SURF_W] / 2,    # center x\n        \"top\": obs[SURF_Y] + obs[SURF_H],        # top edge y\n    }\n\n\ndef get_block(obs):\n    \"\"\"Bottom-left x,y and dimensions of target_block.\"\"\"\n    return {\n        \"x\": obs[BLOCK_X],   # left edge\n        \"y\": obs[BLOCK_Y],   # bottom edge\n        \"w\": obs[BLOCK_W],\n        \"h\": obs[BLOCK_H],\n        \"cx\": obs[BLOCK_X] + obs[BLOCK_W] / 2,  # center x\n        \"top\": obs[BLOCK_Y] + obs[BLOCK_H],      # top edge y\n    }\n\n\ndef get_obstruction(obs, i):\n    \"\"\"Bottom-left x,y and dimensions of obstruction i.\"\"\"\n    base = OBS_BASE + i * OBS_STRIDE\n    x, y = obs[base + OBS_REL_X], obs[base + OBS_REL_Y]\n    w, h = obs[base + OBS_REL_W], obs[base + OBS_REL_H]\n    return {\n        \"x\": x,\n        \"y\": y,\n        \"w\": w,\n        \"h\": h,\n        \"cx\": x + w / 2,   # center x\n        \"top\": y + h,       # top edge y\n    }\n\n\ndef intervals_overlap_strict(lo1, hi1, lo2, hi2):\n    \"\"\"True if open intervals (lo1, hi1) and (lo2, hi2) overlap.\"\"\"\n    return lo1 < hi2 and lo2 < hi1\n\n\ndef obstruction_on_surface(obs, i):\n    \"\"\"True if obstruction i x-range strictly overlaps the target surface x-range.\"\"\"\n    ob = get_obstruction(obs, i)\n    s  = get_surface(obs)\n    return intervals_overlap_strict(ob[\"x\"], ob[\"x\"] + ob[\"w\"],\n                                    s[\"x\"],  s[\"x\"]  + s[\"w\"])\n\n\ndef any_obstruction_on_surface(obs):\n    \"\"\"True if any obstruction overlaps the target surface in x.\"\"\"\n    return any(obstruction_on_surface(obs, i) for i in range(NUM_OBS))\n\n\ndef is_block_on_surface(obs):\n    \"\"\"\n    Mirrors is_on(): the two bottom vertices of the target_block\n    (offset down by IS_ON_TOL) must lie inside the target_surface rectangle.\n    Uses bottom-left corner convention.\n    \"\"\"\n    b = get_block(obs)\n    s = get_surface(obs)\n\n    # Bottom vertices of block: (b[\"x\"], b[\"y\"]) and (b[\"x\"]+b[\"w\"], b[\"y\"])\n    # Effective y after tol offset:\n    eff_y = b[\"y\"] - IS_ON_TOL\n\n    s_lo_x, s_hi_x = s[\"x\"], s[\"x\"] + s[\"w\"]\n    s_lo_y, s_hi_y = s[\"y\"], s[\"y\"] + s[\"h\"]\n\n    def inside(px, py):\n        return s_lo_x <= px <= s_hi_x and s_lo_y <= py <= s_hi_y\n\n    return inside(b[\"x\"], eff_y) and inside(b[\"x\"] + b[\"w\"], eff_y)\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":11,"lines":["-\"\"\"All observation parsing helpers for Obstruction2D-o4-v0.\"\"\"","+\"\"\"All observation parsing helpers for Obstruction2D-o4-v0.","+","+IMPORTANT COORDINATE CONVENTION:","+  - Robot (x, y) = CENTER of the circular base","+  - Rectangle objects (x, y) = BOTTOM-LEFT CORNER  (confirmed by vertex inspection)","+    => center_x = obs_x + obs_w/2","+    => top_y    = obs_y + obs_h","+\"\"\""," import numpy as np"," "," # ── Robot indices ──────────────────────────────────────────────────────────────"]},{"oldStart":12,"oldLines":13,"newStart":19,"newLines":13,"lines":[" ROBOT_GRIP_H    = 7"," ROBOT_GRIP_W    = 8"," ","-# ── Target surface indices ─────────────────────────────────────────────────────","+# ── Target surface indices (bottom-left corner convention) ─────────────────────"," SURF_X     = 9"," SURF_Y     = 10"," SURF_W     = 17"," SURF_H     = 18"," ","-# ── Target block indices ───────────────────────────────────────────────────────","+# ── Target block indices (bottom-left corner convention) ────