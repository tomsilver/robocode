k_y = pickup_robot_y(ob[\"top\"])","-                self._dep_x  = deposit_x_for_index(self._dep_counter)","-                self._dep_y  = self._pick_y      # release at table level","-                self._dep_counter += 1","-                self._phase = _P_RAISE","-                return","-        self._phase = _P_DONE","+        # Collect all obstructions on the surface; pick tallest first to avoid","+        # robot-base collisions when approaching shorter obstructions nearby.","+        candidates = [","+            (i, get_obstruction(obs, i))","+            for i in range(NUM_OBS)","+            if obstruction_on_surface(obs, i)","+        ]","+        if not candidates:","+            self._phase = _P_DONE","+            return","+        i, ob = max(candidates, key=lambda t: t[1][\"top\"])","+        self._pick_x = ob[\"cx\"]","+        self._pick_y = pickup_robot_y(ob[\"top\"])","+        self._dep_x  = choose_deposit_x(obs, i, ob[\"w\"])","+        self._dep_y  = self._pick_y      # release at table level","+        self._phase  = _P_RAISE"," "," "," # ══════════════════════════════════════════════════════════════════════════════"]}],"userModified":false,"replaceAll":false}}
