fallback\n\n\ndef correct_theta(current_theta):\n    return angle_diff(TARGET_THETA, current_theta)\n","structuredPatch":[{"oldStart":115,"oldLines":13,"newStart":115,"newLines":17,"lines":["     return ob[\"cx\"]   # fallback"," "," ","-def choose_deposit_x(obs, carried_idx, carried_ob, block_ob):","+def choose_deposit_x(obs, carried_idx, carried_ob, block_ob, pick_x=None):","     \"\"\"","     Scan x positions and return the first one clear of:","-      1. Target surface","-      2. All other obstructions (robot base clearance)","+      1. Target surface  (checked using effective object x-range after deposit)","+      2. All other obstructions (checked using effective object x-range)","       3. Carried object overlapping robot-at-block approach zone","       4. Robot base at (dep_x, dep_y) colliding with block during LOWER","+","+    pick_x: the robot x used during pickup.  When pick_x != carried_ob[\"cx\"],","+            the object is gripped off-center, so after deposit at robot_x=dep_x","+            the object's effective center = dep_x + (carried_ob[\"cx\"] - pick_x).","     \"\"\"","     from obs_helpers import get_surface, get_obstruction, NUM_OBS, intervals_overlap_strict","     s = get_surface(obs)"]},{"oldStart":129,"oldLines":6,"newStart":133,"newLines":9,"lines":["     carried_top = carried_ob[\"top\"]","     dep_y       = pickup_robot_y(carried_top)"," ","+    # x-offset between object center and robot x during grip","+    cx_offset = carried_ob[\"cx\"] - (pick_x if pick_x is not None else carried_ob[\"cx\"])","+","     block_lo  = block_ob[\"x\"]","     block_hi  = block_ob[\"x\"] + block_ob[\"w\"]","     block_top = block_ob[\"top\"]"]},{"oldStart":138,"oldLines":16,"newStart":145,"newLines":18,"lines":[" ","     x = DEPOSIT_X_SCAN_START","     while x <= DEPOSIT_X_SCAN_END + 1e-9:","-        lo, hi = x - half, x + half","+        # Effective object center and x-range after deposit at robot_x=x","+        eff_cx  = x + cx_offset","+        eff_lo 