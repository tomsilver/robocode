{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NxZ9t9adGbQapK3RVQz1P5","type":"tool_result","content":"1\t\"\"\"All action generation helpers for Obstruction2D-o4-v0.\"\"\"\n2\timport numpy as np\n3\t\n4\t# ── Action space limits ───────────────────────────────────────────────────────\n5\tDX_MAX     = 0.050\n6\tDY_MAX     = 0.050\n7\tDTHETA_MAX = 0.196   # ~π/16\n8\tDARM_MAX   = 0.100\n9\t\n10\t# ── Arm constants ─────────────────────────────────────────────────────────────\n11\tARM_MIN    = 0.10    # = base_radius (minimum arm extension)\n12\tARM_MAX    = 0.20    # maximum arm extension\n13\t\n14\t# ── Gripper geometry (theta = -pi/2, arm pointing DOWN) ───────────────────────\n15\t# Gripper: height=0.07 perpendicular to arm (→ horizontal extent ±0.035)\n16\t#          width=0.01  along arm direction (→ vertical extent ±0.005)\n17\t# Gripper center:  (robot_x, robot_y - arm_joint)\n18\t# Gripper y_min:   robot_y - arm_joint - 0.005  (gripper bottom)\n19\t# Gripper y_max:   robot_y - arm_joint + 0.005  (gripper top)\n20\tGRIP_H          = 0.07    # perpendicular extent\n21\tGRIP_W          = 0.01    # along-arm extent\n22\tGRIP_HALF_H     = GRIP_H / 2         # 0.035 — horizontal reach\n23\tGRIP_HALF_W     = GRIP_W / 2         # 0.005 — vertical half-thickness\n24\t\n25\t# ── Suction zone geometry ─────────────────────────────────────────────────────\n26\t# suction center: (robot_x, robot_y - arm_joint - GRIP_W - GRIP_W/2) = robot_y - arm_joint - 0.015\n27\t# suction y_max:  robot_y - arm_joint - GRIP_W             = robot_y - arm_joint - 0.010\n28\t# suction y_min:  robot_y - arm_joint - GRIP_W - GRIP_W    = robot_y - arm_joint - 0.020\n29\tSUCTION_REACH   = GRIP_W + GRIP_W / 2      # 0.015 below arm_joint\n30\tSUCTION_Y_TOP   = GRIP_W                   # 0.010 below arm_joint (suction top edge)\n31\tSUCTION_Y_BOT   = GRIP_W + GRIP_W          # 0.020 below arm_joint (suction bottom edge)\n32\t\n33\t# ── Pickup geometry ──────────────────