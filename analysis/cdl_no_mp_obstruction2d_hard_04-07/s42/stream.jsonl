) + a small margin.\n    \"\"\"\n    from obs_helpers import get_surface, get_obstruction, NUM_OBS, intervals_overlap_strict\n    s = get_surface(obs)\n    half = max(carried_w / 2, ARM_MIN) + 0.01  # generous clearance\n\n    x = DEPOSIT_X_SCAN_START\n    while x <= DEPOSIT_X_SCAN_END + 1e-9:\n        lo, hi = x - half, x + half\n        # Avoid target surface (expanded by ARM_MIN for robot-base clearance)\n        if intervals_overlap_strict(lo, hi, s[\"x\"] - ARM_MIN, s[\"x\"] + s[\"w\"] + ARM_MIN):\n            x += DEPOSIT_X_SCAN_STEP; continue\n        # Avoid block approach zone (robot base must reach block_cx freely)\n        if intervals_overlap_strict(lo, hi, block_cx - ARM_MIN, block_cx + ARM_MIN):\n            x += DEPOSIT_X_SCAN_STEP; continue\n        # Avoid all obstructions except the one being carried\n        blocked = False\n        for j in range(NUM_OBS):\n            if j == carried_idx:\n                continue\n            ob = get_obstruction(obs, j)\n            if intervals_overlap_strict(lo, hi, ob[\"x\"], ob[\"x\"] + ob[\"w\"]):\n                blocked = True\n                break\n        if not blocked:\n            return x\n        x += DEPOSIT_X_SCAN_STEP\n    return DEPOSIT_X_SCAN_START  # fallback","originalFile":"\"\"\"All action generation helpers for Obstruction2D-o4-v0.\"\"\"\nimport numpy as np\n\n# ── Action space limits ───────────────────────────────────────────────────────\nDX_MAX     = 0.050\nDY_MAX     = 0.050\nDTHETA_MAX = 0.196   # ~π/16\nDARM_MAX   = 0.100\n\n# ── Arm constants ─────────────────────────────────────────────────────────────\nARM_MIN    = 0.10    # = base_radius (minimum arm extension)\nARM_MAX    = 0.20    # maximum arm extension\n\n# ── Gripper geometry (theta = -pi/2, arm pointing DOWN) ───────────────────────\n# Gripper: height=0.07 perpendicular to arm (→ horizontal extent ±0.035)\n#          width=0.01  along arm direction (→ vertical extent ±0.005)\n# Gripper center:  (robot_x, robot_y - arm_joint)\n# Gripper y_min:   robot_y - arm_joint - 0.005  (gripper bottom)\n# Gripper y_max:   robot_y - arm_joint + 0.005  (gripper top)\nGRIP_H          = 0.07    # perpendicular extent\nGRIP_W          = 0.01    # along-arm extent\nGRIP_HALF_H     = GRIP_H / 2         # 0.035 — horizontal reach\nGRIP_HALF_W     = GRIP_W / 2         # 0.005 — vertical half-thickness\n\n# ── Suction zone geometry ─────────────────────────────────────────────────────\n# suction center: (robot_x, robot_y - arm_joint - GRIP_W - GRIP_W/2) = robot_y - arm_joint - 0.015\n# suction y_max:  robot_y - arm_joint - GRIP_W             = robot_y - arm_joint - 0.010\n# suction y_min:  robot_y - arm_joint - GRIP_W - GRIP_W    = robot_y - arm_joint - 0.020\nSUCTION_REACH   = GRIP_W + GRIP_W / 2      # 0.015 below arm_joint\nSUCTION_Y_TOP   = GRIP_W                   # 0.010 below arm_joint (suction top edge)\nSUCTION_Y_BOT   = GRIP_W + GRIP_W          # 0.020 below arm_joint (suction bottom edge)\n\n# ── Pickup geometry ───────────────────────────────────────────────────────────\n# No-collision condition (gripper_y_min > obj_top):\n#   robot_y > obj_top + arm_joint + GRIP_HALF_W  → robot_y > obj_top + 0.105\n# Suction reaches obj top (suction_y_max ≤ obj_top):\n#   robot_y ≤ obj_top + arm_joint + SUCTION_Y_TOP  → robot_y ≤ obj_top + 0.110\n# Safe pickup robot_y = obj_top + arm_joint + PICKUP_OFFSET (midway in window)\nPICKUP_OFFSET   = 0.108   # above obj_top; window is (0.105, 0.110)\n\n# ── Carry / deposit heights ───────────────────────────────────────────────────\nCARRY_HEIGHT    = 0.700   # safe robot_y for horizontal movement while holding\n# Deposit at TABLE LEVEL: dep_y = pick_y (same as pickup), so block lands at y≈0.100.\n\n# ── Deposit x scan range (dynamically computed, see choose_deposit_x) ────────\nDEPOSIT_X_SCAN_START = 0.15\nDEPOSIT_X_SCAN_END   = 1.55\nDEPOSIT_X_SCAN_STEP  = 0.05\n\n# ── Target theta ─────────────────────────────────────────────────────────────\nTARGET_THETA = -np.pi / 2\n\n# ── Tolerances ────────────────────────────────────────────────────────────────\nXY_TOL    = 0.004   # position tolerance (tighter than one DY step)\nARM_TOL   = 0.005\nTHETA_TOL = 0.02\n\n# ── Helpers ───────────────────────────────────────────────────────────────────\n\ndef clamp(v, lo, hi):\n    return max(lo, min(hi, v))\n\n\ndef move_1d(current, target, max_step):\n    \"\"\"Signed delta toward target, bounded by max_step.\"\"\"\n    delta = target - current\n    return clamp(delta, -max_step, max_step)\n\n\ndef angle_diff(a, b):\n    \"\"\"Signed (a - b) wrapped to [-pi, pi].\"\"\"\n    d = a - b\n    while d >  np.pi: d -= 2 * np.pi\n    while d < -np.pi: d += 2 * np.pi\n    return d\n\n\ndef make_action(dx=0.0, dy=0.0, dtheta=0.0, darm=0.0, vac=0.0):\n    return np.array([\n        clamp(dx,     -DX_MAX,     DX_MAX),\n        clamp(dy,     -DY_MAX,     DY_MAX),\n        clamp(dtheta, -DTHETA_MAX, DTHETA_MAX),\n        clamp(darm,   -DARM_MAX,   DARM_MAX),\n        clamp(vac,    0.0,         1.0),\n    ], dtype=np.float32)\n\n\ndef pickup_robot_y(obj_top):\n    \"\"\"Target robot_y to hover just above obj_top with arm retracted at ARM_MIN.\n    Window: (obj_top + 0.105, obj_top + 0.110) — use midpoint.\n    \"\"\"\n    return obj_top + PICKUP_OFFSET   # = obj_top + 0.108\n\n\ndef choose_deposit_x(obs, carried_idx, carried_w):\n    \"\"\"\n    Scan x positions and return the first one where the carried object\n    (width=carried_w) won't x-overlap any other obstruction or the surface.\n    Uses a clearance = max(carried_w/2, ARM_MIN) + a small margin.\n    \"\"\"\n    from obs_helpers import get_surface, get_obstruction, NUM_OBS, intervals_overlap_strict\n    s = get_surface(obs)\n    half = max(carried_w / 2, ARM_MIN) + 0.01  # generous clearance\n\n    x = DEPOSIT_X_SCAN_START\n    while x <= DEPOSIT_X_SCAN_END + 1e-9:\n        lo, hi = x - half, x + half\n        # Avoid target surface\n        if intervals_overlap_strict(lo, hi, s[\"x\"], s[\"x\"] + s[\"w\"]):\n            x += DEPOSIT_X_SCAN_STEP; continue\n        # Avoid all obstructions except the one being carried\n        blocked = False\n        for j in range(NUM_OBS):\n            if j == carried_idx:\n                continue\n            ob = get_obstruction(obs, j)\n            if intervals_overlap_strict(lo, hi, ob[\"x\"], ob[\"x\"] + ob[\"w\"]):\n                blocked = True\n                break\n        if not blocked:\n            return x\n        x += DEPOSIT_X_SCAN_STEP\n    return DEPOSIT_X_SCAN_START  # fallback\n\n\ndef correct_theta(current_theta):\n    \"\"\"Correction dtheta toward TARGET_THETA.\"\"\"\n    return angle_diff(TARGET_THETA, current_theta)\n","structuredPatch":[{"oldStart":92,"oldLines":11,"newStart":92,"newLines":12,"lines":["     return obj_top + PICKUP_OFFSET   # = obj_top + 0.108"," "," ","-def choose_deposit_x(obs, carried_idx, carried_w):","+def choose_deposit_x(obs, carried_idx, carried_w, block_cx):","     \"\"\"","     Scan x positions and return the first one where the carried object","-    (width=carried_w) won't x-overlap any other obstruction or the surface.","-    Uses a clearance = max(carried_w/2, ARM_MIN) + a small margin.","+    (width=carried_w) won't x-overlap any other obstruction, the surface,","+    or the robot's approach zone for the target block.","+    Clearance = max(carried_w/2, ARM_MIN) + a small margin.","     \"\"\"","     from obs_helpers import get_surface, get_obstruction, NUM_OBS, intervals_overlap_strict","     s = get_surface(obs)"]},{"oldStart":105,"oldLines":9,"newStart":106,"newLines":12,"lines":["     x = DEPOSIT_X_SCAN_START","     while x <= DEPOSIT_X_SCAN_END + 1e-9:","         lo, hi = x - half, x + half","-        # Avoid target surface","-        if intervals_overlap_strict(lo, hi, s[\"x\"], s[\"x\"] + s[\"w\"]):","+        # Avoid target surface (expanded by ARM_MIN for robot-base clearance)","+        if intervals_overlap_strict(lo, hi, s[\"x\"] - ARM_MIN, s[\"x\"] + s[\"w\"] + ARM_MIN):","             x += DEPOSIT_X_SCAN_STEP; continue","+        # Avoid block approach zone (robot base must reach block_cx freely)","+        if intervals_overlap_strict(lo, hi, block_cx - ARM_MIN, block_cx + ARM_MIN):","+            x += DEPOSIT_X_SCAN_STEP; continue","         # Avoid all obstructions except the one being carried","         blocked = False","         for j in range(NUM_OBS):"]}],"userModified":false,"replaceAll":false}}
