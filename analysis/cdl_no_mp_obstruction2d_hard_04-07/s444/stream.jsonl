MARGIN = 0.005  # small margin to count x-overlap as \"on surface\"\n\n\ndef extract_robot(obs):\n    \"\"\"Return dict with robot features.\"\"\"\n    return {\n        \"x\": float(obs[ROBOT_X]),\n        \"y\": float(obs[ROBOT_Y]),\n        \"theta\": float(obs[ROBOT_THETA]),\n        \"base_radius\": float(obs[ROBOT_BASE_RADIUS]),\n        \"arm_joint\": float(obs[ROBOT_ARM_JOINT]),\n        \"arm_length\": float(obs[ROBOT_ARM_LENGTH]),\n        \"vacuum\": float(obs[ROBOT_VACUUM]),\n        \"gripper_height\": float(obs[ROBOT_GRIPPER_HEIGHT]),\n        \"gripper_width\": float(obs[ROBOT_GRIPPER_WIDTH]),\n    }\n\n\ndef extract_surface(obs):\n    \"\"\"Return dict with target surface features (bottom-left origin).\"\"\"\n    return {\n        \"x\": float(obs[SURF_X]),\n        \"y\": float(obs[SURF_Y]),\n        \"width\": float(obs[SURF_WIDTH]),\n        \"height\": float(obs[SURF_HEIGHT]),\n    }\n\n\ndef extract_block(obs):\n    \"\"\"Return dict with target block features (bottom-left origin).\"\"\"\n    return {\n        \"x\": float(obs[BLOCK_X]),\n        \"y\": float(obs[BLOCK_Y]),\n        \"width\": float(obs[BLOCK_WIDTH]),\n        \"height\": float(obs[BLOCK_HEIGHT]),\n    }\n\n\ndef extract_obstruction(obs, i):\n    \"\"\"Return dict with obstruction i features (bottom-left origin).\"\"\"\n    b = OBS_BASE_INDICES[i]\n    return {\n        \"x\": float(obs[b + OBS_OFF_X]),\n        \"y\": float(obs[b + OBS_OFF_Y]),\n        \"width\": float(obs[b + OBS_OFF_WIDTH]),\n        \"height\": float(obs[b + OBS_OFF_HEIGHT]),\n    }\n\n\ndef rect_center_x(rect):\n    \"\"\"x-coordinate of rectangle center.\"\"\"\n    return rect[\"x\"] + rect[\"width\"] / 2.0\n\n\ndef rect_center_y(rect):\n    \"\"\"y-coordinate of rectangle center.\"\"\"\n    return rect[\"y\"] + rect[\"height\"] / 2.0\n\n\ndef rects_overlap_x(r1, r2, margin=0.0):\n    \"\"\"True if two rectangles overlap in the x dimension.\"\"\"\n    return (r1[\"x\"] < r2[\"x\"] + r2[\"width\"] - margin and\n            r1[\"x\"] + r1[\"width\"] > r2[\"x\"] + margin)\n\n\ndef obstruction_on_surface(obs, i):\n    \"\"\"True if obstruction i's x-range overlaps target surface x-range.\"\"\"\n    surf = extract_surface(obs)\n    ob = extract_obstruction(obs, i)\n    return rects_overlap_x(ob, surf, margin=SURFACE_OVERLAP_MARGIN)\n\n\ndef any_obstruction_on_surface(obs):\n    \"\"\"True if any obstruction overlaps the target surface.\"\"\"\n    return any(obstruction_on_surface(obs, i) for i in range(NUM_OBSTRUCTIONS))\n\n\ndef is_vacuum_on(obs):\n    \"\"\"True if robot vacuum is on.\"\"\"\n    return float(obs[ROBOT_VACUUM]) >= VACUUM_THRESHOLD\n\n\ndef is_block_held(obs):\n    \"\"\"Heuristic: block is held if vacuum is on and block y is above TABLE_TOP.\"\"\"\n    robot = extract_robot(obs)\n    block = extract_block(obs)\n    return robot[\"vacuum\"] >= VACUUM_THRESHOLD and block[\"y\"] > TABLE_TOP_Y + 0.04\n\n\ndef block_is_on_surface(obs):\n    \"\"\"Check is_on condition: block bottom vertices inside surface (with tolerance).\"\"\"\n    surf = extract_surface(obs)\n    block = extract_block(obs)\n    # Bottom-left and bottom-right vertices of block\n    bx_left = block[\"x\"]\n    bx_right = block[\"x\"] + block[\"width\"]\n    by = block[\"y\"]\n    offset_y = by - IS_ON_TOL\n\n    sx, sw, sy, sh = surf[\"x\"], surf[\"width\"], surf[\"y\"], surf[\"height\"]\n    def surf_contains(px, py):\n        return sx <= px <= sx + sw and sy <= py <= sy + sh\n\n    return surf_contains(bx_left, offset_y) and surf_contains(bx_right, offset_y)\n\n\ndef compute_dump_x(obs, dump_count=0):\n    \"\"\"Return a safe x-coordinate to dump obstructions (away from target surface).\"\"\"\n    surf = extract_surface(obs)\n    surf_cx = surf[\"x\"] + surf[\"width\"] / 2.0\n    block = extract_block(obs)\n    block_cx = block[\"x\"] + block[\"width\"] / 2.0\n\n    # Choose opposite side of world from surface center\n    if surf_cx < WORLD_WIDTH / 2.0:\n        base_x = WORLD_WIDTH - 0.25  # right side\n        spacing = -0.30\n    else:\n        base_x = 0.15  # left side\n        spacing = 0.30\n\n    dump_x = base_x + dump_count * spacing\n    # Clamp to world bounds\n    dump_x = max(0.08, min(WORLD_WIDTH - 0.08, dump_x))\n    return dump_x\n","structuredPatch":[],"originalFile":null}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01NRhS4bvRWJzFpWqnah31EQ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Mms39FTuspuZKJ1wEZTxmR","name":"Write","input":{"file_path":"/sandbox/act_helpers.py","content":"\"\"\"Action helpers and controllers for Obstruction2D-o4-v0.\"\"\"\n\nimport numpy as np\n\n# ── Action limits ─────────────────────────────────────────────────────────────\nDX_MAX = 0.050      # max delta-x per step\nDY_MAX = 0.050      # max delta-y per step\nDTHETA_MAX = 0.196  # max delta-theta per step (~pi/16)\nDARM_MAX = 0.100    # max delta-arm per step\nVAC_OFF = 0.0\nVAC_ON = 1.0\n\n# ── Robot arm constants ───────────────────────────────────────────────────────\nARM_MIN = 0.10      # minimum arm extension (= base_radius)\nARM_MAX = 0.20      # maximum arm extension (= arm_length)\n\n# ── Gripper geometry (when theta = -pi/2, arm points down) ───────────────────\nGRIPPER_WIDTH = 0.010    # thin dimension of gripper along arm direction\nSUCTION_WIDTH = 0.010    # suction zone width (= gripper_width)\nSUCTION_OFFSET = GRIPPER_WIDTH + SUCTION_WIDTH / 2.0  # = 0.015; offset from arm_joint to suction center\nSUCTION_HALF_X = 0.035   # half-extent of suction zone in x when theta=-pi/2 (= gripper_height/2)\nSUCTION_HALF_Y = 0.005   # half-extent of suction zone in y when theta=-pi/2 (= suction_width/2)\n\n# ── World / table constants ───────────────────────────────────────────────────\nTABLE_TOP_Y = 0.10       # y-coordinate of table surface (objects rest here)\nCARRY_HEIGHT = 0.72      # robot y when carrying objects (clear of all table obstructions)\n\n# ── Controller gains ──────────────────────────────────────────────────────────\nXY_GAIN = 2.5          # proportional gain for x/y positioning\nARM_GAIN = 4.0         # proportional gain for arm extension\nTHETA_GAIN = 2.0       # proportional gain for theta correction\nTARGET_THETA = -np.pi / 2.0  # desired robot orientation (arm pointing down)\n\n# ── Tolerances ────────────────────────────────────────────────────────────────\nXY_TOL = 0.018         # position tolerance for \"close enough\"\nARM_TOL = 0.008        # arm joint tolerance for \"close enough\"\nTHETA_TOL = 0.05       # theta tolerance\n\n\ndef _clip(val, lo, hi):\n    return max(lo, min(hi, float(val)))\n\n\ndef _angle_diff(target, current):\n    \"\"\"Signed angular difference in [-pi, pi].\"\"\"\n    diff = target - current\n    while diff > np.pi:\n        diff -= 2.0 * np.pi\n    while diff < -np.pi:\n        diff += 2.0 * np.pi\n    return diff\n\n\ndef move_action(rx, ry, rtheta, arm_joint, target_x, target_y, target_arm, vac):\n    \"\"\"Return a 5-element action to move robot toward target state.\"\"\"\n    dx = _clip((target_x - rx) * XY_GAIN, -DX_MAX, DX_MAX)\n    dy = _clip((target_y - ry) * XY_GAIN, -DY_MAX, DY_MAX)\n    dtheta = _clip(_angle_diff(TARGET_THETA, rtheta) * THETA_GAIN, -DTHETA_MAX, DTHETA_MAX)\n    darm = _clip((target_arm - arm_joint) * ARM_GAIN, -DARM_MAX, DARM_MAX)\n    return np.array([dx, dy, dtheta, darm, float(vac)], dtype=np.float64)\n\n\ndef compute_pick_height(obj_height):\n    \"\"\"Robot y needed so arm at ARM_MAX puts suction at object vertical center.\n\n    With arm_joint = ARM_MAX and theta = -pi/2:\n        suction_cy = robot_y - ARM_MAX - SUCTION_OFFSET = TABLE_TOP + obj_height/2\n    => robot_y = TABLE_TOP + obj_height/2 + ARM_MAX + SUCTION_OFFSET\n    \"\"\"\n    return TABLE_TOP_Y + obj_height / 2.0 + ARM_MAX + SUCTION_OFFSET\n\n\ndef at_position(rx, ry, target_x, target_y, tol=None):\n    \"\"\"True if robot is within tolerance of target (x, y).\"\"\"\n    if tol is None:\n        tol = XY_TOL\n    return abs(rx - target_x) <= tol and abs(ry - target_y) <= tol\n\n\ndef at_arm(arm_joint, target_arm, tol=None):\n    \"\"\"True if arm is within tolerance of target extension.\"\"\"\n    if tol is None:\n        tol = ARM_TOL\n    return abs(arm_joint - target_arm) <= tol\n\n\ndef at_theta(rtheta, tol=None):\n    \"\"\"True if robot theta is close to TARGET_THETA.\"\"\"\n    if tol is None:\n        tol = THETA_TOL\n    return abs(_angle_diff(TARGET_THETA, rtheta)) <= tol\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2104,"cache_read_input_tokens":68067,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2104},"output_tokens":55,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4fa831d9-eb3f-4745-b971-234a10cba938","uuid":"f2172879-120d-41b9-8960-989ea3095ff9"}
