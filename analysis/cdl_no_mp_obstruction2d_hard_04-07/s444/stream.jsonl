le\n\n# Read obstruction2d.py to understand scene layout\nimport kinder.envs.geom2d, os\npath = kinder.envs.geom2d.__path__[0]\nwith open(os.path.join(path, 'obstruction2d.py'), 'r') as f:\n    print(\"\\n=== obstruction2d.py ===\")\n    print(f.read())\n```\n","uuid":"3313cd41-41c9-414e-9192-93dd26163eb6","session_id":"4fa831d9-eb3f-4745-b971-234a10cba938"}
