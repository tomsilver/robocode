{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BRZYcPKwzVpbQyajEugz5B","type":"tool_result","content":"1\t\"\"\"Base class for Geom2D robot environments.\"\"\"\n2\t\n3\timport abc\n4\tfrom dataclasses import dataclass\n5\tfrom typing import Any, Generic, TypeVar\n6\t\n7\timport gymnasium\n8\timport numpy as np\n9\tfrom numpy.typing import NDArray\n10\tfrom prpl_utils.utils import wrap_angle\n11\tfrom relational_structs import (\n12\t    Array,\n13\t    Object,\n14\t    ObjectCentricState,\n15\t    ObjectCentricStateSpace,\n16\t    Type,\n17\t)\n18\tfrom relational_structs.utils import create_state_from_dict\n19\t\n20\tfrom kinder.core import KinDEREnvConfig, ObjectCentricKinDEREnv, RobotActionSpace\n21\tfrom kinder.envs.geom2d.object_types import (\n22\t    CRVRobotType,\n23\t    Geom2DRobotEnvTypeFeatures,\n24\t)\n25\tfrom kinder.envs.geom2d.structs import MultiBody2D, SE2Pose\n26\tfrom kinder.envs.geom2d.utils import (\n27\t    CRVRobotActionSpace,\n28\t    get_geom2d_crv_robot_action_from_gui_input,\n29\t    get_suctioned_objects,\n30\t    snap_suctioned_objects,\n31\t)\n32\tfrom kinder.envs.utils import render_2dstate, state_2d_has_collision\n33\t\n34\t\n35\t@dataclass(frozen=True)\n36\tclass Geom2DRobotEnvConfig(KinDEREnvConfig):\n37\t    \"\"\"Scene configuration for a Geom2DRobotEnv.\"\"\"\n38\t\n39\t    # The world is oriented like a standard X/Y coordinate frame.\n40\t    world_min_x: float = 0.0\n41\t    world_max_x: float = 10.0\n42\t    world_min_y: float = 0.0\n43\t    world_max_y: float = 10.0\n44\t\n45\t    # Action space parameters.\n46\t    min_dx: float = -5e-1\n47\t    max_dx: float = 5e-1\n48\t    min_dy: float = -5e-1\n49\t    max_dy: float = 5e-1\n50\t    min_dtheta: float = -np.pi / 16\n51\t    max_dtheta: float = np.pi / 16\n52\t    min_darm: float = -1e-1\n53\t    max_darm: float = 1e-1\n54\t    min_vac: float = 0.0\n55\t    max_vac: float = 1.0\n56\t\n57\t    # For rendering.\n58\t    render_dpi: int = 50\n59\t\n60\t\n61\t_ConfigType = TypeVar(\"_ConfigType\", bound=Geom2DRobotEnvConfig)\n62\t\n63\t\n64\tclass ObjectCentricGeom2DRobotEnv(\n65\t    ObjectCentricKinDEREnv[ObjectCentricState, Array, _ConfigType],\n66\t    Generic[_ConfigType],\n67\t):\n68\t    \"\"\"Base class for Geom2D robot environments.\n69\t\n70\t    NOTE: this implementation currently assumes we are using CRVRobotType.\n71\t    If we add other robot types in the future, we will need to refactor a bit.\n72\t    \"\"\"\n73\t\n74\t    def __init__(self, *args, **kwargs) -> None:\n75\t        super().__init__(*args, **kwargs)\n76\t\n77\t        # Initialized by reset().\n78\t        self._current_state: ObjectCentricState | None = None\n79\t\n80\t        # Used for collision checking.\n81\t        self._static_object_body_cache: dict[Object, MultiBody2D] = {}\n82\t\n83\t    @abc.abstractmethod\n84\t    def _create_constant_initial_state_dict(self) -> dict[Object, dict[str, float]]:\n85\t        \"\"\"Create the constant initial state dict.\"\"\"\n86\t\n87\t    @abc.abstractmethod\n88\t    def _sample_initial_state(self) -> ObjectCentricState:\n89\t        \"\"\"Use self.np_random to sample an initial state.\"\"\"\n90\t\n91\t    @abc.abstractmethod\n92\t    def _get_reward_and_done(self) -> tuple[float, bool]:\n93\t        \"\"\"Calculate reward and termination based on self._current_state.\"\"\"\n94\t\n95\t    def _create_observation_space(self, config: _ConfigType) -> ObjectCentricStateSpace:\n96\t        types = set(self.type_features)\n97\t        return ObjectCentricStateSpace(types)\n98\t\n99\t    def _create_action_space(self, config: _ConfigType) -> RobotActionSpace:\n100\t        return CRVRobotActionSpace(\n101\t            min_dx=config.min_dx,\n102\t            max_dx=config.max_dx,\n103\t            min_dy=config.min_dy,\n104\t            max_dy=config.max_dy,\n105\t            min_dtheta=config.min_dtheta,\n106\t            max_dtheta=config.max_dtheta,\n107\t            min_darm=config.min_darm,\n108\t            max_darm=config.max_darm,\n109\t            min_vac=config.min_vac,\n110\t            max_vac=config.max_vac,\n111\t        )\n112\t\n113\t    def _create_constant_initial_state(self) -> ObjectCentricState:\n114\t        initial_state_dict = self._create_constant_initial_state_dict()\n115\t        return create_state_from_dict(initial_state_dict, Geom2DRobotEnvTypeFeatures)\n116\t\n117\t    def reset(\n118\t        self, *, seed: int | None = None, options: dict | None = None\n119\t    ) -> tuple[ObjectCentricState, dict]:\n120\t        # Reset random seeding.\n121\t        gymnasium.Env.reset(self, seed=seed)\n122\t\n123\t        # Need to flush the cache in case static objects move.\n124\t        self._static_object_body_cache = {}\n125\t\n126\t        # For testing purposes only, the options may specify an initial scene.\n127\t        if options is not None and \"init_state\" in options:\n128\t            self._current_state = options[\"init_state\"].copy()\n129\t\n130\t        # Otherwise, set up the initial scene here.\n131\t        else:\n132\t            self._current_state = self._sample_initial_state()\n133\t\n134\t        observation = self._get_obs()\n135\t        info = self._get_info()\n136\t\n137\t        return observation, info\n138\t\n139\t    def step(self, action: Array) -> tuple[ObjectCentricState, float, bool, bool, dict]:\n140\t        assert self.action_space.contains(action)\n141\t        dx, dy, dtheta, darm, vac = action\n142\t        assert self._current_state is not None, \"Need to call reset()\"\n143\t        state = self._current_state.copy()\n144\t        robots = [o for o in state if o.is_instance(CRVRobotType)]\n145\t        assert len(robots) == 1, \"Multi-robot not yet supported\"\n146\t        robot = robots[0]\n147\t\n148\t        # NOTE: xy clipping is not needed because world boundaries are assumed\n149\t        # handled by collision detection with walls.\n150\t        new_x = state.get(robot, \"x\") + dx\n151\t        new_y = state.get(robot, \"y\") + dy\n152\t        new_theta = wrap_angle(state.get(robot, \"theta\") + dtheta)\n153\t        min_arm = state.get(robot, \"base_radius\")\n154\t        max_arm = state.get(robot, \"arm_length\")\n155\t        new_arm = np.clip(state.get(robot, \"arm_joint\") + darm, min_arm, max_arm)\n156\t        state.set(robot, \"x\", new_x)\n157\t        state.set(robot, \"y\", new_y)\n158\t        state.set(robot, \"arm_joint\", new_arm)\n159\t        state.set(robot, \"theta\", new_theta)\n160\t        state.set(robot, \"vacuum\", vac)\n161\t\n162\t        # The order here is subtle and important:\n163\t        # 1) Look at which objects were suctioned in the *previous* time step.\n164\t        # 2) Get the transform between gripper and object in the *previous*.\n165\t        # 3) Update the position of the object to snap to the robot *now*.\n166\t        # 4) When checking collisions, make sure to include all objects that\n167\t        #    may have moved. This cannot be derived from `state` alone!\n168\t        # The last point was previously overlook and led to bugs where the held\n169\t        # objects could come into collision with other objects if the suction is\n170\t        # disabled at the right time.\n171\t\n172\t        # Update the state of any objects that are currently suctioned.\n173\t        # NOTE: this is both objects and their SE2 transforms.\n174\t        suctioned_objs = get_suctioned_objects(self._current_state, robot)\n175\t        snap_suctioned_objects(state, robot, suctioned_objs)\n176\t\n177\t        # Update non-static objects if contact is detected between them\n178\t        # and the suctioned objects.\n179\t        state, moved_objects = self.get_objects_to_move(state, suctioned_objs)\n180\t\n181\t        # Check for collisions, and only update the state if none exist.\n182\t        moving_objects = (\n183\t            {robot} | {o for o, _ in suctioned_objs} | {o for o, _ in moved_objects}\n184\t        )\n185\t        full_state = state.copy()\n186\t        full_state.data.update(self.initial_constant_state.data)\n187\t        obstacles = set(full_state) - moving_objects\n188\t        if not state_2d_has_collision(\n189\t            full_state, moving_objects, obstacles, self._static_object_body_cache\n190\t        ):\n191\t            self._current_state = state\n192\t\n193\t        reward, terminated = self._get_reward_and_done()\n194\t        truncated = False  # no maximum horizon, by default\n195\t        observation = self._get_obs()\n196\t        info = self._get_info()\n197\t        return observation, reward, terminated, truncated, info\n198\t\n199\t    @property\n200\t    def type_features(self) -> dict[Type, list[str]]:\n201\t        \"\"\"The types and features for this environment.\"\"\"\n202\t        return Geom2DRobotEnvTypeFeatures\n203\t\n204\t    def _get_obs(self) -> ObjectCentricState:\n205\t        assert self._current_state is not None, \"Need to call reset()\"\n206\t        # NOTE: Based on the discussion, we commit to providing\n207\t        # only the changeable objects in the state.\n208\t        # A learning-based algorithm has no access to the\n209\t        # initial constant state, as the algorithm should learn\n210\t        # to handle them if they affect decision making.\n211\t\n212\t        # That being said, we still want to provide an interface\n213\t        # for accessing the static objects, as some baselines\n214\t        # (planner model) requires such information.\n215\t        return self._current_state.copy()\n216\t\n217\t    def _get_info(self) -> dict:\n218\t        return {}  # no extra info provided right now\n219\t\n220\t    @property\n221\t    def full_state(self) -> ObjectCentricState:\n222\t        \"\"\"Get the full state, which includes both dynamic and static objects.\"\"\"\n223\t        assert self._current_state is not None\n224\t        return self.get_state_with_constant_objects(self._current_state)\n225\t\n226\t    def get_objects_to_move(\n227\t        self,\n228\t        state: ObjectCentricState,\n229\t        suctioned_objs: list[tuple[Object, SE2Pose]],\n230\t    ) -> tuple[ObjectCentricState, set[tuple[Object, SE2Pose]]]:\n231\t        \"\"\"Get the set of objects that should be moved based on the current state and\n232\t        robot actions.\n233\t\n234\t        Implement this in the derived class.\n235\t        \"\"\"\n236\t        del suctioned_objs  # not used, but subclasses may use\n237\t        # Explicitly type the set to ensure it's set[Object]\n238\t        moved_objects: set[tuple[Object, SE2Pose]] = set()\n239\t        return state, moved_objects\n240\t\n241\t    def render(self) -> NDArray[np.uint8]:  # type: ignore\n242\t        assert self.render_mode == \"rgb_array\"\n243\t        assert self._current_state is not None, \"Need to call reset()\"\n244\t        render_input_state = self._current_state.copy()\n245\t        render_input_state.data.update(self.initial_constant_state.data)\n246\t        return render_2dstate(\n247\t            render_input_state,\n248\t            self._static_object_body_cache,\n249\t            self.config.world_min_x,\n250\t            self.config.world_max_x,\n251\t            self.config.world_min_y,\n252\t            self.config.world_max_y,\n253\t            self.config.render_dpi,\n254\t        )\n255\t\n256\t    def get_action_from_gui_input(\n257\t        self, gui_input: dict[str, Any]\n258\t    ) -> NDArray[np.float32]:\n259\t        \"\"\"Get the mapping from human inputs to actions.\"\"\"\n260\t        assert isinstance(self.action_space, CRVRobotActionSpace)\n261\t        return get_geom2d_crv_robot_action_from_gui_input(self.action_space, gui_input)\n262\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze