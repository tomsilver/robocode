{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EcKUKeKfTqabHMyhkT5Xwv","type":"tool_result","content":"1\t\"\"\"Utilities.\"\"\"\n2\t\n3\tfrom typing import Any\n4\t\n5\timport numpy as np\n6\tfrom numpy.typing import NDArray\n7\tfrom prpl_utils.utils import get_signed_angle_distance\n8\tfrom relational_structs import (\n9\t    Array,\n10\t    Object,\n11\t    ObjectCentricState,\n12\t)\n13\tfrom tomsgeoms2d.structs import Rectangle\n14\tfrom tomsgeoms2d.utils import find_closest_points, geom2ds_intersect\n15\t\n16\tfrom kinder.core import RobotActionSpace\n17\tfrom kinder.envs.geom2d.object_types import (\n18\t    DoubleRectType,\n19\t    RectangleType,\n20\t)\n21\tfrom kinder.envs.geom2d.structs import (\n22\t    MultiBody2D,\n23\t    SE2Pose,\n24\t    ZOrder,\n25\t)\n26\tfrom kinder.envs.utils import (\n27\t    BLACK,\n28\t    crv_robot_to_multibody2d,\n29\t    double_rectangle_object_to_part_geom,\n30\t    get_se2_pose,\n31\t    object_to_multibody2d,\n32\t    rectangle_object_to_geom,\n33\t)\n34\t\n35\t\n36\tclass CRVRobotActionSpace(RobotActionSpace):\n37\t    \"\"\"An action space for a CRV robot.\n38\t\n39\t    Actions are bounded relative movements of the base and the arm, as well as an\n40\t    absolute setting for the vacuum.\n41\t    \"\"\"\n42\t\n43\t    def __init__(\n44\t        self,\n45\t        min_dx: float = -5e-1,\n46\t        max_dx: float = 5e-1,\n47\t        min_dy: float = -5e-1,\n48\t        max_dy: float = 5e-1,\n49\t        min_dtheta: float = -np.pi / 16,\n50\t        max_dtheta: float = np.pi / 16,\n51\t        min_darm: float = -1e-1,\n52\t        max_darm: float = 1e-1,\n53\t        min_vac: float = 0.0,\n54\t        max_vac: float = 1.0,\n55\t    ) -> None:\n56\t        low = np.array([min_dx, min_dy, min_dtheta, min_darm, min_vac])\n57\t        high = np.array([max_dx, max_dy, max_dtheta, max_darm, max_vac])\n58\t        super().__init__(low, high)\n59\t\n60\t    def create_markdown_description(self) -> str:\n61\t        \"\"\"Create a human-readable markdown description of this space.\"\"\"\n62\t        # pylint: disable=line-too-long\n63\t        features = [\n64\t            (\"dx\", \"Change in robot x position (positive is right)\"),\n65\t            (\"dy\", \"Change in robot y position (positive is up)\"),\n66\t            (\"dtheta\", \"Change in robot angle in radians (positive is ccw)\"),\n67\t            (\"darm\", \"Change in robot arm length (positive is out)\"),\n68\t            (\"vac\", \"Directly sets the vacuum (0.0 is off, 1.0 is on)\"),\n69\t        ]\n70\t        md_table_str = (\n71\t            \"| **Index** | **Feature** | **Description** | **Min** | **Max** |\"\n72\t        )\n73\t        md_table_str += \"\\n| --- | --- | --- | --- | --- |\"\n74\t        for idx, (feature, description) in enumerate(features):\n75\t            lb = self.low[idx]\n76\t            ub = self.high[idx]\n77\t            md_table_str += (\n78\t                f\"\\n| {idx} | {feature} | {description} | {lb:.3f} | {ub:.3f} |\"\n79\t            )\n80\t        return f\"The entries of an array in this Box space correspond to the following action features:\\n{md_table_str}\\n\"\n81\t\n82\t\n83\tdef create_walls_from_world_boundaries(\n84\t    world_min_x: float,\n85\t    world_max_x: float,\n86\t    world_min_y: float,\n87\t    world_max_y: float,\n88\t    min_dx: float,\n89\t    max_dx: float,\n90\t    min_dy: float,\n91\t    max_dy: float,\n92\t) -> dict[Object, dict[str, float]]:\n93\t    \"\"\"Create wall objects and feature dicts based on world boundaries.\n94\t\n95\t    Velocities are used to determine how large the walls need to be to avoid the\n96\t    possibility that the robot will transport over the wall.\n97\t    \"\"\"\n98\t    state_dict: dict[Object, dict[str, float]] = {}\n99\t    # Right wall.\n100\t    right_wall = Object(\"right_wall\", RectangleType)\n101\t    side_wall_height = world_max_y - world_min_y\n102\t    state_dict[right_wall] = {\n103\t        \"x\": world_max_x,\n104\t        \"y\": world_min_y,\n105\t        \"width\": 2 * max_dx,  # 2x just for safety\n106\t        \"height\": side_wall_height,\n107\t        \"theta\": 0.0,\n108\t        \"static\": True,\n109\t        \"color_r\": BLACK[0],\n110\t        \"color_g\": BLACK[1],\n111\t        \"color_b\": BLACK[2],\n112\t        \"z_order\": ZOrder.ALL.value,\n113\t    }\n114\t    # Left wall.\n115\t    left_wall = Object(\"left_wall\", RectangleType)\n116\t    state_dict[left_wall] = {\n117\t        \"x\": world_min_x + 2 * min_dx,\n118\t        \"y\": world_min_y,\n119\t        \"width\": 2 * abs(min_dx),  # 2x just for safety\n120\t        \"height\": side_wall_height,\n121\t        \"theta\": 0.0,\n122\t        \"static\": True,\n123\t        \"color_r\": BLACK[0],\n124\t        \"color_g\": BLACK[1],\n125\t        \"color_b\": BLACK[2],\n126\t        \"z_order\": ZOrder.ALL.value,\n127\t    }\n128\t    # Top wall.\n129\t    top_wall = Object(\"top_wall\", RectangleType)\n130\t    horiz_wall_width = 2 * 2 * abs(min_dx) + world_max_x - world_min_x\n131\t    state_dict[top_wall] = {\n132\t        \"x\": world_min_x + 2 * min_dx,\n133\t        \"y\": world_max_y,\n134\t        \"width\": horiz_wall_width,\n135\t        \"height\": 2 * max_dy,\n136\t        \"theta\": 0.0,\n137\t        \"static\": True,\n138\t        \"color_r\": BLACK[0],\n139\t        \"color_g\": BLACK[1],\n140\t        \"color_b\": BLACK[2],\n141\t        \"z_order\": ZOrder.ALL.value,\n142\t    }\n143\t    # Bottom wall.\n144\t    bottom_wall = Object(\"bottom_wall\", RectangleType)\n145\t    state_dict[bottom_wall] = {\n146\t        \"x\": world_min_x + 2 * min_dx,\n147\t        \"y\": world_min_y + 2 * min_dy,\n148\t        \"width\": horiz_wall_width,\n149\t        \"height\": 2 * max_dy,\n150\t        \"theta\": 0.0,\n151\t        \"static\": True,\n152\t        \"color_r\": BLACK[0],\n153\t        \"color_g\": BLACK[1],\n154\t        \"color_b\": BLACK[2],\n155\t        \"z_order\": ZOrder.ALL.value,\n156\t    }\n157\t    return state_dict\n158\t\n159\t\n160\tdef get_tool_tip_position(\n161\t    state: ObjectCentricState, robot: Object\n162\t) -> tuple[float, float]:\n163\t    \"\"\"Get the tip of the tool for the robot, which is defined as the center of the\n164\t    bottom edge of the gripper.\"\"\"\n165\t    multibody = crv_robot_to_multibody2d(robot, state)\n166\t    gripper_geom = multibody.get_body(\"gripper\").geom\n167\t    assert isinstance(gripper_geom, Rectangle)\n168\t    # Transform the x, y point.\n169\t    tool_tip = np.array([1.0, 0.5])\n170\t    scale_matrix = np.array(\n171\t        [\n172\t            [gripper_geom.width, 0],\n173\t            [0, gripper_geom.height],\n174\t        ]\n175\t    )\n176\t    translate_vector = np.array([gripper_geom.x, gripper_geom.y])\n177\t    tool_tip = tool_tip @ scale_matrix.T\n178\t    tool_tip = tool_tip @ gripper_geom.rotation_matrix.T\n179\t    tool_tip = translate_vector + tool_tip\n180\t    return (tool_tip[0], tool_tip[1])\n181\t\n182\t\n183\tdef get_suctioned_objects(\n184\t    state: ObjectCentricState, robot: Object\n185\t) -> list[tuple[Object, SE2Pose]]:\n186\t    \"\"\"Find objects that are in the suction zone of a CRVRobot and return the associated\n187\t    transform from gripper tool tip to suctioned object.\"\"\"\n188\t    # If the robot's vacuum is not on, there are no suctioned objects.\n189\t    if state.get(robot, \"vacuum\") <= 0.5:\n190\t        return []\n191\t    robot_multibody = crv_robot_to_multibody2d(robot, state)\n192\t    suction_body = robot_multibody.get_body(\"suction\")\n193\t    gripper_x, gripper_y = get_tool_tip_position(state, robot)\n194\t    gripper_theta = state.get(robot, \"theta\")\n195\t    world_to_gripper = SE2Pose(gripper_x, gripper_y, gripper_theta)\n196\t    # Find MOVABLE objects in collision with the suction geom.\n197\t    movable_objects = [o for o in state if o != robot and state.get(o, \"static\") < 0.5]\n198\t    suctioned_objects: list[tuple[Object, SE2Pose]] = []\n199\t    for obj in movable_objects:\n200\t        # No point in using a static object cache because these objects are\n201\t        # not static by definition.\n202\t        obj_multibody = object_to_multibody2d(obj, state, {})\n203\t        for obj_body in obj_multibody.bodies:\n204\t            if geom2ds_intersect(suction_body.geom, obj_body.geom):\n205\t                world_to_obj = get_se2_pose(state, obj)\n206\t                gripper_to_obj = world_to_gripper.inverse * world_to_obj\n207\t                suctioned_objects.append((obj, gripper_to_obj))\n208\t    return suctioned_objects\n209\t\n210\t\n211\tdef snap_suctioned_objects(\n212\t    state: ObjectCentricState,\n213\t    robot: Object,\n214\t    suctioned_objs: list[tuple[Object, SE2Pose]],\n215\t) -> None:\n216\t    \"\"\"Updates the state in-place.\"\"\"\n217\t    gripper_x, gripper_y = get_tool_tip_position(state, robot)\n218\t    gripper_theta = state.get(robot, \"theta\")\n219\t    world_to_gripper = SE2Pose(gripper_x, gripper_y, gripper_theta)\n220\t    for obj, gripper_to_obj in suctioned_objs:\n221\t        world_to_obj = world_to_gripper * gripper_to_obj\n222\t        state.set(obj, \"x\", world_to_obj.x)\n223\t        state.set(obj, \"y\", world_to_obj.y)\n224\t        state.set(obj, \"theta\", world_to_obj.theta)\n225\t\n226\t\n227\tdef move_objects_in_contact(\n228\t    state: ObjectCentricState,\n229\t    robot: Object,\n230\t    suctioned_objs: list[tuple[Object, SE2Pose]],\n231\t) -> tuple[ObjectCentricState, set[tuple[Object, SE2Pose]]]:\n232\t    \"\"\"Move objects that are in contact with the robot's suctioned objects.\"\"\"\n233\t    moved_objects = []\n234\t    moving_objects = {robot} | {o for o, _ in suctioned_objs}\n235\t    nonstatic_objects = {\n236\t        o for o in state if (o not in moving_objects) and (not state.get(o, \"static\"))\n237\t    }\n238\t\n239\t    for contact_obj in nonstatic_objects:\n240\t        for suctioned_obj, _ in suctioned_objs:\n241\t            suctioned_body = object_to_multibody2d(suctioned_obj, state, {})\n242\t            contact_body = object_to_multibody2d(contact_obj, state, {})\n243\t            for b1 in suctioned_body.bodies:\n244\t                for b2 in contact_body.bodies:\n245\t                    if geom2ds_intersect(b1.geom, b2.geom):\n246\t                        closest_points_b1, closest_points_b2, _ = find_closest_points(\n247\t                            b1.geom, b2.geom\n248\t                        )\n249\t                        contact_vec = np.array(closest_points_b2) - np.array(\n250\t                            closest_points_b1\n251\t                        )\n252\t\n253\t                        current_x = state.get(contact_obj, \"x\")\n254\t                        current_y = state.get(contact_obj, \"y\")\n255\t\n256\t                        new_x = current_x + contact_vec[0]\n257\t                        new_y = current_y + contact_vec[1]\n258\t\n259\t                        state.set(contact_obj, \"x\", new_x)\n260\t                        state.set(contact_obj, \"y\", new_y)\n261\t\n262\t                        moved_objects.append(\n263\t                            (contact_obj, get_se2_pose(state, contact_obj))\n264\t                        )\n265\t\n266\t                        return state, set(moved_objects)  # Stop checking other objects\n267\t\n268\t    return state, set(moved_objects)\n269\t\n270\t\n271\tdef crv_pose_plan_to_action_plan(\n272\t    pose_plan: list[SE2Pose],\n273\t    action_space: CRVRobotActionSpace,\n274\t    vacuum_while_moving: bool = False,\n275\t) -> list[Array]:\n276\t    \"\"\"Convert a CRV robot pose plan into corresponding actions.\"\"\"\n277\t    action_plan: list[Array] = []\n278\t    for pt1, pt2 in zip(pose_plan[:-1], pose_plan[1:]):\n279\t        action = np.zeros_like(action_space.high)\n280\t        action[0] = pt2.x - pt1.x\n281\t        action[1] = pt2.y - pt1.y\n282\t        action[2] = get_signed_angle_distance(pt2.theta, pt1.theta)\n283\t        action[4] = 1.0 if vacuum_while_moving else 0.0\n284\t        action_plan.append(action)\n285\t    return action_plan\n286\t\n287\t\n288\tdef is_inside(\n289\t    state: ObjectCentricState,\n290\t    inner: Object,\n291\t    outer: Object,\n292\t    static_object_cache: dict[Object, MultiBody2D],\n293\t) -> bool:\n294\t    \"\"\"Checks if the inner object is completely inside the outer one.\n295\t\n296\t    Only rectangles are currently supported.\n297\t    \"\"\"\n298\t    inner_geom = rectangle_object_to_geom(state, inner, static_object_cache)\n299\t    outer_geom = rectangle_object_to_geom(state, outer, static_object_cache)\n300\t    for x, y in inner_geom.vertices:\n301\t        if not outer_geom.contains_point(x, y):\n302\t            return False\n303\t    return True\n304\t\n305\t\n306\tdef is_inside_shelf(\n307\t    state: ObjectCentricState,\n308\t    inner: Object,\n309\t    outer: Object,\n310\t    static_object_cache: dict[Object, MultiBody2D],\n311\t) -> bool:\n312\t    \"\"\"Checks if the inner object is completely inside the outer shelf.\n313\t\n314\t    The outer object is assumed to be a double rectangle type. (shelf)\n315\t    \"\"\"\n316\t    assert outer.is_instance(\n317\t        DoubleRectType\n318\t    ), \"Outer object must be a shelf (DoubleRectType).\"\n319\t    inner_geom = rectangle_object_to_geom(state, inner, static_object_cache)\n320\t    outer_geom = double_rectangle_object_to_part_geom(state, outer, static_object_cache)\n321\t    for x, y in inner_geom.vertices:\n322\t        if not outer_geom.contains_point(x, y):\n323\t            return False\n324\t    return True\n325\t\n326\t\n327\tdef is_on(\n328\t    state: ObjectCentricState,\n329\t    top: Object,\n330\t    bottom: Object,\n331\t    static_object_cache: dict[Object, MultiBody2D],\n332\t    tol: float = 0.025,\n333\t) -> bool:\n334\t    \"\"\"Checks top object is completely on the bottom one.\n335\t\n336\t    Only rectangles are currently supported.\n337\t\n338\t    Assumes that \"up\" is positive y.\n339\t    \"\"\"\n340\t    top_geom = rectangle_object_to_geom(state, top, static_object_cache)\n341\t    bottom_geom = rectangle_object_to_geom(state, bottom, static_object_cache)\n342\t    # The bottom-most vertices of top_geom should be contained within the bottom\n343\t    # geom when those vertices are offset by tol.\n344\t    sorted_vertices = sorted(top_geom.vertices, key=lambda v: v[1])\n345\t    for x, y in sorted_vertices[:2]:\n346\t        offset_y = y - tol\n347\t        if not bottom_geom.contains_point(x, offset_y):\n348\t            return False\n349\t    return True\n350\t\n351\t\n352\tdef is_movable_rectangle(state: ObjectCentricState, obj: Object) -> bool:\n353\t    \"\"\"Checks if an object is a movable rectangle.\"\"\"\n354\t    return obj.is_instance(RectangleType) and state.get(obj, \"static\") < 0.5\n355\t\n356\t\n357\tdef get_geom2d_crv_robot_action_from_gui_input(\n358\t    action_space: CRVRobotActionSpace, gui_input: dict[str, Any]\n359\t) -> NDArray[np.float32]:\n360\t    \"\"\"Get the mapping from human inputs to actions, derived from action space.\"\"\"\n361\t    # Unpack the input.\n362\t    keys_pressed = gui_input[\"keys\"]\n363\t    right_x, right_y = gui_input[\"right_stick\"]\n364\t    left_x, _ = gui_input[\"left_stick\"]\n365\t\n366\t    # Initialize the action.\n367\t    low = action_space.low\n368\t    high = action_space.high\n369\t    action = np.zeros(action_space.shape, action_space.dtype)\n370\t\n371\t    def _rescale(x: float, lb: float, ub: float) -> float:\n372\t        \"\"\"Rescale from [-1, 1] to [lb, ub].\"\"\"\n373\t        return lb + (x + 1) * (ub - lb) / 2\n374\t\n375\t    # The right stick controls the x, y movement of the base.\n376\t    action[0] = _rescale(right_x, low[0], high[0])\n377\t    action[1] = _rescale(right_y, low[1], high[1])\n378\t\n379\t    # The left stick controls the rotation of the base. Only the x axis\n380\t    # is used right now.\n381\t    action[2] = _rescale(left_x, low[2], high[2])\n382\t\n383\t    # The w/s mouse keys are used to adjust the robot arm.\n384\t    if \"w\" in keys_pressed:\n385\t        action[3] = low[3]\n386\t    if \"s\" in keys_pressed:\n387\t        action[3] = high[3]\n388\t\n389\t    # The space bar is used to turn on the vacuum.\n390\t    if \"space\" in keys_pressed:\n391\t        action[4] = 1.0\n392\t\n393\t    return action\n394\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01VeUJEyruLis7W9KbM4JPyJ","session_id":"4fa831d9-eb3f-4745-b971-234a10cba938","uuid":"164a6a3d-b37c-4a83-bc45-66f0dc180fc9","timestamp":"2026-04-07T21:04:53.267Z"}
