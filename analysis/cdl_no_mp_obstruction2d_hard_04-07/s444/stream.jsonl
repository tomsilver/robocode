theta correction\nTARGET_THETA = -np.pi / 2.0  # desired robot orientation (arm pointing down)\n\n# ── Tolerances ────────────────────────────────────────────────────────────────\nXY_TOL = 0.055         # position tolerance (one max step = 0.05, add margin)\nARM_TOL = 0.012        # arm joint tolerance\nTHETA_TOL = 0.05       # theta tolerance\n\n\ndef _clip(val, lo, hi):\n    return max(lo, min(hi, float(val)))\n\n\ndef _angle_diff(target, current):\n    \"\"\"Signed angular difference in [-pi, pi].\"\"\"\n    diff = target - current\n    while diff > np.pi:\n        diff -= 2.0 * np.pi\n    while diff < -np.pi:\n        diff += 2.0 * np.pi\n    return diff\n\n\ndef move_action(rx, ry, rtheta, arm_joint, target_x, target_y, target_arm, vac):\n    \"\"\"Return a 5-element action to move robot toward target state.\"\"\"\n    dx = _clip((target_x - rx) * XY_GAIN, -DX_MAX, DX_MAX)\n    dy = _clip((target_y - ry) * XY_GAIN, -DY_MAX, DY_MAX)\n    dtheta = _clip(_angle_diff(TARGET_THETA, rtheta) * THETA_GAIN, -DTHETA_MAX, DTHETA_MAX)\n    darm = _clip((target_arm - arm_joint) * ARM_GAIN, -DARM_MAX, DARM_MAX)\n    return np.array([dx, dy, dtheta, darm, float(vac)], dtype=np.float64)\n\n\ndef compute_pick_height(obj_height):\n    \"\"\"Robot y needed so arm at ARM_MAX puts suction at object vertical center.\n\n    With arm_joint = ARM_MAX and theta = -pi/2:\n        suction_cy = robot_y - ARM_MAX - SUCTION_OFFSET = TABLE_TOP + obj_height/2\n    => robot_y = TABLE_TOP + obj_height/2 + ARM_MAX + SUCTION_OFFSET\n    \"\"\"\n    return TABLE_TOP_Y + obj_height / 2.0 + ARM_MAX + SUCTION_OFFSET\n\n\ndef at_position(rx, ry, target_x, target_y, tol=None):\n    \"\"\"True if robot is within tolerance of target (x, y).\"\"\"\n    if tol is None:\n        tol = XY_TOL\n    return abs(rx - target_x) <= tol and abs(ry - target_y) <= tol\n\n\ndef at_arm(arm_joint, target_arm, tol=None):\n    \"\"\"True if arm is within tolerance of target extension.\"\"\"\n    if tol is None:\n        tol = ARM_TOL\n    return abs(arm_joint - target_arm) <= tol\n\n\ndef at_theta(rtheta, tol=None):\n    \"\"\"True if robot theta is close to TARGET_THETA.\"\"\"\n    if tol is None:\n        tol = THETA_TOL\n    return abs(_angle_diff(TARGET_THETA, rtheta)) <= tol\n","structuredPatch":[{"oldStart":21,"oldLines":6,"newStart":21,"newLines":16,"lines":[" SUCTION_HALF_X = 0.035   # half-extent of suction zone in x when theta=-pi/2 (= gripper_height/2)"," SUCTION_HALF_Y = 0.005   # half-extent of suction zone in y when theta=-pi/2 (= suction_width/2)"," ","+# ── Arm approach gap ─────────────────────────────────────────────────────────","+# When approaching from above, arm body bottom must clear the object top.","+# APPROACH_GAP: minimum clearance between arm body bottom and object top.","+# Gripper half-height (in y when theta=-pi/2) = GRIPPER_WIDTH/2 = 0.005","+# So arm body bottom = gripper_center_y - GRIPPER_WIDTH/2; we want this > obj_top","+# Setting arm_joint_target = robot_y - obj_top - APPROACH_GAP ensures:","+#   gripper_center_y = robot_y - arm_joint_target = obj_top + APPROACH_GAP","+#   gripper bottom = obj_top + APPROACH_GAP - GRIPPER_WIDTH/2 = obj_top + 0.008 - 0.005 = obj_top + 0.003 > obj_top ✓","+APPROACH_GAP = 0.008     # clearance: arm_joint_target = robot_y - obj_top - APPROACH_GAP","+"," # ── World / table constants ───────────────────────────────────────────────────"," TABLE_TOP_Y = 0.10       # y-coordinate of table surface (objects rest here)"," CARRY_HEIGHT = 0.72      # robot y when carrying objects (clear of all table obstructions)"]}],"userModified":false,"replaceAll":false}}
