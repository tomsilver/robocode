X of target_cx, ensure","+    suction at ARM_MIN is above that object's top.","+    pick_y >= neighbor_top + ARM_MIN + SUCTION_OFFSET + margin","+    Also applies the standard formula: TABLE_TOP + target_h/2 + ARM_MAX + SUCTION_OFFSET.","+    \"\"\"","+    from act_helpers import ARM_MIN, ARM_MAX, SUCTION_OFFSET, SUCTION_HALF_X, TABLE_TOP_Y","+    MARGIN = 0.01","+","+    base_pick_y = TABLE_TOP_Y + target_h / 2.0 + ARM_MAX + SUCTION_OFFSET","+","+    # Check all objects' tops that x-overlap target_cx ± SUCTION_HALF_X","+    check_range = (target_cx - SUCTION_HALF_X, target_cx + SUCTION_HALF_X)","+    max_pick_y = base_pick_y","+","+    for i in range(NUM_OBSTRUCTIONS):","+        if i == exclude_idx:","+            continue","+        ob = extract_obstruction(obs, i)","+        # Check x-overlap","+        if ob[\"x\"] < check_range[1] and ob[\"x\"] + ob[\"width\"] > check_range[0]:","+            ob_top = ob[\"y\"] + ob[\"height\"]","+            safe_y = ob_top + ARM_MIN + SUCTION_OFFSET + MARGIN","+            if safe_y > max_pick_y:","+                max_pick_y = safe_y","+","+    block = extract_block(obs)","+    if block[\"x\"] < check_range[1] and block[\"x\"] + block[\"width\"] > check_range[0]:","+        block_top = block[\"y\"] + block[\"height\"]","+        safe_y = block_top + ARM_MIN + SUCTION_OFFSET + MARGIN","+        if safe_y > max_pick_y:","+            max_pick_y = safe_y","+","+    return float(max_pick_y)","+","+"," def find_clear_dump_x(obs, carried_obs_idx, carried_w):","     \"\"\"Find a dump x-position clear of all other objects."," "]}],"userModified":false,"replaceAll":false}}
