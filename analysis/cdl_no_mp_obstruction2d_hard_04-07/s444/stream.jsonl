BS_OFF_WIDTH = 8\nOBS_OFF_HEIGHT = 9\n\n# ── Geometric constants ───────────────────────────────────────────────────────\nTABLE_TOP_Y = 0.1          # y-coordinate of table top surface\nWORLD_WIDTH = 1.618        # approximate world x extent\nIS_ON_TOL = 0.025          # tolerance used in is_on predicate\nVACUUM_THRESHOLD = 0.5     # vacuum ≥ this means \"on\"\nSURFACE_OVERLAP_MARGIN = 0.0  # zero margin: any x-overlap counts as \"on surface\"\n\n\ndef extract_robot(obs):\n    \"\"\"Return dict with robot features.\"\"\"\n    return {\n        \"x\": float(obs[ROBOT_X]),\n        \"y\": float(obs[ROBOT_Y]),\n        \"theta\": float(obs[ROBOT_THETA]),\n        \"base_radius\": float(obs[ROBOT_BASE_RADIUS]),\n        \"arm_joint\": float(obs[ROBOT_ARM_JOINT]),\n        \"arm_length\": float(obs[ROBOT_ARM_LENGTH]),\n        \"vacuum\": float(obs[ROBOT_VACUUM]),\n        \"gripper_height\": float(obs[ROBOT_GRIPPER_HEIGHT]),\n        \"gripper_width\": float(obs[ROBOT_GRIPPER_WIDTH]),\n    }\n\n\ndef extract_surface(obs):\n    \"\"\"Return dict with target surface features (bottom-left origin).\"\"\"\n    return {\n        \"x\": float(obs[SURF_X]),\n        \"y\": float(obs[SURF_Y]),\n        \"width\": float(obs[SURF_WIDTH]),\n        \"height\": float(obs[SURF_HEIGHT]),\n    }\n\n\ndef extract_block(obs):\n    \"\"\"Return dict with target block features (bottom-left origin).\"\"\"\n    return {\n        \"x\": float(obs[BLOCK_X]),\n        \"y\": float(obs[BLOCK_Y]),\n        \"width\": float(obs[BLOCK_WIDTH]),\n        \"height\": float(obs[BLOCK_HEIGHT]),\n    }\n\n\ndef extract_obstruction(obs, i):\n    \"\"\"Return dict with obstruction i features (bottom-left origin).\"\"\"\n    b = OBS_BASE_INDICES[i]\n    return {\n        \"x\": float(obs[b + OBS_OFF_X]),\n        \"y\": float(obs[b + OBS_OFF_Y]),\n        \"width\": float(obs[b + OBS_OFF_WIDTH]),\n        \"height\": float(obs[b + OBS_OFF_HEIGHT]),\n    }\n\n\ndef rect_center_x(rect):\n    \"\"\"x-coordinate of rectangle center.\"\"\"\n    return rect[\"x\"] + rect[\"width\"] / 2.0\n\n\ndef rect_center_y(rect):\n    \"\"\"y-coordinate of rectangle center.\"\"\"\n    return rect[\"y\"] + rect[\"height\"] / 2.0\n\n\ndef rects_overlap_x(r1, r2, margin=0.0):\n    \"\"\"True if two rectangles overlap in the x dimension.\"\"\"\n    return (r1[\"x\"] < r2[\"x\"] + r2[\"width\"] - margin and\n            r1[\"x\"] + r1[\"width\"] > r2[\"x\"] + margin)\n\n\ndef obstruction_on_surface(obs, i):\n    \"\"\"True if obstruction i's x-range overlaps target surface x-range.\"\"\"\n    surf = extract_surface(obs)\n    ob = extract_obstruction(obs, i)\n    return rects_overlap_x(ob, surf, margin=SURFACE_OVERLAP_MARGIN)\n\n\ndef any_obstruction_on_surface(obs):\n    \"\"\"True if any obstruction overlaps the target surface.\"\"\"\n    return any(obstruction_on_surface(obs, i) for i in range(NUM_OBSTRUCTIONS))\n\n\ndef is_vacuum_on(obs):\n    \"\"\"True if robot vacuum is on.\"\"\"\n    return float(obs[ROBOT_VACUUM]) >= VACUUM_THRESHOLD\n\n\ndef is_block_held(obs):\n    \"\"\"Heuristic: block is held if vacuum is on and block y is above TABLE_TOP.\"\"\"\n    robot = extract_robot(obs)\n    block = extract_block(obs)\n    return robot[\"vacuum\"] >= VACUUM_THRESHOLD and block[\"y\"] > TABLE_TOP_Y + 0.04\n\n\ndef block_is_on_surface(obs):\n    \"\"\"Check is_on condition: block bottom vertices inside surface (with tolerance).\"\"\"\n    surf = extract_surface(obs)\n    block = extract_block(obs)\n    # Bottom-left and bottom-right vertices of block\n    bx_left = block[\"x\"]\n    bx_right = block[\"x\"] + block[\"width\"]\n    by = block[\"y\"]\n    offset_y = by - IS_ON_TOL\n\n    sx, sw, sy, sh = surf[\"x\"], surf[\"width\"], surf[\"y\"], surf[\"height\"]\n    def surf_contains(px, py):\n        return sx <= px <= sx + sw and sy <= py <= sy + sh\n\n    return surf_contains(bx_left, offset_y) and surf_contains(bx_right, offset_y)\n\n\ndef compute_safe_pick_y(obs, target_cx, target_h, exclude_idx=None):\n    \"\"\"Compute pick_y that clears all nearby objects at arm=ARM_MIN.\n\n    For any object within SUCTION_HALF_X of target_cx, ensure\n    suction at ARM_MIN is above that object's top.\n    pick_y >= neighbor_top + ARM_MIN + SUCTION_OFFSET + margin\n    Also applies the standard formula: TABLE_TOP + target_h/2 + ARM_MAX + SUCTION_OFFSET.\n    \"\"\"\n    from act_helpers import ARM_MIN, ARM_MAX, SUCTION_OFFSET, SUCTION_HALF_X, TABLE_TOP_Y\n    MARGIN = 0.01\n\n    base_pick_y = TABLE_TOP_Y + target_h / 2.0 + ARM_MAX + SUCTION_OFFSET\n\n    # Check all objects' tops that x-overlap target_cx ± SUCTION_HALF_X\n    check_range = (target_cx - SUCTION_HALF_X, target_cx + SUCTION_HALF_X)\n    max_pick_y = base_pick_y\n\n    for i in range(NUM_OBSTRUCTIONS):\n        if i == exclude_idx:\n            continue\n        ob = extract_obstruction(obs, i)\n        # Check x-overlap\n        if ob[\"x\"] < check_range[1] and ob[\"x\"] + ob[\"width\"] > check_range[0]:\n            ob_top = ob[\"y\"] + ob[\"height\"]\n            safe_y = ob_top + ARM_MIN + SUCTION_OFFSET + MARGIN\n            if safe_y > max_pick_y:\n                max_pick_y = safe_y\n\n    block = extract_block(obs)\n    if block[\"x\"] < check_range[1] and block[\"x\"] + block[\"width\"] > check_range[0]:\n        block_top = block[\"y\"] + block[\"height\"]\n        safe_y = block_top + ARM_MIN + SUCTION_OFFSET + MARGIN\n        if safe_y > max_pick_y:\n            max_pick_y = safe_y\n\n    return float(max_pick_y)\n\n\nROBOT_RADIUS = 0.100   # robot base radius (circle)\n\n\ndef find_blocker_for(obs, target_idx):\n    \"\"\"Find a non-surface obstruction that prevents robot from descending to pick_y.\n\n    Uses circle-rect collision: a non-surface obs blocks if the robot circle\n    centered at (target_cx, pick_y) would overlap that obs at any point during\n    vertical descent from CARRY_HEIGHT to pick_y.\n\n    Returns the index of the tallest such blocker, or None.\n    \"\"\"\n    from act_helpers import TABLE_TOP_Y\n    ob_target = extract_obstruction(obs, target_idx)\n    target_cx = rect_center_x(ob_target)\n    pick_y = compute_safe_pick_y(obs, target_cx, ob_target[\"height\"], exclude_idx=target_idx)\n\n    best_blocker = None\n    best_top = -1.0\n    for i in range(NUM_OBSTRUCTIONS):\n        if i == target_idx:\n            continue\n        if obstruction_on_surface(obs, i):\n            continue  # surface obstructions handled by normal FIND loop\n        ob = extract_obstruction(obs, i)\n        ob_top = ob[\"y\"] + ob[\"height\"]\n        # Horizontal distance from target_cx to nearest x-edge of ob\n        dx = max(0.0, max(ob[\"x\"] - target_cx, target_cx - (ob[\"x\"] + ob[\"width\"])))\n        if dx >= ROBOT_RADIUS:\n            continue  # too far horizontally, no circle collision possible\n        # Minimum robot_y where circle just touches ob top-edge: ob_top + sqrt(R^2 - dx^2)\n        min_robot_y = ob_top + (ROBOT_RADIUS**2 - dx**2) ** 0.5\n        if min_robot_y > pick_y:\n            # Robot would collide with ob before reaching pick_y\n            if ob_top > best_top:\n                best_top = ob_top\n                best_blocker = i\n    return best_blocker\n\n\ndef get_floor_height_at(obs, dump_x, carried_idx, carried_half_w):\n    \"\"\"Return top height of highest object the carried obj would land on at dump_x.\n\n    Checks all non-carried obstructions for x-overlap with the carried object\n    footprint [dump_x - carried_half_w, dump_x + carried_half_w].\n    Returns TABLE_TOP_Y if none overlap.\n    \"\"\"\n    check_lo = dump_x - carried_half_w\n    check_hi = dump_x + carried_half_w\n    max_top = TABLE_TOP_Y\n    for i in range(NUM_OBSTRUCTIONS):\n        if i == carried_idx:\n            continue\n        ob = extract_obstruction(obs, i)\n        if ob[\"x\"] < check_hi and ob[\"x\"] + ob[\"width\"] > check_lo:\n            ob_top = ob[\"y\"] + ob[\"height\"]\n            if ob_top > max_top:\n                max_top = ob_top\n    return float(max_top)\n\n\ndef find_safe_pick_x(obs, ob, pick_y, exclude_idx=None):\n    \"\"\"Find a robot x for picking ob that avoids circle-rect collision during descent.\n\n    Tries center of ob first, then shifts left/right while suction still overlaps ob.\n    Checks all obstructions (except target) + block for robot-circle collision.\n    Returns safe robot_x (falls back to center if nothing better found).\n    \"\"\"\n    from act_helpers import SUCTION_HALF_X\n    ob_cx = rect_center_x(ob)\n    # Suction overlaps ob when: rx - SUCTION_HALF_X < ob_right AND rx + SUCTION_HALF_X > ob_left\n    rx_min = ob[\"x\"] - SUCTION_HALF_X + 0.002\n    rx_max = ob[\"x\"] + ob[\"width\"] + SUCTION_HALF_X - 0.002\n\n    # Collect blockers: other obstructions + block\n    blockers = []\n    for i in range(NUM_OBSTRUCTIONS):\n        if i == exclude_idx:\n            continue\n        blockers.append(extract_obstruction(obs, i))\n    blockers.append(extract_block(obs))\n\n    def is_safe(rx):\n        for b in blockers:\n            b_top = b[\"y\"] + b[\"height\"]\n            dx = max(0.0, max(b[\"x\"] - rx, rx - (b[\"x\"] + b[\"width\"])))\n            if dx >= ROBOT_RADIUS:\n                continue\n            min_robot_y = b_top + (ROBOT_RADIUS ** 2 - dx ** 2) ** 0.5\n            if min_robot_y > pick_y:\n                return False\n        return True\n\n    if is_safe(ob_cx):\n        return ob_cx\n\n    STEP = 0.010\n    max_delta = (rx_max - rx_min) / 2.0 + STEP\n    steps = int(max_delta / STEP) + 2\n    for i in range(1, steps):\n        delta = i * STEP\n        for sign in (-1, 1):\n            rx = ob_cx + sign * delta\n            if rx_min <= rx <= rx_max and is_safe(rx):\n                return rx\n\n    return ob_cx  # fallback\n\n\ndef find_clear_dump_x(obs, carried_obs_idx, carried_w):\n    \"\"\"Find a dump x-position clear of all other objects.\n\n    Ensures robot base (radius=0.1) and carried obstruction (width=carried_w)\n    centered at dump_x do not overlap any other object's x-range.\n\n    Searches left side first, then right side, starting from edges.\n    Returns the best (farthest from surface) valid dump_x.\n    \"\"\"\n    import numpy as np\n\n    ROBOT_RADIUS = 0.1\n    WORLD_MIN_X = 0.12\n    WORLD_MAX_X = WORLD_WIDTH - 0.12\n    MARGIN = 0.015  # extra clearance\n\n    # Half-width of exclusion zone around dump_x\n    excl_hw = max(ROBOT_RADIUS, carried_w / 2.0) + MARGIN\n\n    # Collect all other objects' x-ranges to avoid\n    other_ranges = []\n    surf = extract_surface(obs)\n    other_ranges.append((surf[\"x\"], surf[\"x\"] + surf[\"width\"]))  # avoid surface too\n\n    block = extract_block(obs)\n    other_ranges.append((block[\"x\"], block[\"x\"] + block[\"width\"]))\n\n    for i in range(NUM_OBSTRUCTIONS):\n        if i != carried_obs_idx:\n            ob = extract_obstruction(obs, i)\n            other_ranges.append((ob[\"x\"], ob[\"x\"] + ob[\"width\"]))\n\n    # Build blocked intervals for dump_x:\n    # dump_x is blocked if it's within excl_hw of any other object\n    blocked = [(ox - excl_hw, ox_r + excl_hw) for ox, ox_r in other_ranges]\n\n    def is_clear(x):\n        return WORLD_MIN_X <= x <= WORLD_MAX_X and all(\n            not (lo <= x <= hi) for lo, hi in blocked\n        )\n\n    # Prefer side farther from surface center\n    surf_cx = surf[\"x\"] + surf[\"width\"] / 2.0\n    STEP = 0.04\n\n    # Search right side (high x) then left side\n    candidates = []\n    for x in np.arange(WORLD_MAX_X, WORLD_MIN_X - STEP, -STEP):\n        if is_clear(x):\n            candidates.append(x)\n            break\n    for x in np.arange(WORLD_MIN_X, WORLD_MAX_X + STEP, STEP):\n        if is_clear(x):\n            candidates.append(x)\n            break\n\n    if not candidates:\n        # Fallback: try denser search\n        for x in np.arange(WORLD_MIN_X, WORLD_MAX_X, 0.01):\n            if is_clear(x):\n                return float(x)\n        # Stacking fallback: find best non-block, non-carried obstruction to stack on.\n        # Stack at center of obs with lowest top, checking other obs don't block descent.\n        best_stack_x = None\n        best_stack_top = float('inf')\n        for i in range(NUM_OBSTRUCTIONS):\n            if i == carried_obs_idx:\n                continue\n            ob_i = extract_obstruction(obs, i)\n            stack_x = ob_i[\"x\"] + ob_i[\"width\"] / 2.0\n            stack_top = ob_i[\"y\"] + ob_i[\"height\"]\n            # Ensure other obstructions (not i, not carried) don't block descent here.\n            # Approximate: use ARM_MAX + SUCTION_OFFSET above stack as pick height.\n            approx_pick_y = stack_top + ARM_MAX + SUCTION_OFFSET + 0.10\n            can_reach = True\n            for j in range(NUM_OBSTRUCTIONS):\n                if j == carried_obs_idx or j == i:\n                    continue\n                ob_j = extract_obstruction(obs, j)\n                dx_j = max(0.0, max(ob_j[\"x\"] - stack_x, stack_x - (ob_j[\"x\"] + ob_j[\"width\"])))\n                if dx_j >= ROBOT_RADIUS:\n                    continue\n                min_ry = ob_j[\"y\"] + ob_j[\"height\"] + (ROBOT_RADIUS ** 2 - dx_j ** 2) ** 0.5\n                if min_ry > approx_pick_y:\n                    can_reach = False\n                    break\n            if can_reach and stack_top < best_stack_top:\n                best_stack_top = stack_top\n                best_stack_x = stack_x\n        if best_stack_x is not None:\n            return float(best_stack_x)\n        return float(WORLD_WIDTH / 2.0)  # last resort\n\n    # Pick the one farthest from surface\n    return float(max(candidates, key=lambda x: abs(x - surf_cx)))\n","structuredPatch":[{"oldStart":317,"oldLines":6,"newStart":317,"newLines":7,"lines":["     Returns the best (farthest from surface) valid dump_x.","     \"\"\"","     import numpy as np","+    from act_helpers import ARM_MAX, SUCTION_OFFSET"," ","     ROBOT_RADIUS = 0.1","     WORLD_MIN_X = 0.12"]}],"userModified":false,"replaceAll":false}}
