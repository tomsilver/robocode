re arm_target from PickBlock (robot's current arm_joint)","+        self._arm_target = robot[\"arm_joint\"]","         self._block_height = block[\"height\"]","-        # Record where robot was (the grasp position)","-        robot = extract_robot(obs)","-        self._grasp_rx = robot[\"x\"]","-        self._grasp_ry = robot[\"y\"]"," ","     def initializable(self, obs):","         return is_vacuum_on(obs)"]},{"oldStart":218,"oldLines":16,"newStart":220,"newLines":13,"lines":["             robot[\"x\"], robot[\"y\"], robot[\"theta\"], robot[\"arm_joint\"]","         )","         surf = extract_surface(obs)","-        block = extract_block(obs)"," ","-        # Target: block center x at surface center x","-        surf_cx = rect_center_x(surf)","-        place_robot_x = surf_cx","-","-        # pick_y uses block height (same formula as pick, ensures block lands at TABLE_TOP)","+        # Target: robot x at surface center x","+        place_robot_x = rect_center_x(surf)","+        # pick_y uses block height (same formula as pick)","         pick_y = compute_pick_height(self._block_height)"," ","-        # ── LIFT: retract arm (block rises up) ────────────────────────────────","+        # ── LIFT: retract arm (block rises) ───────────────────────────────────","         if self.phase == _LIFT:","             if at_arm(arm_joint, ARM_MIN):","                 self.phase = _RAISE"]},{"oldStart":239,"oldLines":27,"newStart":238,"newLines":26,"lines":["                 self.phase = _CARRY","             return move_action(rx, ry, rtheta, arm_joint, rx, CARRY_HEIGHT, ARM_MIN, VAC_ON)"," ","-        # ── CARRY: move horizontally to above surface center ─────────────────","+        # ── CARRY: move horizontally to above surface center ──────────────────","         elif self.phase == _CARRY:","             if abs(rx - place_robot_x) <= CARRY_X_TOL:","                 self.phase = _DESCEND","             return move_action(rx, ry, rtheta, arm_joint, place_robot_x, CARRY_HEIGHT, ARM_MIN, VAC_ON)"," ","-        # ── DESCEND: lower robot to pick_y ────────────────────────────────────","+        # ── DESCEND: lower robot to pick_y ─────────────────────────────────────","         elif self.phase == _DESCEND:","             if at_position(rx, ry, place_robot_x, pick_y):","                 self.phase = _LOWER","             return move_action(rx, ry, rtheta, arm_joint, place_robot_x, pick_y, ARM_MIN, VAC_ON)"," ","-        # ── LOWER: extend arm (lowers block to TABLE_TOP) ────────────────────","+        # ── LOWER: extend arm to arm_target (lowers block to TABLE_TOP) ───────","         elif self.phase == _LOWER:","-            if at_arm(arm_joint, ARM_MAX) and at_position(rx, ry, place_robot_x, pick_y):","+            if at_arm(arm_joint, self._arm_target) and at_position(rx, ry, place_robot_x, pick_y):","                 self.phase = _RELEASE","-            return move_action(rx, ry, rtheta, arm_joint, place_robot_x, pick_y, ARM_MAX, VAC_ON)","+            return move_action(rx, ry, rtheta, arm_joint, place_robot_x, pick_y, self._arm_target, VAC_ON)"," ","         # ── RELEASE: turn off vacuum ──────────────────────────────────────────","         elif self.phase == _RELEASE:","-            self._release_steps += 1","-            return move_action(rx, ry, rtheta, arm_joint, place_robot_x, pick_y, ARM_MAX, VAC_OFF)","+            return move_action(rx, ry, rtheta, arm_joint, place_robot_x, pick_y, self._arm_target, VAC_OFF)"," ","         return np.zeros(5, dtype=np.float64)"]}],"originalFile":"\"\"\"Behavior classes for Obstruction2D-o4-v0.\"\"\"\n\nimport numpy as np\nfrom behavior import Behavior\nfrom obs_helpers import (\n    extract_robot, extract_surface, extract_block, extract_obstruction,\n    rect_center_x, rect_center_y,\n    obstruction_on_surface, any_obstruction_on_surface,\n    is_vacuum_on, is_block_held, block_is_on_surface,\n    compute_dump_x, NUM_OBSTRUCTIONS, TABLE_TOP_Y,\n)\nfrom act_helpers import (\n    move_action, compute_pick_height,\n    at_position, at_arm,\n    ARM_MIN, ARM_MAX, CARRY_HEIGHT,\n    VAC_OFF, VAC_ON, DX_MAX, DY_MAX, DARM_MAX,\n)\n\n# ── Phase names ───────────────────────────────────────────────────────────────\n_RETRACT = \"RETRACT\"\n_MOVE = \"MOVE\"\n_EXTEND = \"EXTEND\"\n_GRASP = \"GRASP\"\n_LIFT = \"LIFT\"\n_RAISE = \"RAISE\"\n_CARRY = \"CARRY\"\n_DESCEND = \"DESCEND\"\n_LOWER = \"LOWER\"\n_RELEASE = \"RELEASE\"\n_FIND = \"FIND\"\n_DONE = \"DONE\"\n\n# ── How many steps to hold vacuum before assuming grasp succeeded ─────────────\nGRASP_HOLD_STEPS = 5\n# How close to target x before we attempt descent\nCARRY_X_TOL = 0.025\n\n\nclass ClearSurface(Behavior):\n    \"\"\"Pick up each obstruction overlapping the target surface and dump it elsewhere.\"\"\"\n\n    def reset(self, obs):\n        self.phase = _FIND\n        self.current_obs_idx = None\n        self.dump_count = 0\n        self._grasp_steps = 0\n        # Recompute dump_x at reset\n        self._base_obs = obs.copy()\n\n    def initializable(self, obs):\n        return True  # can always start from reset\n\n    def terminated(self, obs):\n        return not any_obstruction_on_surface(obs)\n\n    def step(self, obs):\n        robot = extract_robot(obs)\n        rx, ry, rtheta, arm_joint = (\n            robot[\"x\"], robot[\"y\"], robot[\"theta\"], robot[\"arm_joint\"]\n        )\n\n        # ── FIND: locate next obstruction on surface ──────────────────────────\n        if self.phase == _FIND:\n            self.current_obs_idx = None\n            for i in range(NUM_OBSTRUCTIONS):\n                if obstruction_on_surface(obs, i):\n                    self.current_obs_idx = i\n                    self.phase = _RETRACT\n                    self._grasp_steps = 0\n                    break\n            # No obstruction found → terminated, return idle\n            return move_action(rx, ry, rtheta, arm_joint, rx, ry, arm_joint, VAC_OFF)\n\n        ob = extract_obstruction(obs, self.current_obs_idx)\n        ob_cx = rect_center_x(ob)\n        pick_y = compute_pick_height(ob[\"height\"])\n        dump_x = compute_dump_x(self._base_obs, self.dump_count)\n\n        # ── RETRACT: pull arm in before moving ────────────────────────────────\n        if self.phase == _RETRACT:\n            if at_arm(arm_joint, ARM_MIN):\n                self.phase = _MOVE\n            return move_action(rx, ry, rtheta, arm_joint, rx, ry, ARM_MIN, VAC_OFF)\n\n        # ── MOVE: position robot above target (high, arm retracted) ──────────\n        elif self.phase == _MOVE:\n            if at_position(rx, ry, ob_cx, pick_y):\n                self.phase = _EXTEND\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, pick_y, ARM_MIN, VAC_OFF)\n\n        # ── EXTEND: lower arm to reach object ────────────────────────────────\n        elif self.phase == _EXTEND:\n            if at_arm(arm_joint, ARM_MAX) and at_position(rx, ry, ob_cx, pick_y):\n                self.phase = _GRASP\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, pick_y, ARM_MAX, VAC_OFF)\n\n        # ── GRASP: activate vacuum for several steps ──────────────────────────\n        elif self.phase == _GRASP:\n            self._grasp_steps += 1\n            if self._grasp_steps >= GRASP_HOLD_STEPS:\n                self.phase = _LIFT\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, pick_y, ARM_MAX, VAC_ON)\n\n        # ── LIFT: retract arm (lifts object) ─────────────────────────────────\n        elif self.phase == _LIFT:\n            if at_arm(arm_joint, ARM_MIN):\n                self.phase = _RAISE\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, pick_y, ARM_MIN, VAC_ON)\n\n        # ── RAISE: move robot up to carry height ──────────────────────────────\n        elif self.phase == _RAISE:\n            if at_position(rx, ry, ob_cx, CARRY_HEIGHT):\n                self.phase = _CARRY\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, CARRY_HEIGHT, ARM_MIN, VAC_ON)\n\n        # ── CARRY: move horizontally to dump zone ─────────────────────────────\n        elif self.phase == _CARRY:\n            if abs(rx - dump_x) <= CARRY_X_TOL:\n                self.phase = _DESCEND\n            return move_action(rx, ry, rtheta, arm_joint, dump_x, CARRY_HEIGHT, ARM_MIN, VAC_ON)\n\n        # ── DESCEND: lower robot to pick_y at dump location ──────────────────\n        elif self.phase == _DESCEND:\n            dump_pick_y = compute_pick_height(ob[\"height\"])\n            if at_position(rx, ry, dump_x, dump_pick_y):\n                self.phase = _LOWER\n            return move_action(rx, ry, rtheta, arm_joint, dump_x, dump_pick_y, ARM_MIN, VAC_ON)\n\n        # ── LOWER: extend arm (lowers object to table level) ─────────────────\n        elif self.phase == _LOWER:\n            dump_pick_y = compute_pick_height(ob[\"height\"])\n            if at_arm(arm_joint, ARM_MAX):\n                self.phase = _RELEASE\n            return move_action(rx, ry, rtheta, arm_joint, dump_x, dump_pick_y, ARM_MAX, VAC_ON)\n\n        # ── RELEASE: turn off vacuum ──────────────────────────────────────────\n        elif self.phase == _RELEASE:\n            dump_pick_y = compute_pick_height(ob[\"height\"])\n            self.dump_count += 1\n            self.phase = _FIND\n            return move_action(rx, ry, rtheta, arm_joint, dump_x, dump_pick_y, ARM_MAX, VAC_OFF)\n\n        # Fallback\n        return np.zeros(5, dtype=np.float64)\n\n\nclass PickBlock(Behavior):\n    \"\"\"Position robot over target block, extend arm, and activate vacuum.\"\"\"\n\n    def reset(self, obs):\n        self.phase = _RETRACT\n        self._grasp_steps = 0\n\n    def initializable(self, obs):\n        return not any_obstruction_on_surface(obs)\n\n    def terminated(self, obs):\n        return is_vacuum_on(obs)\n\n    def step(self, obs):\n        robot = extract_robot(obs)\n        rx, ry, rtheta, arm_joint = (\n            robot[\"x\"], robot[\"y\"], robot[\"theta\"], robot[\"arm_joint\"]\n        )\n        block = extract_block(obs)\n        block_cx = rect_center_x(block)\n        pick_y = compute_pick_height(block[\"height\"])\n\n        # ── RETRACT ───────────────────────────────────────────────────────────\n        if self.phase == _RETRACT:\n            if at_arm(arm_joint, ARM_MIN):\n                self.phase = _MOVE\n            return move_action(rx, ry, rtheta, arm_joint, rx, ry, ARM_MIN, VAC_OFF)\n\n        # ── MOVE ──────────────────────────────────────────────────────────────\n        elif self.phase == _MOVE:\n            if at_position(rx, ry, block_cx, pick_y):\n                self.phase = _EXTEND\n            return move_action(rx, ry, rtheta, arm_joint, block_cx, pick_y, ARM_MIN, VAC_OFF)\n\n        # ── EXTEND ────────────────────────────────────────────────────────────\n        elif self.phase == _EXTEND:\n            if at_arm(arm_joint, ARM_MAX) and at_position(rx, ry, block_cx, pick_y):\n                self.phase = _GRASP\n            return move_action(rx, ry, rtheta, arm_joint, block_cx, pick_y, ARM_MAX, VAC_OFF)\n\n        # ── GRASP: hold vacuum for several steps ──────────────────────────────\n        elif self.phase == _GRASP:\n            self._grasp_steps += 1\n            return move_action(rx, ry, rtheta, arm_joint, block_cx, pick_y, ARM_MAX, VAC_ON)\n\n        return np.zeros(5, dtype=np.float64)\n\n\nclass PlaceBlock(Behavior):\n    \"\"\"Carry target block to surface center and release vacuum.\"\"\"\n\n    def reset(self, obs):\n        self.phase = _LIFT\n        self._release_steps = 0\n        # Record block height for pick_y computation (doesn't change)\n        block = extract_block(obs)\n        self._block_height = block[\"height\"]\n        # Record where robot was (the grasp position)\n        robot = extract_robot(obs)\n        self._grasp_rx = robot[\"x\"]\n        self._grasp_ry = robot[\"y\"]\n\n    def initializable(self, obs):\n        return is_vacuum_on(obs)\n\n    def terminated(self, obs):\n        return block_is_on_surface(obs)\n\n    def step(self, obs):\n        robot = extract_robot(obs)\n        rx, ry, rtheta, arm_joint = (\n            robot[\"x\"], robot[\"y\"], robot[\"theta\"], robot[\"arm_joint\"]\n        )\n        surf = extract_surface(obs)\n        block = extract_block(obs)\n\n        # Target: block center x at surface center x\n        surf_cx = rect_center_x(surf)\n        place_robot_x = surf_cx\n\n        # pick_y uses block height (same formula as pick, ensures block lands at TABLE_TOP)\n        pick_y = compute_pick_height(self._block_height)\n\n        # ── LIFT: retract arm (block rises up) ────────────────────────────────\n        if self.phase == _LIFT:\n            if at_arm(arm_joint, ARM_MIN):\n                self.phase = _RAISE\n            return move_action(rx, ry, rtheta, arm_joint, rx, ry, ARM_MIN, VAC_ON)\n\n        # ── RAISE: move robot up to carry height ──────────────────────────────\n        elif self.phase == _RAISE:\n            if at_position(rx, ry, rx, CARRY_HEIGHT):\n                self.phase = _CARRY\n            return move_action(rx, ry, rtheta, arm_joint, rx, CARRY_HEIGHT, ARM_MIN, VAC_ON)\n\n        # ── CARRY: move horizontally to above surface center ─────────────────\n        elif self.phase == _CARRY:\n            if abs(rx - place_robot_x) <= CARRY_X_TOL:\n                self.phase = _DESCEND\n            return move_action(rx, ry, rtheta, arm_joint, place_robot_x, CARRY_HEIGHT, ARM_MIN, VAC_ON)\n\n        # ── DESCEND: lower robot to pick_y ────────────────────────────────────\n        elif self.phase == _DESCEND:\n            if at_position(rx, ry, place_robot_x, pick_y):\n                self.phase = _LOWER\n            return move_action(rx, ry, rtheta, arm_joint, place_robot_x, pick_y, ARM_MIN, VAC_ON)\n\n        # ── LOWER: extend arm (lowers block to TABLE_TOP) ────────────────────\n        elif self.phase == _LOWER:\n            if at_arm(arm_joint, ARM_MAX) and at_position(rx, ry, place_robot_x, pick_y):\n                self.phase = _RELEASE\n            return move_action(rx, ry, rtheta, arm_joint, place_robot_x, pick_y, ARM_MAX, VAC_ON)\n\n        # ── RELEASE: turn off vacuum ──────────────────────────────────────────\n        elif self.phase == _RELEASE:\n            self._release_steps += 1\n            return move_action(rx, ry, rtheta, arm_joint, place_robot_x, pick_y, ARM_MAX, VAC_OFF)\n\n        return np.zeros(5, dtype=np.float64)\n"}}
