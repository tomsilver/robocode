{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DWXjytKcsXzhuTFJphi2A7","type":"tool_result","content":"diff --git a/obs_helpers.py b/obs_helpers.py\nindex 9fc249d..e883c59 100644\n--- a/obs_helpers.py\n+++ b/obs_helpers.py\n@@ -160,28 +160,29 @@ def block_is_on_surface(obs):\n     return surf_contains(bx_left, offset_y) and surf_contains(bx_right, offset_y)\n \n \n+ROBOT_RADIUS = 0.100   # robot base radius\n+\n def compute_safe_pick_y(obs, target_cx, target_h, exclude_idx=None):\n-    \"\"\"Compute pick_y that clears all nearby objects at arm=ARM_MIN.\n+    \"\"\"Compute pick_y that clears all nearby objects for both robot base and arm.\n \n-    For any object within SUCTION_HALF_X of target_cx, ensure\n-    suction at ARM_MIN is above that object's top.\n+    Uses ROBOT_RADIUS for x-range check (wider than arm body) to handle\n+    robot base collision during descent.\n     pick_y >= neighbor_top + ARM_MIN + SUCTION_OFFSET + margin\n     Also applies the standard formula: TABLE_TOP + target_h/2 + ARM_MAX + SUCTION_OFFSET.\n     \"\"\"\n-    from act_helpers import ARM_MIN, ARM_MAX, SUCTION_OFFSET, SUCTION_HALF_X, TABLE_TOP_Y\n+    from act_helpers import ARM_MIN, ARM_MAX, SUCTION_OFFSET, TABLE_TOP_Y\n     MARGIN = 0.01\n \n     base_pick_y = TABLE_TOP_Y + target_h / 2.0 + ARM_MAX + SUCTION_OFFSET\n \n-    # Check all objects' tops that x-overlap target_cx ± SUCTION_HALF_X\n-    check_range = (target_cx - SUCTION_HALF_X, target_cx + SUCTION_HALF_X)\n+    # Use ROBOT_RADIUS for x-range (robot base can collide even if arm body wouldn't)\n+    check_range = (target_cx - ROBOT_RADIUS, target_cx + ROBOT_RADIUS)\n     max_pick_y = base_pick_y\n \n     for i in range(NUM_OBSTRUCTIONS):\n         if i == exclude_idx:\n             continue\n         ob = extract_obstruction(obs, i)\n-        # Check x-overlap\n         if ob[\"x\"] < check_range[1] and ob[\"x\"] + ob[\"width\"] > check_range[0]:\n             ob_top = ob[\"y\"] + ob[\"height\"]\n             safe_y = ob_top + ARM_MIN + SUCTION_OFFSET + MARGIN\n@@ -198,6 +199,58 @@ def compute_safe_pick_y(obs, target_cx, target_h, exclude_idx=None):\n     return float(max_pick_y)\n \n \n+def can_pick_at(obs, target_idx):\n+    \"\"\"Return True if target obstruction can be physically grasped at computed pick_y.\n+\n+    Checks that arm_tgt (at safe pick_y) doesn't fall below ARM_MIN,\n+    i.e., the suction can actually reach inside the target.\n+    \"\"\"\n+    from act_helpers import ARM_MIN, ARM_MAX, SUCTION_OFFSET, SUCTION_HALF_Y, TABLE_TOP_Y, APPROACH_GAP\n+    ob = extract_obstruction(obs, target_idx)\n+    ob_cx = rect_center_x(ob)\n+    pick_y = compute_safe_pick_y(obs, ob_cx, ob[\"height\"], exclude_idx=target_idx)\n+    arm_tgt = ob[\"y\"] + ob[\"height\"] + APPROACH_GAP  # = pick_y - arm_tgt → arm_tgt = pick_y - obj_top - GAP\n+    arm_tgt_val = pick_y - (ob[\"y\"] + ob[\"height\"]) - APPROACH_GAP\n+    # Clamp to [ARM_MIN, ARM_MAX]\n+    arm_tgt_val = max(ARM_MIN, min(ARM_MAX, arm_tgt_val))\n+    # Suction y when arm at arm_tgt_val\n+    suction_y = pick_y - arm_tgt_val - SUCTION_OFFSET\n+    obj_top = ob[\"y\"] + ob[\"height\"]\n+    # Suction must be at or below obj_top + SUCTION_HALF_Y (inside the object)\n+    return suction_y <= obj_top + SUCTION_HALF_Y\n+\n+\n+def find_blocker_for(obs, target_idx):\n+    \"\"\"Find a non-surface obstruction that blocks picking target_idx.\n+\n+    Returns the index of the tallest such blocker, or None if none found.\n+    A blocker is a non-surface obs whose x-range is within ROBOT_RADIUS of\n+    target_cx, and that causes can_pick_at to fail for target_idx.\n+    \"\"\"\n+    if can_pick_at(obs, target_idx):\n+        return None  # target is pickable, no blocker\n+\n+    ob_target = extract_obstruction(obs, target_idx)\n+    target_cx = rect_center_x(ob_target)\n+\n+    best_blocker = None\n+    best_top = -1.0\n+    for i in range(NUM_OBSTRUCTIONS):\n+        if i == target_idx:\n+            continue