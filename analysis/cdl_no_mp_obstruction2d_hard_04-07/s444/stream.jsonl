C_ON)\n196\t\n197\t        # ── LOWER: extend arm (places obstruction at dump floor level) ────────\n198\t        elif self.phase == _LOWER:\n199\t            # Use dump_floor_y + PLACE_SLACK so obs bottom is a few mm above floor.\n200\t            # This avoids floating-point floor-penetration which the env blocks.\n201\t            # The obs falls to dump_floor_y when vacuum is released.\n202\t            _PLACE_SLACK = 0.003\n203\t            dump_arm_tgt = compute_arm_target(dump_pick_y, dump_floor_y + _PLACE_SLACK, ob[\"height\"])\n204\t            if at_arm(arm_joint, dump_arm_tgt):\n205\t                self.phase = _RELEASE\n206\t            return move_action(rx, ry, rtheta, arm_joint, dump_x, dump_pick_y, dump_arm_tgt, VAC_ON)\n207\t\n208\t        # ── RELEASE: turn off vacuum ──────────────────────────────────────────\n209\t        elif self.phase == _RELEASE:\n210\t            _PLACE_SLACK = 0.003\n211\t            dump_arm_tgt = compute_arm_target(dump_pick_y, dump_floor_y + _PLACE_SLACK, ob[\"height\"])\n212\t            self.dump_count += 1\n213\t            self.phase = _FIND\n214\t            self._dump_x = None\n215\t            self._pick_y = None\n216\t            self._pick_x = None\n217\t            self._dump_floor_y = None\n218\t            return move_action(rx, ry, rtheta, arm_joint, dump_x, dump_pick_y, dump_arm_tgt, VAC_OFF)\n219\t\n220\t        return np.zeros(5, dtype=np.float64)\n221\t\n222\t\n223\tclass PickBlock(Behavior):\n224\t    \"\"\"Position robot over target block, extend arm, activate vacuum.\"\"\"\n225\t\n226\t    def reset(self, obs):\n227\t        self.phase = _RETRACT\n228\t        self._grasp_steps = 0\n229\t        self._arm_target = ARM_MIN\n230\t        self._pick_y = None\n231\t        self._pick_x = None\n232\t\n233\t    def initializable(self, obs):\n234\t        return not any_obstruction_on_surface(obs)\n235\t\n236\t    def terminated(self, obs):\n237\t        return is_vacuum_on(obs)\n238\t\n239\t    def step(se