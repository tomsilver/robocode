{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01HSW5Bdq7Bi8MCWLuHJfdan","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01UHUZeBxBTAShDaeuF8GYaW","name":"Write","input":{"file_path":"/sandbox/behaviors.py","content":"\"\"\"Behavior classes for Obstruction2D-o4-v0.\"\"\"\n\nimport numpy as np\nfrom behavior import Behavior\nfrom obs_helpers import (\n    extract_robot, extract_surface, extract_block, extract_obstruction,\n    rect_center_x, rect_center_y,\n    obstruction_on_surface, any_obstruction_on_surface,\n    is_vacuum_on, is_block_held, block_is_on_surface,\n    compute_dump_x, NUM_OBSTRUCTIONS, TABLE_TOP_Y,\n)\nfrom act_helpers import (\n    move_action, compute_pick_height,\n    at_position, at_arm,\n    ARM_MIN, ARM_MAX, CARRY_HEIGHT,\n    VAC_OFF, VAC_ON, DX_MAX, DY_MAX, DARM_MAX,\n)\n\n# ── Phase names ───────────────────────────────────────────────────────────────\n_RETRACT = \"RETRACT\"\n_MOVE = \"MOVE\"\n_EXTEND = \"EXTEND\"\n_GRASP = \"GRASP\"\n_LIFT = \"LIFT\"\n_RAISE = \"RAISE\"\n_CARRY = \"CARRY\"\n_DESCEND = \"DESCEND\"\n_LOWER = \"LOWER\"\n_RELEASE = \"RELEASE\"\n_FIND = \"FIND\"\n_DONE = \"DONE\"\n\n# ── How many steps to hold vacuum before assuming grasp succeeded ─────────────\nGRASP_HOLD_STEPS = 5\n# How close to target x before we attempt descent\nCARRY_X_TOL = 0.025\n\n\nclass ClearSurface(Behavior):\n    \"\"\"Pick up each obstruction overlapping the target surface and dump it elsewhere.\"\"\"\n\n    def reset(self, obs):\n        self.phase = _FIND\n        self.current_obs_idx = None\n        self.dump_count = 0\n        self._grasp_steps = 0\n        # Recompute dump_x at reset\n        self._base_obs = obs.copy()\n\n    def initializable(self, obs):\n        return True  # can always start from reset\n\n    def terminated(self, obs):\n        return not any_obstruction_on_surface(obs)\n\n    def step(self, obs):\n        robot = extract_robot(obs)\n        rx, ry, rtheta, arm_joint = (\n            robot[\"x\"], robot[\"y\"], robot[\"theta\"], robot[\"arm_joint\"]\n        )\n\n        # ── FIND: locate next obstruction on surface ──────────────────────────\n        if self.phase == _FIND:\n            self.current_obs_idx = None\n            for i in range(NUM_OBSTRUCTIONS):\n                if obstruction_on_surface(obs, i):\n                    self.current_obs_idx = i\n                    self.phase = _RETRACT\n                    self._grasp_steps = 0\n                    break\n            # No obstruction found → terminated, return idle\n            return move_action(rx, ry, rtheta, arm_joint, rx, ry, arm_joint, VAC_OFF)\n\n        ob = extract_obstruction(obs, self.current_obs_idx)\n        ob_cx = rect_center_x(ob)\n        pick_y = compute_pick_height(ob[\"height\"])\n        dump_x = compute_dump_x(self._base_obs, self.dump_count)\n\n        # ── RETRACT: pull arm in before moving ────────────────────────────────\n        if self.phase == _RETRACT:\n            if at_arm(arm_joint, ARM_MIN):\n                self.phase = _MOVE\n            return move_action(rx, ry, rtheta, arm_joint, rx, ry, ARM_MIN, VAC_OFF)\n\n        # ── MOVE: position robot above target (high, arm retracted) ──────────\n        elif self.phase == _MOVE:\n            if at_position(rx, ry, ob_cx, pick_y):\n                self.phase = _EXTEND\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, pick_y, ARM_MIN, VAC_OFF)\n\n        # ── EXTEND: lower arm to reach object ────────────────────────────────\n        elif self.phase == _EXTEND:\n            if at_arm(arm_joint, ARM_MAX) and at_position(rx, ry, ob_cx, pick_y):\n                self.phase = _GRASP\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, pick_y, ARM_MAX, VAC_OFF)\n\n        # ── GRASP: activate vacuum for several steps ──────────────────────────\n        elif self.phase == _GRASP:\n            self._grasp_steps += 1\n            if self._grasp_steps >= GRASP_HOLD_S