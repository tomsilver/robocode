─────\n_RETRACT = \"RETRACT\"\n_RISE = \"RISE\"           # raise to CARRY_HEIGHT before moving\n_MOVE = \"MOVE\"           # move horizontally at CARRY_HEIGHT\n_DESCEND_PICK = \"DESCEND_PICK\"  # descend from CARRY_HEIGHT to pick_y\n_EXTEND = \"EXTEND\"\n_GRASP = \"GRASP\"\n_LIFT = \"LIFT\"\n_RAISE = \"RAISE\"\n_CARRY = \"CARRY\"\n_DESCEND = \"DESCEND\"\n_LOWER = \"LOWER\"\n_RELEASE = \"RELEASE\"\n_FIND = \"FIND\"\n_DONE = \"DONE\"\n\n# ── Constants ─────────────────────────────────────────────────────────────────\nGRASP_HOLD_STEPS = 8    # steps to hold vacuum before assuming grasp succeeded\n\n\nclass ClearSurface(Behavior):\n    \"\"\"Pick up each obstruction overlapping the target surface and dump it elsewhere.\"\"\"\n\n    def reset(self, obs):\n        self.phase = _FIND\n        self.current_obs_idx = None\n        self.dump_count = 0\n        self._grasp_steps = 0\n        self._arm_target = ARM_MIN\n        self._dump_x = None\n        self._pick_y = None    # computed per-obstruction\n        self._pick_x = None    # safe pick x (avoids robot-circle collision)\n        self._dump_floor_y = None  # floor height at dump_x (for stacking)\n\n    def initializable(self, obs):\n        return True\n\n    def terminated(self, obs):\n        # Must not be holding anything — vacuum off guarantees obstruction was released\n        return not any_obstruction_on_surface(obs) and not is_vacuum_on(obs)\n\n    def step(self, obs):\n        robot = extract_robot(obs)\n        rx, ry, rtheta, arm_joint = (\n            robot[\"x\"], robot[\"y\"], robot[\"theta\"], robot[\"arm_joint\"]\n        )\n\n        # ── FIND ──────────────────────────────────────────────────────────────\n        if self.phase == _FIND:\n            self.current_obs_idx = None\n            # Pick the obstruction with the highest top first (clears blockers first)\n            best_idx = None\n            best_top = -1.0\n            for i in range(NUM_OBSTRUCTIONS):\n                if obstruction_on_surface(obs, i):\n                    ob_i = extract_obstruction(obs, i)\n                    ob_top = ob_i[\"y\"] + ob_i[\"height\"]\n                    if ob_top > best_top:\n                        best_top = ob_top\n                        best_idx = i\n            # Check if best surface target has a non-surface path blocker\n            if best_idx is not None:\n                blocker = find_blocker_for(obs, best_idx)\n                if blocker is not None:\n                    best_idx = blocker  # clear the blocker first\n            if best_idx is not None:\n                self.current_obs_idx = best_idx\n                self.phase = _RETRACT\n                self._grasp_steps = 0\n                self._dump_x = None\n                self._pick_y = None\n                self._pick_x = None\n                self._dump_floor_y = None\n            return move_action(rx, ry, rtheta, arm_joint, rx, ry, arm_joint, VAC_OFF)\n\n        ob = extract_obstruction(obs, self.current_obs_idx)\n\n        # Compute safe pick x (avoids robot-circle collision with block/neighbors)\n        if self._pick_y is None:\n            ob_cx_default = rect_center_x(ob)\n            # First pass: pick_y at center\n            py_at_center = compute_safe_pick_y(obs, ob_cx_default, ob[\"height\"],\n                                               exclude_idx=self.current_obs_idx)\n            # Find safe pick_x that avoids circle collision during descent\n            safe_x = find_safe_pick_x(obs, ob, py_at_center,\n                                      exclude_idx=self.current_obs_idx)\n            # Recompute pick_y at safe_x\n            self._pick_y = compute_safe_pick_y(obs, safe_x, ob[\"height\"],\n                                               exclude_idx=self.current_obs_idx)\n            self._pick_x = safe_x\n        pick_y = self._pick_y\n        ob_cx = self._pick_x  # use safe pick x throughout all sub-phases\n\n        # Compute dump_x\n        if self._dump_x is None:\n            self._dump_x = find_clear_dump_x(obs, self.current_obs_idx, ob[\"width\"])\n        dump_x = self._dump_x\n\n        # Compute dump floor height (for stacking on previously-placed objects)\n        if self._dump_floor_y is None:\n            self._dump_floor_y = get_floor_height_at(obs, dump_x, self.current_obs_idx,\n                                                     ob[\"width\"] / 2.0)\n        dump_floor_y = self._dump_floor_y\n        dump_pick_y = dump_floor_y + ob[\"height\"] / 2.0 + ARM_MAX + SUCTION_OFFSET\n\n        arm_tgt = compute_arm_target(pick_y, ob[\"y\"], ob[\"height\"])\n\n        # ── RETRACT ───────────────────────────────────────────────────────────\n        if self.phase == _RETRACT:\n            if at_arm(arm_joint, ARM_MIN):\n                self.phase = _RISE\n            return move_action(rx, ry, rtheta, arm_joint, rx, ry, ARM_MIN, VAC_OFF)\n\n        # ── RISE: raise to CARRY_HEIGHT before horizontal move ────────────────\n        elif self.phase == _RISE:\n            if at_position(rx, ry, rx, CARRY_HEIGHT):\n                self.phase = _MOVE\n            return move_action(rx, ry, rtheta, arm_joint, rx, CARRY_HEIGHT, ARM_MIN, VAC_OFF)\n\n        # ── MOVE: move horizontally at CARRY_HEIGHT ───────────────────────────\n        elif self.phase == _MOVE:\n            if abs(rx - ob_cx) <= CARRY_X_TOL:\n                self.phase = _DESCEND_PICK\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, CARRY_HEIGHT, ARM_MIN, VAC_OFF)\n\n        # ── DESCEND_PICK: lower to pick_y ─────────────────────────────────────\n        elif self.phase == _DESCEND_PICK:\n            if at_position(rx, ry, ob_cx, pick_y):\n                self.phase = _EXTEND\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, pick_y, ARM_MIN, VAC_OFF)\n\n        # ── EXTEND: lower arm to just above obstruction top ───────────────────\n        elif self.phase == _EXTEND:\n            self._arm_target = arm_tgt\n            if at_arm(arm_joint, arm_tgt) and at_position(rx, ry, ob_cx, pick_y):\n                self.phase = _GRASP\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, pick_y, arm_tgt, VAC_OFF)\n\n        # ── GRASP: activate vacuum ────────────────────────────────────────────\n        elif self.phase == _GRASP:\n            self._grasp_steps += 1\n            if self._grasp_steps >= GRASP_HOLD_STEPS:\n                self.phase = _LIFT\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, pick_y, self._arm_target, VAC_ON)\n\n        # ── LIFT: retract arm (lifts object) ─────────────────────────────────\n        elif self.phase == _LIFT:\n            if at_arm(arm_joint, ARM_MIN):\n                self.phase = _RAISE\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, pick_y, ARM_MIN, VAC_ON)\n\n        # ── RAISE: move robot up to carry height ─────────────────────────────\n        elif self.phase == _RAISE:\n            if at_position(rx, ry, ob_cx, CARRY_HEIGHT):\n                self.phase = _CARRY\n            return move_action(rx, ry, rtheta, arm_joint, ob_cx, CARRY_HEIGHT, ARM_MIN, VAC_ON)\n\n        # ── CARRY: move horizontally to dump zone ─────────────────────────────\n        elif self.phase == _CARRY:\n            if abs(rx - dump_x) <= CARRY_X_TOL:\n                self.phase = _DESCEND\n            return move_action(rx, ry, rtheta, arm_joint, dump_x, CARRY_HEIGHT, ARM_MIN, VAC_ON)\n\n        # ── DESCEND: lower robot to dump_pick_y (stacking-aware) ─────────────\n        elif self.phase == _DESCEND:\n            if at_position(rx, ry, dump_x, dump_pick_y):\n                self.phase = _LOWER\n            return move_action(rx, ry, rtheta, arm_joint, dump_x, dump_pick_y, ARM_MIN, VAC_ON)\n\n        # ── LOWER: extend arm (places obstruction at dump floor level) ────────\n        elif self.phase == _LOWER:\n            if at_arm(arm_joint, self._arm_target):\n                self.phase = _RELEASE\n            return move_action(rx, ry, rtheta, arm_joint, dump_x, dump_pick_y, self._arm_target, VAC_ON)\n\n        # ── RELEASE: turn off vacuum ──────────────────────────────────────────\n        elif self.phase == _RELEASE:\n            self.dump_count += 1\n            self.phase = _FIND\n            self._dump_x = None\n            self._pick_y = None\n            self._pick_x = None\n            self._dump_floor_y = None\n            return move_action(rx, ry, rtheta, arm_joint, dump_x, dump_pick_y, self._arm_target, VAC_OFF)\n\n        return np.zeros(5, dtype=np.float64)\n\n\nclass PickBlock(Behavior):\n    \"\"\"Position robot over target block, extend arm, activate vacuum.\"\"\"\n\n    def reset(self, obs):\n        self.phase = _RETRACT\n        self._grasp_steps = 0\n        self._arm_target = ARM_MIN\n        self._pick_y = None\n        self._pick_x = None\n\n    def initializable(self, obs):\n        return not any_obstruction_on_surface(obs)\n\n    def terminated(self, obs):\n        return is_vacuum_on(obs)\n\n    def step(self, obs):\n        robot = extract_robot(obs)\n        rx, ry, rtheta, arm_joint = (\n            robot[\"x\"], robot[\"y\"], robot[\"theta\"], robot[\"arm_joint\"]\n        )\n        block = extract_block(obs)\n\n        if self._pick_y is None:\n            default_cx = rect_center_x(block)\n            py_at_center = compute_safe_pick_y(obs, default_cx, block[\"height\"])\n            safe_x = find_safe_pick_x(obs, block, py_at_center)\n            self._pick_x = safe_x\n            self._pick_y = compute_safe_pick_y(obs, safe_x, block[\"height\"])\n        pick_y = self._pick_y\n        block_cx = self._pick_x\n        arm_tgt = compute_arm_target(pick_y, block[\"y\"], block[\"height\"])\n\n        # ── RETRACT ───────────────────────────────────────────────────────────\n        if self.phase == _RETRACT:\n            if at_arm(arm_joint, ARM_MIN):\n                self.phase = _RISE\n            return move_action(rx, ry, rtheta, arm_joint, rx, ry, ARM_MIN, VAC_OFF)\n\n        # ── RISE: raise to CARRY_HEIGHT ───────────────────────────────────────\n        elif self.phase == _RISE:\n            if at_position(rx, ry, rx, CARRY_HEIGHT):\n                self.phase = _MOVE\n            return move_action(rx, ry, rtheta, arm_joint, rx, CARRY_HEIGHT, ARM_MIN, VAC_OFF)\n\n        # ── MOVE: horizontal at CARRY_HEIGHT ──────────────────────────────────\n        elif self.phase == _MOVE:\n            if abs(rx - block_cx) <= CARRY_X_TOL:\n                self.phase = _DESCEND_PICK\n            return move_action(rx, ry, rtheta, arm_joint, block_cx, CARRY_HEIGHT, ARM_MIN, VAC_OFF)\n\n        # ── DESCEND_PICK: lower to pick_y ─────────────────────────────────────\n        elif self.phase == _DESCEND_PICK:\n            if at_position(rx, ry, block_cx, pick_y):\n                self.phase = _EXTEND\n            return move_action(rx, ry, rtheta, arm_joint, block_cx, pick_y, ARM_MIN, VAC_OFF)\n\n        # ── EXTEND ────────────────────────────────────────────────────────────\n        elif self.phase == _EXTEND:\n            self._arm_target = arm_tgt\n            if at_arm(arm_joint, arm_tgt) and at_position(rx, ry, block_cx, pick_y):\n                self.phase = _GRASP\n            return move_action(rx, ry, rtheta, arm_joint, block_cx, pick_y, arm_tgt, VAC_OFF)\n\n        # ── GRASP ─────────────────────────────────────────────────────────────\n        elif self.phase == _GRASP:\n            self._grasp_steps += 1\n            return move_action(rx, ry, rtheta, arm_joint, block_cx, pick_y, self._arm_target, VAC_ON)\n\n        return np.zeros(5, dtype=np.float64)\n\n\nclass PlaceBlock(Behavior):\n    \"\"\"Carry target block to surface center and release vacuum.\"\"\"\n\n    def reset(self, obs):\n        self.phase = _LIFT\n        self._release_steps = 0\n        robot = extract_robot(obs)\n        block = extract_block(obs)\n        self._arm_target = robot[\"arm_joint\"]\n        self._block_height = block[\"height